# LeanKernel Environment Configuration

# Postgres
POSTGRES_DB=leankernel
POSTGRES_USER=leankernel
POSTGRES_PASSWORD=leankernel-dev-password
POSTGRES_PORT=5432

# LiteLLM
LITELLM_MASTER_KEY=sk-leankernel-local
LITELLM_PORT=4000
OPENAI_API_KEY=
GROQ_API_KEY=
GROQ_API_KEY_2=
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
AZURE_AI_API_KEY=
AZURE_AI_API_BASE=
AZURE_AI_API_KEY_2=
AZURE_AI_API_BASE_2=
GITHUB_COPILOT_OAUTH_TOKEN=
GITHUB_COPILOT_API_BASE=
OLLAMA_BASE_URL=http://host.docker.internal:11434
NVIDIA_API_KEY=
NVIDIA_API_BASE=

# GBrain
GBRAIN_AUTH_TOKEN=
GBRAIN_PORT=8789
GBRAIN_EMBEDDING_MODEL=openai:embedding-small
GBRAIN_EMBEDDING_DIMENSIONS=3072
LITELLM_BASE_URL=http://litellm:4000
LITELLM_API_KEY=sk-leankernel-local

# Browser service
WEBWRIGHT_ENABLED=false
WEBWRIGHT_PORT=8000
WEBWRIGHT_API_TOKEN=
WEBWRIGHT_LITELLM_KEY=
WEBWRIGHT_MODEL=gpt-4o
WEBWRIGHT_MAX_CONCURRENT_RUNS=2
WEBWRIGHT_MAX_QUEUE_DEPTH=20
WEBWRIGHT_RUN_WALL_CLOCK_SECONDS=600
WEBWRIGHT_ARTIFACT_TTL_HOURS=24
WEBWRIGHT_DOMAIN_ALLOWLIST=
WEBWRIGHT_DOMAIN_DENYLIST=

# Engine
LEANKERNEL_ENGINE_PORT=5080
DEFAULT_MODEL=gpt-4o-mini
CONTEXT_WINDOW_TOKENS=128000
GATEWAY_API_KEY=

# Timezone
TZ=America/Toronto
