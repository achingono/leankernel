# ── LiteLLM Provider Key Instances (provider_keys in config/litellm/config.yaml) ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# groq1 / groq2
GROQ_API_KEY=
GROQ_API_KEY_2=
# azure1 / azure2
AZURE_AI_API_KEY=
AZURE_AI_API_BASE=
AZURE_AI_API_KEY_2=
AZURE_AI_API_BASE_2=
# gemini1 / gemini2 / gemini3
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
# local
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── Search Tools ─────────────────────────────────────────
BRAVE_SEARCH_API_KEY=

# ── LiteLLM ────────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-LeanKernel-local
LITELLM_SALT_KEY=change-me-to-random-string
LITELLM_PORT=4000

# ── Signal ─────────────────────────────────────────────────
SIGNAL_PHONE_NUMBER=+1234567890

# ── Qdrant ─────────────────────────────────────────────────
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# ── LeanKernel Engine ───────────────────────────────────────────
LEANKERNEL_HEALTH_PORT=5080

# ── General ────────────────────────────────────────────────
TZ=America/Toronto
