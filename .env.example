# LeanKernel Environment Configuration

# Postgres
POSTGRES_DB=leankernel
POSTGRES_USER=leankernel
POSTGRES_PASSWORD=leankernel-dev-password
POSTGRES_PORT=5432

# LiteLLM
LITELLM_MASTER_KEY=sk-leankernel-local
LITELLM_PORT=4000
OLLAMA_BASE_URL=http://host.docker.internal:11434

# GBrain
GBRAIN_AUTH_TOKEN=
GBRAIN_PORT=8789
# GBrain embedding provider (choose one)
OPENAI_API_KEY=
ZEROENTROPY_API_KEY=
ANTHROPIC_API_KEY=

# Engine
ENGINE_PORT=5080
DEFAULT_MODEL=gpt-4o-mini
CONTEXT_WINDOW_TOKENS=128000
GATEWAY_API_KEY=

# Timezone
TZ=America/Toronto
