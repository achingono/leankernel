{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "OpenTelemetry": {
    "ConsoleExporterEnabled": false,
    "Otlp": {
      "Endpoint": ""
    }
  },
  "LeanKernel": {
    "LiteLlm": {
      "BaseUrl": "http://litellm:4000",
      "ApiKey": "sk-leankernel-local",
      "DefaultModel": "tool",
      "ContextWindowTokens": 128000
    },
    "Context": {
      "SystemPromptBudgetRatio": 0.15,
      "WikiFactsBudgetRatio": 0.20,
      "ConversationBudgetRatio": 0.40,
      "RetrievalBudgetRatio": 0.20,
      "ToolsBudgetRatio": 0.05,
      "ResponseHeadroomRatio": 0.25,
      "RecentTurnsVerbatim": 6,
      "CompactedTurnsMax": 10,
      "EntityExpansionDepth": 2
    },
    "History": {
      "RecentTurnsVerbatim": 6,
      "CompactedTurnsMax": 10,
      "SummarizedTurnsMax": 20,
      "EnableCompaction": true,
      "EnableSummarization": true,
      "CompactionModel": "small",
      "CompactionTemperature": 0.1,
      "MaxSummaryTokens": 200,
      "PersistCompactionMarkers": true
    },
    "Retrieval": {
      "ScopingEnabled": true,
      "DefaultScope": "global",
      "MaxEntityExpansionResults": 5,
      "EntityBoostMultiplier": 1.5,
      "MinScopeRelevanceScore": 0.3,
      "EmitRetrievalDiagnostics": true,
      "ScopePolicies": [
        {
          "Name": "global",
          "IncludeNamespaces": [],
          "ExcludeNamespaces": ["identity"],
          "RequiredMetadataKeys": [],
          "MinScore": 0.0
        },
        {
          "Name": "personal",
          "IncludeNamespaces": ["identity", "preferences"],
          "ExcludeNamespaces": [],
          "RequiredMetadataKeys": [],
          "MinScore": 0.2
        }
      ]
    },
    "Routing": {
      "Enabled": false,
      "QualityMinOutputLength": 50,
      "QualityMinConstraintCoverage": 0.6,
      "MaxEscalationAttempts": 2,
      "RefusalPatterns": [
        "I cannot",
        "I'm sorry, I can't",
        "As an AI language model",
        "I'm not able to",
        "I don't have the ability"
      ],
      "ShadowRoutingEnabled": false,
      "ShadowModel": "",
      "Economy": { "Model": "small", "MaxTokens": 4096, "CostWeight": 0.3 },
      "Standard": { "Model": "medium", "MaxTokens": 8192, "CostWeight": 1.0 },
      "Premium": { "Model": "large", "MaxTokens": 16384, "CostWeight": 3.0 },
      "Scoring": {
        "HighComplexityTokenThreshold": 2000,
        "MediumComplexityTokenThreshold": 500,
        "ToolUsageComplexityBoost": 0.3,
        "MultiTurnComplexityBoost": 0.2,
        "LongContextComplexityBoost": 0.2
      }
    },
    "Orchestration": {
      "Enabled": false,
      "MaxWorkerConcurrency": 3,
      "MaxOrchestrationDepth": 2,
      "WorkerTimeout": "00:01:00",
      "Workers": [
        {
          "Name": "researcher",
          "Description": "Searches knowledge base and retrieves relevant information",
          "Model": "small",
          "SystemPrompt": "You are a research assistant. Search for and summarize relevant information.",
          "AllowedTools": ["wiki_search", "wiki_read"],
          "AllowedCategories": ["knowledge"],
          "Scope": "global"
        },
        {
          "Name": "writer",
          "Description": "Drafts and refines written content",
          "Model": "medium",
          "SystemPrompt": "You are a writing assistant. Draft clear, concise content based on provided context.",
          "AllowedTools": [],
          "AllowedCategories": [],
          "Scope": null
        }
      ]
    },
    "GBrain": {
      "BaseUrl": "http://gbrain:8789",
      "AuthToken": "",
      "TimeoutSeconds": 30
    },
    "Webwright": {
      "Enabled": false,
      "BaseUrl": "http://webwright:8000",
      "ApiToken": "",
      "RequestTimeoutSeconds": 15,
      "MaxArtifactBytes": 2000000,
      "MaxOutputChars": 12000,
      "DefaultModel": "tool",
      "HealthProbe": {
        "Enabled": true
      }
    },
    "Identity": {
      "AgentProfilePageKey": "identity-agent-main",
      "UserPreferencePageKey": "identity-user-default",
      "OnboardingConfidenceThreshold": 0.6,
      "MaxOnboardingQuestionsPerTurn": 2,
      "EnableIdentityExtraction": true,
      "AllowedIdentityFields": [
        "preferred_name",
        "timezone",
        "locale",
        "communication_style",
        "work_style",
        "recurring_goals",
        "tool_preferences",
        "autonomy_level"
      ]
    },
    "Database": {
      "ConnectionString": "Host=database;Database=leankernel;Username=leankernel;Password=leankernel"
    },
    "DatabaseQuery": {
      "MaxRows": 200,
      "DefaultTimeoutSeconds": 30,
      "Connections": [
        {
          "Name": "postgres-main",
          "Provider": "postgres",
          "ConnectionString": "Host=database;Database=leankernel;Username=leankernel_ro;Password=leankernel_ro",
          "ReadOnly": true,
          "AllowedSchemas": [ "public" ]
        },
        {
          "Name": "sqlite-local",
          "Provider": "sqlite",
          "ConnectionString": "Data Source=/app/data/leankernel.db;Mode=ReadOnly",
          "ReadOnly": true,
          "AllowedSchemas": []
        }
      ]
    },
    "Diagnostics": {
      "Enabled": true,
      "PersistToDatabase": true,
      "ContextDiagnosticsEnabled": true,
      "MaxDiagnosticsPerSession": 100,
      "ServiceName": "leankernel"
    },
    "Channels": {
      "Enabled": true,
      "Signal": {
        "Enabled": false,
        "DaemonUrl": "http://signal:8080",
        "PhoneNumber": "",
        "PollIntervalSeconds": 2,
        "ReconnectDelaySeconds": 5,
        "MaxReconnectAttempts": 10
      },
      "ChannelAuth": [
        {
          "ChannelId": "signal",
          "AllowedSenders": [],
          "RequireAuth": true
        }
      ]
    },
    "Enhancement": {
      "Enabled": true,
      "KnowledgeSynthesisEnabled": true,
      "RefusalInterceptionEnabled": true,
      "CitationInjectionEnabled": false,
      "MaxEnhancementTimeMs": 5000
    },
    "Learning": {
      "Enabled": true,
      "FactExtractionEnabled": true,
      "IntentExtractionEnabled": true,
      "CapabilityGapDetectionEnabled": true,
      "EngagementTrackingEnabled": true,
      "MaxConcurrentLearningTasks": 2,
      "QueueCapacity": 100,
      "ExtractionModel": "small",
      "ExtractionTemperature": 0.1,
      "MinTurnLengthForExtraction": 50,
      "IntentExtractionModel": "small",
      "IntentExtractionTemperature": 0.0,
      "IntentExtractionMinConfidence": 0.72,
      "IntentExtractionMaxUpdatesPerTurn": 3
    },
    "FileSystem": {
      "AllowedRoot": "/app/data",
      "ScratchRoot": "/app/data/.scratch",
      "MaxDownloadBytes": 10000000,
      "MaxExtractedCharacters": 20000,
      "PythonExecutable": "python3",
      "PaddleOcrModule": "paddleocr",
      "PdfToImageModule": "pdf2image"
    },
    "Hardening": {
      "SpendGuard": {
        "Enabled": false,
        "MaxDailySpendUsd": 10.0,
        "MaxSessionSpendUsd": 2.0,
        "MaxMonthlySpendUsd": 100.0,
        "WarnAtPercent": "80"
      },
      "RateLimit": {
        "Enabled": true,
        "RequestsPerMinute": 30,
        "RequestsPerHour": 300,
        "ConcurrentRequests": 5
      },
      "HealthTracking": {
        "CheckIntervalSeconds": 30,
        "UnhealthyThreshold": 3,
        "HealthyThreshold": 2
      },
      "Resilience": {
        "RetryCount": 2,
        "RetryDelayMs": 1000,
        "CircuitBreakerThreshold": 5,
        "CircuitBreakerDurationSeconds": 30,
        "TimeoutSeconds": 30
      }
    },
    "Scheduler": {
      "Enabled": true,
      "TickIntervalSeconds": 60,
      "MaxConcurrentJobs": 2,
      "DefaultTimezone": "America/Toronto",
      "Jobs": [
        {
          "Name": "morning-briefing",
          "CronExpression": "0 8 * * *",
          "JobType": "agent-prompt",
          "Prompt": "Provide a brief morning summary of pending tasks and recent updates.",
          "ChannelId": "scheduler",
          "UserId": "system",
          "Enabled": false,
          "Parameters": {}
        },
        {
          "Name": "knowledge-maintenance",
          "CronExpression": "0 2 * * 0",
          "JobType": "maintenance",
          "Enabled": false,
          "Parameters": {
            "task": "cleanup-old-diagnostics",
            "retention_days": "30"
          }
        },
        {
          "Name": "emanate-blogging-ideas",
          "CronExpression": "0 19 * * 5",
          "JobType": "agent-prompt",
          "Prompt": "Using the available tools, analyze recent Emanate interactions for my personal social accounts (LinkedIn: linkedin-achingono, Twitter/X: twitter-achingono). Extract actionable blog post ideas derived from what people engaged with (themes, recurring questions, and the strongest comment topics).\n\nThen create new tasks in Microsoft To Do in the list named 'Blogging' (use the tools to locate the list and its id). Create 7 tasks. For each task:\n- Title: 'Blog idea: <short catchy title>'\n- Notes: include (1) which observed themes/comments it came from, (2) a 3-5 bullet outline, and (3) one specific example/angle I can use.\n\nReturn a concise summary of the created tasks (titles + a one-line rationale each).",
          "ChannelId": "scheduler",
          "UserId": "system",
          "Enabled": true,
          "Parameters": {
            "lookback_days": "14",
            "timezone": "America/Toronto"
          }
        },
        {
          "Name": "emanate-branding-review",
          "CronExpression": "0 19 * * 5",
          "JobType": "agent-prompt",
          "Prompt": "Using the available tools, review the quality of my personal branding in recent Emanate engagement activity for LinkedIn (linkedin-achingono) and Twitter/X (twitter-achingono).\n\n1) Fetch recent engagement rows (especially comments) and summarize:\n- Tone consistency with my voice, specificity vs. generic remarks, and whether my comments add real value.\n- Common failure modes (e.g., off-topic, too broad, repetitive phrasing, missing evidence, or overly cautious responses).\n\n2) Draft improved engagement prompts for each platform to address the issues you found. Keep the prompts aligned with my constraints: sound human, be specific, avoid engagement-bait, and only comment when I can write a high-quality, safe comment.\n\n3) Patch the platform engagement_prompt for each platform using the Emanate tools.\n\nReturn a concise report: issues found + the final engagement_prompt content (or a shortened excerpt if very long), and confirmation that the platform prompts were updated.",
          "ChannelId": "scheduler",
          "UserId": "system",
          "Enabled": true,
          "Parameters": {
            "lookback_days": "30",
            "timezone": "America/Toronto"
          }
        }
      ]
    },
    "Gateway": {
      "ApiKey": ""
    },
    "DocumentIngestion": {
      "Enabled": true,
      "MaxConcurrentJobs": 3,
      "MaxQueuedDocuments": 100,
      "WatchFolderEnabled": false,
      "WatchFolderPath": "/app/data/documents",
      "WatchFilter": "*.*",
      "WatchIncludeSubdirectories": true,
      "WatchStartupScanEnabled": false,
      "WatchSettleDelaySeconds": 2,
      "WatchPollingIntervalSeconds": 30,
      "WatchDefaultTags": [ "auto-import" ],
      "ManagedStoragePath": "/app/data/managed-documents"
    }
  },
  "AllowedHosts": "*"
}
