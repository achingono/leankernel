{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug"
    }
  },
  "LeanKernel": {
    "LiteLlm": {
      "BaseUrl": "http://localhost:4000",
      "ApiKey": "sk-dev"
    },
    "GBrain": {
      "BaseUrl": "http://localhost:8789"
    },
    "Webwright": {
      "Enabled": false,
      "BaseUrl": "http://localhost:8000",
      "ApiToken": ""
    },
    "Database": {
      "ConnectionString": "Host=localhost;Database=leankernel;Username=leankernel;Password=leankernel"
    },
    "DatabaseQuery": {
      "MaxRows": 200,
      "DefaultTimeoutSeconds": 30,
      "Connections": [
        {
          "Name": "postgres-main",
          "Provider": "postgres",
          "ConnectionString": "Host=localhost;Database=leankernel;Username=leankernel;Password=leankernel",
          "ReadOnly": true,
          "AllowedSchemas": [ "public" ]
        },
        {
          "Name": "sqlite-local",
          "Provider": "sqlite",
          "ConnectionString": "Data Source=../../data/leankernel-dev.db;Mode=ReadOnly",
          "ReadOnly": true,
          "AllowedSchemas": []
        }
      ]
    },
    "Diagnostics": {
      "ContextDiagnosticsEnabled": true,
      "MaxDiagnosticsPerSession": 100
    },
    "Channels": {
      "Signal": {
        "DaemonUrl": "http://localhost:8080"
      }
    },
    "FileSystem": {
      "AllowedRoot": "/app/data",
      "ScratchRoot": "/app/data/.scratch",
      "MaxDownloadBytes": 10000000,
      "MaxExtractedCharacters": 20000,
      "PythonExecutable": "python3",
      "PaddleOcrModule": "paddleocr",
      "PdfToImageModule": "pdf2image"
    }
  }
}
