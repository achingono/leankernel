@page "/"
@page "/chat"
@page "/chat/{SessionId}"
@inject ChatService ChatService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@implements IAsyncDisposable
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>LeanKernel Chat</PageTitle>

<div class="chat-page">
    @if (!string.IsNullOrWhiteSpace(ChatService.ErrorMessage))
    {
        <FluentMessageBar Title="Error" Intent="@MessageIntent.Error">
            @ChatService.ErrorMessage
        </FluentMessageBar>
    }

    <FluentMultiSplitter Orientation="Orientation.Horizontal" Class="chat-horizontal-splitter">
        <FluentMultiSplitterPane Size="260px" Min="180px" Max="400px" Class="chat-session-pane">
            <FluentStack Orientation="Orientation.Vertical" Class="chat-session-list">
                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center"
                             Style="justify-content: space-between; width: 100%; padding: var(--lk-space-s); padding-bottom: 0;">
                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Sessions</FluentLabel>
                    <FluentButton Appearance="Appearance.Lightweight"
                                  Id="chat-new-session-button"
                                  OnClick="StartNewSessionAsync"
                                  AriaLabel="New session"
                                  Title="New session"
                                  Style="height: 24px; min-width: 24px; padding: 0;">
                        <FluentIcon Value="@(new Icons.Regular.Size16.Add())" />
                    </FluentButton>
                </FluentStack>

                @if (ChatService.Sessions.Count == 0)
                {
                    <div style="padding: var(--lk-space-s);">
                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">No sessions yet</FluentLabel>
                    </div>
                }
                else
                {
                    <div class="chat-session-items">
                        @foreach (var session in ChatService.Sessions)
                        {
                            <button type="button"
                                    class="chat-session-item @(string.Equals(session.SessionId, ChatService.CurrentSessionId, StringComparison.Ordinal) ? "active" : "")"
                                    @onclick="() => NavigateToSession(session.SessionId)"
                                    title="@session.Preview">
                                <span class="chat-session-item-title">@session.Title</span>
                            </button>
                        }
                    </div>
                }
            </FluentStack>
        </FluentMultiSplitterPane>

        <FluentMultiSplitterPane Size="1fr" Class="chat-content-pane">
            <FluentMultiSplitter Orientation="Orientation.Vertical" Class="chat-vertical-splitter">
                <FluentMultiSplitterPane Size="1fr" Class="chat-messages-pane">
                    <FluentStack Orientation="Orientation.Vertical" Class="chat-main">
                        <PageHeader Title="Chat" Subtitle="@GetHeaderSubtitle()" />

                        <div id="chat-message-list" class="chat-message-list">
                            @if (ChatService.Messages.Count == 0 && !ChatService.IsLoading)
                            {
                                <FluentCard Class="lk-empty-state">
                                    <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center" Style="gap: var(--lk-space-xs);">
                                        <div style="background: linear-gradient(135deg, var(--accent-fill-rest) 0%, #a855f7 100%); width: 64px; height: 64px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto var(--lk-space-xs) auto; box-shadow: 0 8px 16px var(--lk-glow-indigo);">
                                            <fluent-icon name="chat" value="@(new Icons.Regular.Size32.Chat())" color="white" />
                                        </div>
                                        <FluentLabel Typo="Typography.H3" Weight="FontWeight.Bold" Style="background: linear-gradient(90deg, var(--accent-fill-rest) 0%, #a855f7 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: var(--lk-space-xxs);">Start a LeanKernel conversation</FluentLabel>
                                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral" Style="max-width: 440px; margin: 0 auto; line-height: 1.6;">
                                            Ask a question, inspect previous sessions, and keep the existing Gateway APIs available for automation.
                                        </FluentLabel>
                                    </FluentStack>
                                </FluentCard>
                            }
                            else
                            {
                                @foreach (var message in ChatService.Messages)
                                {
                                    <ChatMessage Message="message" />
                                }
                            }

                            @if (ChatService.IsLoading)
                            {
                                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Class="lk-loading">
                                    <FluentProgressRing />
                                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">LeanKernel is thinking…</FluentLabel>
                                </FluentStack>
                            }
                        </div>
                    </FluentStack>
                </FluentMultiSplitterPane>

                <FluentMultiSplitterPane Size="auto" Min="100px" Max="400px" Class="chat-composer-pane">
                    <FluentStack Orientation="Orientation.Vertical" Class="chat-composer-shell">
                        <FluentTextArea Id="chat-composer-input"
                                       @bind-Value="ChatService.ComposerText"
                                       Rows="4"
                                       Maxlength="12000"
                                       Placeholder="Ask LeanKernel anything…"
                                       Disabled="@ChatService.IsLoading"
                                       Class="chat-composer-input" />
                        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Class="chat-composer-footer">
                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Enter to send · Shift+Enter for newline</FluentLabel>
                            <FluentButton Id="chat-send-button"
                                          Appearance="Appearance.Accent"
                                          OnClick="SendAsync"
                                          Disabled="@IsSendDisabled"
                                          Title="Send message"
                                          AriaLabel="Send message">
                                <FluentIcon Value="@(new Icons.Regular.Size16.Send())" />
                            </FluentButton>
                        </FluentStack>
                    </FluentStack>
                </FluentMultiSplitterPane>
            </FluentMultiSplitter>
        </FluentMultiSplitterPane>
    </FluentMultiSplitter>
</div>

@code {
    private const string OwnerStorageKey = "leankernel.chat.owner-id";
    private const string SessionCacheStorageKey = "leankernel.chat.sessions";
    private readonly CancellationTokenSource _disposeCts = new();
    private bool _initialized;
    private bool _shouldScroll;
    private bool _disposed;

    [Parameter]
    public string? SessionId { get; set; }

    private bool IsSendDisabled => ChatService.IsLoading || string.IsNullOrWhiteSpace(ChatService.ComposerText);

    protected override void OnInitialized()
    {
        ChatService.SessionsChanged += HandleSessionsChanged;
        Navigation.LocationChanged += HandleLocationChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_initialized && !string.IsNullOrWhiteSpace(SessionId)
            && !string.Equals(SessionId, ChatService.CurrentSessionId, StringComparison.Ordinal))
        {
            await ChatService.OpenSessionAsync(SessionId, _disposeCts.Token);
            await PersistSessionCacheAsync();
            _shouldScroll = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var isAuthenticated = user.Identity?.IsAuthenticated == true
                && string.Equals(user.Identity.AuthenticationType, LeanKernel.Gateway.Auth.ForwardedAuthHandler.SchemeName, StringComparison.Ordinal);
            var authenticatedUserKey = isAuthenticated
                ? GetUserKey(authState.User)
                : null;

            var legacyOwnerId = await GetLegacyOwnerIdAsync();

            string ownerId;
            string? legacyForMigration = null;
            bool authFlag;

            if (isAuthenticated && !string.IsNullOrWhiteSpace(authenticatedUserKey))
            {
                ownerId = authenticatedUserKey!;
                legacyForMigration = legacyOwnerId;
                authFlag = true;
            }
            else
            {
                ownerId = legacyOwnerId ?? Guid.NewGuid().ToString("N");
                if (legacyOwnerId is null)
                {
                    await JS.InvokeVoidAsync("leanKernelChat.storage.set", OwnerStorageKey, ownerId);
                }
                authFlag = false;
            }

            var cacheKey = authFlag ? $"{SessionCacheStorageKey}.{GetCacheKeySuffix(ownerId)}" : SessionCacheStorageKey;
            var cachedSessions = await LoadCachedSessionsAsync(cacheKey);

            await ChatService.InitializeAsync(ownerId, cachedSessions, SessionId, legacyForMigration, authFlag, _disposeCts.Token);

            if (legacyForMigration is not null && authFlag)
            {
                await JS.InvokeVoidAsync("leanKernelChat.storage.remove", OwnerStorageKey);
            }

            await PersistSessionCacheAsync(cacheKey);

            await JS.InvokeVoidAsync("leanKernelChat.registerComposer", "chat-composer-input", "chat-send-button");

            _initialized = true;
            _shouldScroll = true;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (_shouldScroll)
        {
            _shouldScroll = false;
            await JS.InvokeVoidAsync("leanKernelChat.scrollToBottom", "chat-message-list");
        }
    }

    private static string GetUserKey(ClaimsPrincipal user)
    {
        var email = user.FindFirst(ClaimTypes.Email)?.Value
                 ?? user.FindFirst("email")?.Value;
        if (!string.IsNullOrWhiteSpace(email))
            return email;

        var sub = user.FindFirst("sub")?.Value;
        if (!string.IsNullOrWhiteSpace(sub))
            return sub;

        return user.FindFirst(ClaimTypes.Name)?.Value
            ?? user.FindFirst("name")?.Value
            ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value
            ?? "unknown-user";
    }

    private static string GetCacheKeySuffix(string key)
    {
        using var sha = System.Security.Cryptography.SHA256.Create();
        var hash = sha.ComputeHash(System.Text.Encoding.UTF8.GetBytes(key));
        return Convert.ToHexString(hash).ToLowerInvariant()[..16];
    }

    private async Task<string?> GetLegacyOwnerIdAsync()
    {
        return await JS.InvokeAsync<string?>("leanKernelChat.storage.get", OwnerStorageKey);
    }

    private void HandleSessionsChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task SendAsync()
    {
        var text = await JS.InvokeAsync<string?>("leanKernelChat.getTextareaValue", "chat-composer-input");
        ChatService.ComposerText = text ?? string.Empty;

        var sent = await ChatService.SendAsync(_disposeCts.Token);
        var cacheKey = GetCurrentCacheKey();
        await PersistSessionCacheAsync(cacheKey);

        if (!sent)
        {
            return;
        }

        _shouldScroll = true;

        if (!string.IsNullOrWhiteSpace(ChatService.CurrentSessionId))
        {
            Navigation.NavigateTo($"/chat/{ChatService.CurrentSessionId}", replace: true);
        }
    }

    private async Task StartNewSessionAsync()
    {
        var sessionId = await ChatService.CreateNewSessionAsync(_disposeCts.Token);
        var cacheKey = GetCurrentCacheKey();
        await PersistSessionCacheAsync(cacheKey);
        _shouldScroll = true;
        Navigation.NavigateTo($"/chat/{sessionId}");
    }

    private void NavigateToSession(string sessionId)
    {
        Navigation.NavigateTo($"/chat/{sessionId}");
    }

    private string GetCurrentCacheKey()
    {
        return ChatService.IsAuthenticated && !string.IsNullOrWhiteSpace(ChatService.OwnerId)
            ? $"{SessionCacheStorageKey}.{GetCacheKeySuffix(ChatService.OwnerId)}"
            : SessionCacheStorageKey;
    }

    private async Task<IReadOnlyList<ChatSessionSummary>> LoadCachedSessionsAsync(string cacheKey)
    {
        var json = await JS.InvokeAsync<string?>("leanKernelChat.storage.get", cacheKey);
        if (string.IsNullOrWhiteSpace(json))
        {
            json = await JS.InvokeAsync<string?>("leanKernelChat.storage.get", SessionCacheStorageKey);
        }

        if (string.IsNullOrWhiteSpace(json))
        {
            return [];
        }

        try
        {
            return JsonSerializer.Deserialize<List<ChatSessionSummary>>(json) ?? [];
        }
        catch (JsonException)
        {
            return [];
        }
    }

    private Task PersistSessionCacheAsync(string? cacheKey = null)
        => JS.InvokeVoidAsync(
            "leanKernelChat.storage.set",
            cacheKey ?? GetCurrentCacheKey(),
            JsonSerializer.Serialize(ChatService.Sessions)).AsTask();

    private string GetHeaderSubtitle()
    {
        if (string.IsNullOrWhiteSpace(ChatService.CurrentSessionId))
        {
            return "Create a session or pick a recent conversation.";
        }

        var session = ChatService.Sessions.FirstOrDefault(item => string.Equals(item.SessionId, ChatService.CurrentSessionId, StringComparison.Ordinal));
        return session is null
            ? $"Session {ChatService.CurrentSessionId}"
            : $"{session.Title} · Updated {session.UpdatedAt.LocalDateTime:g}";
    }

    private void Cleanup()
    {
        ChatService.SessionsChanged -= HandleSessionsChanged;
        Navigation.LocationChanged -= HandleLocationChanged;
    }

    private void CleanupAndDisposeCts()
    {
        if (_disposed)
        {
            return;
        }

        _disposed = true;
        Cleanup();

        if (!_disposeCts.IsCancellationRequested)
        {
            _disposeCts.Cancel();
        }

        _disposeCts.Dispose();
    }

    public void Dispose()
    {
        CleanupAndDisposeCts();
    }

    public async ValueTask DisposeAsync()
    {
        if (_disposed)
        {
            return;
        }

        _disposed = true;
        Cleanup();

        if (!_disposeCts.IsCancellationRequested)
        {
            await _disposeCts.CancelAsync();
        }

        _disposeCts.Dispose();
    }
}
