@page "/onboarding"
@inject OnboardingService OnboardingService
@inject IJSRuntime JS
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>LeanKernel Setup</PageTitle>

@if (!_initialized)
{
    <FluentStack Orientation="Orientation.Vertical"
                 HorizontalAlignment="HorizontalAlignment.Center"
                 VerticalAlignment="VerticalAlignment.Center"
                 Style="padding: 3rem; gap: 1rem;">
        <FluentCard Style="padding: 2rem; min-width: 320px; text-align: center;">
            <FluentStack Orientation="Orientation.Vertical"
                         HorizontalAlignment="HorizontalAlignment.Center"
                         Style="gap: 0.75rem;">
                <FluentProgressRing Style="width: 32px; height: 32px;" />
                <FluentLabel Typo="Typography.PageTitle" Weight="FontWeight.Bold">Setup</FluentLabel>
                <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Loading your onboarding profile…</FluentLabel>
            </FluentStack>
        </FluentCard>
    </FluentStack>
}
else
{
    <FluentStack Orientation="Orientation.Vertical" Style="gap: 1rem;">
        <FluentCard Style="padding: 1.5rem;">
            <FluentStack Orientation="Orientation.Horizontal"
                         VerticalAlignment="VerticalAlignment.Center"
                         Wrap="true"
                         Style="justify-content: space-between; gap: 1rem;">
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem; max-width: 720px;">
                    <FluentLabel Typo="Typography.PageTitle" Weight="FontWeight.Bold">Guided setup</FluentLabel>
                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Tell LeanKernel how to address you, what domains matter most, and what outcomes you want help with.</FluentLabel>
                </FluentStack>
                <FluentBadge Appearance="Appearance.Accent">Step @(CurrentStepIndex + 1) of @Steps.Count</FluentBadge>
            </FluentStack>
        </FluentCard>

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <FluentMessageBar Title="Error" Intent="@MessageIntent.Error">
                @_errorMessage
            </FluentMessageBar>
        }

        @if (!string.IsNullOrWhiteSpace(_successMessage))
        {
            <FluentMessageBar Title="Success" Intent="@MessageIntent.Success">
                @_successMessage
            </FluentMessageBar>
        }

        <FluentStack Orientation="Orientation.Horizontal" Wrap="true" Style="align-items: flex-start; gap: 1rem;">
            <FluentCard Style="flex: 1 1 720px; padding: 1.5rem;" aria-busy="@_isSaving">
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 1rem;">
                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.75rem;" aria-label="Onboarding progress">
                        @for (var index = 0; index < Steps.Count; index++)
                        {
                            var step = Steps[index];
                            var isActive = index == CurrentStepIndex;
                            var isComplete = index < CurrentStepIndex || (_saveCompleted && index == Steps.Count - 1);
                            var badgeAppearance = isActive ? Appearance.Accent : isComplete ? Appearance.Neutral : Appearance.Lightweight;
                            var cardStyle = isActive
                                ? "padding: 0.75rem; border: 1px solid var(--accent-fill-rest);"
                                : "padding: 0.75rem;";

                            <FluentCard Style="@cardStyle" aria-current="@(isActive ? "step" : null)">
                                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 0.75rem;">
                                    <FluentBadge Appearance="@badgeAppearance">@(index + 1)</FluentBadge>
                                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.15rem;">
                                        <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">@step.Label</FluentLabel>
                                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@step.Hint</FluentLabel>
                                    </FluentStack>
                                </FluentStack>
                            </FluentCard>
                        }
                    </FluentStack>

                    @if (_saveCompleted)
                    {
                        <FluentCard Style="padding: 1.25rem;">
                            <FluentStack Orientation="Orientation.Vertical" Style="gap: 1rem;">
                                <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">Profile saved</FluentLabel>
                                <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Your onboarding profile is now written to the GBrain wiki pages for identity and goals.</FluentLabel>
                                <FluentStack Orientation="Orientation.Horizontal" Wrap="true" Style="gap: 0.75rem;">
                                    <FluentButton Appearance="Appearance.Accent" OnClick='@(() => JS.InvokeVoidAsync("open", "/chat", "_self").AsTask())'>Go to Chat</FluentButton>
                                    <FluentButton Appearance="Appearance.Outline" OnClick="ReviewSummaryAsync">Review summary</FluentButton>
                                </FluentStack>
                            </FluentStack>
                        </FluentCard>
                    }
                    else
                    {
                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 1rem;">
                            @switch (CurrentStepIndex)
                            {
                                case 0:
                                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 1rem;">
                                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem;">
                                            <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">Welcome to LeanKernel</FluentLabel>
                                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">This guided setup creates durable identity pages so LeanKernel can personalize retrieval, tone, and follow-up support without asking you to repeat yourself every session.</FluentLabel>
                                        </FluentStack>

                                        <FluentStack Orientation="Orientation.Horizontal" Wrap="true" Style="gap: 1rem; align-items: stretch;">
                                            <FluentCard Style="flex: 1 1 280px; padding: 1rem;">
                                                <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.5rem;">
                                                    <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">What we capture</FluentLabel>
                                                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">• How you want LeanKernel to address and respond to you</FluentLabel>
                                                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">• Knowledge domains that should shape retrieval and memory</FluentLabel>
                                                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">• Goals that help prioritize future support</FluentLabel>
                                                </FluentStack>
                                            </FluentCard>

                                            <FluentCard Style="flex: 1 1 280px; padding: 1rem;">
                                                <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.75rem;">
                                                    <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">What gets written</FluentLabel>
                                                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.5rem;">
                                                        <FluentBadge Appearance="Appearance.Neutral">@LeanKernel.Gateway.Services.OnboardingService.UserProfilePageKey</FluentBadge>
                                                        <FluentBadge Appearance="Appearance.Neutral">@LeanKernel.Gateway.Services.OnboardingService.UserGoalsPageKey</FluentBadge>
                                                    </FluentStack>
                                                </FluentStack>
                                            </FluentCard>
                                        </FluentStack>
                                    </FluentStack>
                                    break;
                                case 1:
                                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 1rem;">
                                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem;">
                                            <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">Identity</FluentLabel>
                                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Give LeanKernel the core profile details it should use across future conversations.</FluentLabel>
                                        </FluentStack>

                                        <EditForm EditContext="_editContext">
                                            <DataAnnotationsValidator />

                                            <FluentStack Orientation="Orientation.Vertical" Style="gap: 1rem;">
                                                <FluentStack Orientation="Orientation.Horizontal" Wrap="true" Style="gap: 1rem;">
                                                    <FluentTextField Id="onboarding-display-name"
                                                                     Name="display-name"
                                                                     Label="Display name"
                                                                     Required="true"
                                                                     @bind-Value="_draft.DisplayName"
                                                                     Immediate="true"
                                                                     @onblur="RefreshInsightsAsync"
                                                                     Maxlength="120"
                                                                     AutoComplete="name"
                                                                     Style="flex: 1 1 260px; min-width: 260px;" />

                                                    <FluentTextField Id="onboarding-role"
                                                                     Name="role"
                                                                     Label="Role or title"
                                                                     @bind-Value="_draft.RoleTitle"
                                                                     Immediate="true"
                                                                     @onblur="RefreshInsightsAsync"
                                                                     Maxlength="120"
                                                                     AutoComplete="organization-title"
                                                                     Style="flex: 1 1 260px; min-width: 260px;" />

                                                    <FluentTextField Id="onboarding-timezone"
                                                                     Name="timezone"
                                                                     Label="Timezone"
                                                                     @bind-Value="_draft.Timezone"
                                                                     Immediate="true"
                                                                     @onblur="RefreshInsightsAsync"
                                                                     Maxlength="120"
                                                                     Placeholder="UTC, America/New_York, GMT+1…"
                                                                     AutoComplete="off"
                                                                     Style="flex: 1 1 260px; min-width: 260px;" />

                                                    <FluentTextField Id="onboarding-language"
                                                                     Name="preferred-language"
                                                                     Label="Preferred language"
                                                                     @bind-Value="_draft.PreferredLanguage"
                                                                     Immediate="true"
                                                                     @onblur="RefreshInsightsAsync"
                                                                     Maxlength="120"
                                                                     AutoComplete="language"
                                                                     Placeholder="English, French, Swahili…"
                                                                     Style="flex: 1 1 260px; min-width: 260px;" />
                                                </FluentStack>

                                                <ValidationMessage For="@(() => _draft.DisplayName)" />

                                                <FluentCard Style="padding: 1rem;">
                                                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.5rem;">
                                                        <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">Communication style</FluentLabel>
                                                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Choose the tone LeanKernel should default to when responding.</FluentLabel>
                                                        <FluentSelect Id="onboarding-communication-style"
                                                                      Name="communication-style"
                                                                      Label="Communication style"
                                                                      TOption="string"
                                                                      Value="@_draft.CommunicationStyle"
                                                                      ValueChanged='@(value => SetCommunicationStyleAsync(value ?? "balanced"))'
                                                                      Style="width: 100%;">
                                                            @foreach (var option in CommunicationStyles)
                                                            {
                                                                <FluentOption Value="@option.Value">@option.Label — @option.Hint</FluentOption>
                                                            }
                                                        </FluentSelect>
                                                    </FluentStack>
                                                </FluentCard>
                                            </FluentStack>
                                        </EditForm>
                                    </FluentStack>
                                    break;
                                case 2:
                                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 1rem;">
                                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem;">
                                            <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">Knowledge domains</FluentLabel>
                                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Add the areas LeanKernel should treat as important context for retrieval and memory.</FluentLabel>
                                        </FluentStack>

                                        <FluentCard Style="padding: 1rem;">
                                            <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.75rem;">
                                                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Bottom" Wrap="true" Style="gap: 0.75rem;">
                                                    <FluentTextField Id="onboarding-domain-input"
                                                                     Name="domain-input"
                                                                     Label="Add a domain"
                                                                     @bind-Value="_domainInput"
                                                                     Immediate="true"
                                                                     @onkeydown="HandleDomainKeyDown"
                                                                     Maxlength="120"
                                                                     Placeholder="Type a domain and press Enter"
                                                                     AutoComplete="off"
                                                                     Style="flex: 1 1 280px; min-width: 280px;" />
                                                    <FluentButton Appearance="Appearance.Outline"
                                                                  OnClick="AddDomainAsync"
                                                                  Disabled="@string.IsNullOrWhiteSpace(_domainInput)">
                                                        Add
                                                    </FluentButton>
                                                </FluentStack>
                                                <FluentLabel Typo="Typography.Body" Color="Color.Neutral">At least one domain is recommended to improve retrieval quality.</FluentLabel>
                                            </FluentStack>
                                        </FluentCard>

                                        @if (_draft.Domains.Count > 0)
                                        {
                                            <FluentStack Orientation="Orientation.Horizontal" Wrap="true" Style="gap: 0.75rem;">
                                                @foreach (var domain in _draft.Domains)
                                                {
                                                    <FluentCard Style="padding: 0.5rem 0.75rem;">
                                                        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 0.5rem;">
                                                            <FluentBadge Appearance="Appearance.Accent">@domain</FluentBadge>
                                                            <FluentButton Appearance="Appearance.Outline"
                                                                          OnClick="@(() => RemoveDomainAsync(domain))"
                                                                          Title="@($"Remove {domain} domain")">
                                                                Remove
                                                            </FluentButton>
                                                        </FluentStack>
                                                    </FluentCard>
                                                }
                                            </FluentStack>
                                        }

                                        <FluentCard Style="padding: 1rem;">
                                            <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.75rem;">
                                                <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Suggested domains</FluentLabel>
                                                <FluentStack Orientation="Orientation.Horizontal" Wrap="true" Style="gap: 0.5rem;">
                                                    @foreach (var suggestion in DomainSuggestions)
                                                    {
                                                        <FluentButton Appearance="Appearance.Outline"
                                                                      OnClick="@(() => AddDomainAsync(suggestion))"
                                                                      Title="@($"Add suggested domain {suggestion}")">
                                                            @suggestion
                                                        </FluentButton>
                                                    }
                                                </FluentStack>
                                            </FluentStack>
                                        </FluentCard>
                                    </FluentStack>
                                    break;
                                case 3:
                                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 1rem;">
                                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem;">
                                            <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">Goals</FluentLabel>
                                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Choose the outcomes LeanKernel should optimize for when supporting you.</FluentLabel>
                                        </FluentStack>

                                        <FluentCard Style="padding: 1rem;">
                                            <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.75rem;">
                                                <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">Common goals</FluentLabel>
                                                <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.5rem;">
                                                    @foreach (var goal in GoalOptions)
                                                    {
                                                        <FluentCheckbox Value="@IsGoalSelected(goal)"
                                                                        ValueChanged="@(value => ToggleGoalAsync(goal, new ChangeEventArgs { Value = value }))"
                                                                        Label="@goal" />
                                                    }
                                                </FluentStack>
                                            </FluentStack>
                                        </FluentCard>

                                        @if (_draft.Goals.Count > 0)
                                        {
                                            <FluentStack Orientation="Orientation.Horizontal" Wrap="true" Style="gap: 0.75rem;">
                                                @foreach (var goal in _draft.Goals)
                                                {
                                                    <FluentCard Style="padding: 0.5rem 0.75rem;">
                                                        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 0.5rem;">
                                                            <FluentBadge Appearance="Appearance.Accent">@goal</FluentBadge>
                                                            <FluentButton Appearance="Appearance.Outline"
                                                                          OnClick="@(() => RemoveGoalAsync(goal))"
                                                                          Title="@($"Remove {goal} goal")">
                                                                Remove
                                                            </FluentButton>
                                                        </FluentStack>
                                                    </FluentCard>
                                                }
                                            </FluentStack>
                                        }

                                        <FluentTextArea Id="onboarding-other-goals"
                                                        Name="other-goals"
                                                        Label="Other goals"
                                                        @bind-Value="_draft.OtherGoals"
                                                        Immediate="true"
                                                        @onblur="RefreshInsightsAsync"
                                                        Rows="4"
                                                        Maxlength="1200"
                                                        Placeholder="Anything else you want LeanKernel to help with?"
                                                        Style="width: 100%;" />
                                    </FluentStack>
                                    break;
                                case 4:
                                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 1rem;">
                                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem;">
                                            <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">Complete</FluentLabel>
                                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Review what LeanKernel will save, then confirm to write your profile pages.</FluentLabel>
                                        </FluentStack>

                                        <FluentStack Orientation="Orientation.Horizontal" Wrap="true" Style="gap: 1rem; align-items: stretch;">
                                            <FluentCard Style="flex: 1 1 260px; padding: 1rem;">
                                                <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.75rem;">
                                                    <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">Identity</FluentLabel>
                                                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.5rem;">
                                                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.1rem;">
                                                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Display name</FluentLabel>
                                                            <FluentLabel Typo="Typography.Body">@GetValueOrFallback(_draft.DisplayName, "Required")</FluentLabel>
                                                        </FluentStack>
                                                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.1rem;">
                                                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Role or title</FluentLabel>
                                                            <FluentLabel Typo="Typography.Body">@GetValueOrFallback(_draft.RoleTitle, "Skipped for now")</FluentLabel>
                                                        </FluentStack>
                                                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.1rem;">
                                                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Communication style</FluentLabel>
                                                            <FluentLabel Typo="Typography.Body">@GetValueOrFallback(_draft.CommunicationStyle, "Balanced")</FluentLabel>
                                                        </FluentStack>
                                                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.1rem;">
                                                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Timezone</FluentLabel>
                                                            <FluentLabel Typo="Typography.Body">@GetValueOrFallback(_draft.Timezone, "Skipped for now")</FluentLabel>
                                                        </FluentStack>
                                                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.1rem;">
                                                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Preferred language</FluentLabel>
                                                            <FluentLabel Typo="Typography.Body">@GetValueOrFallback(_draft.PreferredLanguage, "Skipped for now")</FluentLabel>
                                                        </FluentStack>
                                                    </FluentStack>
                                                </FluentStack>
                                            </FluentCard>

                                            <FluentCard Style="flex: 1 1 220px; padding: 1rem;">
                                                <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.75rem;">
                                                    <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">Domains</FluentLabel>
                                                    @if (_draft.Domains.Count == 0)
                                                    {
                                                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">No domains added yet.</FluentLabel>
                                                    }
                                                    else
                                                    {
                                                        <FluentStack Orientation="Orientation.Horizontal" Wrap="true" Style="gap: 0.5rem;">
                                                            @foreach (var domain in _draft.Domains)
                                                            {
                                                                <FluentBadge Appearance="Appearance.Neutral">@domain</FluentBadge>
                                                            }
                                                        </FluentStack>
                                                    }
                                                </FluentStack>
                                            </FluentCard>

                                            <FluentCard Style="flex: 1 1 260px; padding: 1rem;">
                                                <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.75rem;">
                                                    <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">Goals</FluentLabel>
                                                    @if (_draft.Goals.Count == 0 && string.IsNullOrWhiteSpace(_draft.OtherGoals))
                                                    {
                                                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">No goals selected yet.</FluentLabel>
                                                    }
                                                    else
                                                    {
                                                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.4rem;">
                                                            @foreach (var goal in _draft.Goals)
                                                            {
                                                                <FluentLabel Typo="Typography.Body">• @goal</FluentLabel>
                                                            }
                                                        </FluentStack>

                                                        @if (!string.IsNullOrWhiteSpace(_draft.OtherGoals))
                                                        {
                                                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Other goals: @_draft.OtherGoals</FluentLabel>
                                                        }
                                                    }
                                                </FluentStack>
                                            </FluentCard>
                                        </FluentStack>
                                    </FluentStack>
                                    break;
                            }
                        </FluentStack>

                        <FluentStack Orientation="Orientation.Horizontal"
                                     VerticalAlignment="VerticalAlignment.Center"
                                     Wrap="true"
                                     Style="justify-content: space-between; gap: 0.75rem;">
                            <FluentStack Orientation="Orientation.Horizontal" Wrap="true" Style="gap: 0.75rem;">
                                @if (CurrentStepIndex > 0)
                                {
                                    <FluentButton Appearance="Appearance.Outline"
                                                  OnClick="GoBackAsync"
                                                  Title="Go to the previous onboarding step">
                                        Back
                                    </FluentButton>
                                }

                                @if (IsOptionalStep)
                                {
                                    <FluentButton Appearance="Appearance.Outline"
                                                  OnClick="SkipOptionalStepAsync"
                                                  Title="@($"Skip the {CurrentStep.Label} step for now")">
                                        Skip for now
                                    </FluentButton>
                                }
                            </FluentStack>

                            <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Wrap="true" Style="gap: 0.75rem;">
                                @if (_isSaving)
                                {
                                    <FluentProgressRing Style="width: 20px; height: 20px;" />
                                }

                                @if (CurrentStepIndex < Steps.Count - 1)
                                {
                                    <FluentButton Appearance="Appearance.Accent"
                                                  OnClick="GoNextAsync"
                                                  Title="Continue to the next onboarding step">
                                        Next
                                    </FluentButton>
                                }
                                else
                                {
                                    <FluentButton Appearance="Appearance.Accent"
                                                  OnClick="SaveAsync"
                                                  Disabled="@_isSaving"
                                                  Title="Save onboarding profile">
                                        @(_isSaving ? "Saving…" : "Save Profile")
                                    </FluentButton>
                                }
                            </FluentStack>
                        </FluentStack>
                    }
                </FluentStack>
            </FluentCard>

            <FluentStack Orientation="Orientation.Vertical" Style="flex: 0 1 320px; gap: 1rem;">
                <FluentCard Style="padding: 1rem;" aria-label="Profile guidance">
                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.75rem;">
                        <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">Identity gaps</FluentLabel>
                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">These suggestions reflect the profile fields this wizard uses to improve personalization quality.</FluentLabel>

                        @if (_gaps.Count == 0)
                        {
                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">No priority gaps detected for the current profile draft.</FluentLabel>
                        }
                        else
                        {
                            <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.75rem;">
                                @foreach (var gap in _gaps)
                                {
                                    <FluentCard Style="padding: 0.75rem;">
                                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem;">
                                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">@gap.Title</FluentLabel>
                                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@gap.Detail</FluentLabel>
                                        </FluentStack>
                                    </FluentCard>
                                }
                            </FluentStack>
                        }
                    </FluentStack>
                </FluentCard>

                <FluentCard Style="padding: 1rem;">
                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.75rem;">
                        <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">Recommended next context</FluentLabel>
                        <FluentLabel Typo="Typography.Body">• @GetDomainRecommendation()</FluentLabel>
                        <FluentLabel Typo="Typography.Body">• @GetGoalRecommendation()</FluentLabel>
                        <FluentLabel Typo="Typography.Body">• Re-open setup any time to keep your profile current as your work evolves.</FluentLabel>
                    </FluentStack>
                </FluentCard>
            </FluentStack>
        </FluentStack>
    </FluentStack>
}

@code {
    private const string OwnerStorageKey = "leankernel.chat.owner-id";

    private static readonly IReadOnlyList<WizardStep> Steps =
    [
        new("Welcome", "What setup saves"),
        new("Identity", "Name, tone, locale"),
        new("Knowledge Domains", "Optional retrieval tags"),
        new("Goals", "Optional priorities"),
        new("Complete", "Review and save")
    ];

    private static readonly IReadOnlyList<ChoiceOption> CommunicationStyles =
    [
        new("formal", "Formal", "Structured, direct, and polished."),
        new("balanced", "Balanced", "Clear, friendly, and practical."),
        new("casual", "Casual", "Relaxed, conversational, and quick.")
    ];

    private static readonly IReadOnlyList<string> DomainSuggestions =
    [
        "Technology",
        "Business",
        "Science",
        "Health",
        "Finance",
        "Creative",
        "Education",
        "Operations"
    ];

    private static readonly IReadOnlyList<string> GoalOptions =
    [
        "Research & learning",
        "Writing assistance",
        "Code review & development",
        "Decision support",
        "Knowledge management",
        "Scheduling & planning"
    ];

    private readonly CancellationTokenSource _disposeCts = new();
    private EditContext _editContext = new(new OnboardingDraft());
    private OnboardingDraft _draft = new();
    private List<OnboardingGapInsight> _gaps = [];
    private bool _initialized;
    private bool _isSaving;
    private bool _saveCompleted;
    private int CurrentStepIndex;
    private string? _ownerId;
    private string _domainInput = string.Empty;
    private string? _errorMessage;
    private string? _successMessage;

    private WizardStep CurrentStep => Steps[CurrentStepIndex];

    private bool IsOptionalStep => CurrentStepIndex is 2 or 3;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await InitializeAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task InitializeAsync()
    {
        _errorMessage = null;
        _successMessage = null;

        try
        {
            _ownerId = await GetOrCreateOwnerIdAsync();
            var state = await OnboardingService.LoadAsync(_ownerId, _disposeCts.Token);
            _draft = state.Draft;
            _editContext = new EditContext(_draft);
            _gaps = state.Gaps.ToList();
            _successMessage = state.HasExistingProfile
                ? "Existing onboarding pages were loaded from GBrain."
                : null;
        }
        catch (OperationCanceledException) when (_disposeCts.IsCancellationRequested)
        {
            return;
        }
        catch (Exception)
        {
            _errorMessage = "The onboarding profile could not be loaded. You can still continue and save a new profile.";
            _draft = new OnboardingDraft();
            _editContext = new EditContext(_draft);
            _gaps = [];
        }
        finally
        {
            _initialized = true;
        }
    }

    private async Task GoNextAsync()
    {
        _errorMessage = null;
        _successMessage = null;

        if (CurrentStepIndex == 1 && !(_editContext.Validate()))
        {
            _errorMessage = "Display name is required before you continue.";
            return;
        }

        if (CurrentStepIndex >= Steps.Count - 1)
        {
            return;
        }

        CurrentStepIndex++;
        await RefreshInsightsAsync();
    }

    private async Task GoBackAsync()
    {
        _errorMessage = null;
        _successMessage = null;

        if (CurrentStepIndex == 0)
        {
            return;
        }

        CurrentStepIndex--;
        await RefreshInsightsAsync();
    }

    private async Task SkipOptionalStepAsync()
    {
        _errorMessage = null;
        _successMessage = null;

        if (!IsOptionalStep)
        {
            return;
        }

        if (CurrentStepIndex < Steps.Count - 1)
        {
            CurrentStepIndex++;
        }

        await RefreshInsightsAsync();
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_ownerId) || _isSaving)
        {
            return;
        }

        _errorMessage = null;
        _successMessage = null;

        if (string.IsNullOrWhiteSpace(_draft.DisplayName))
        {
            CurrentStepIndex = 1;
            _editContext.Validate();
            _errorMessage = "Display name is required before saving your profile.";
            return;
        }

        _isSaving = true;

        try
        {
            var result = await OnboardingService.SaveAsync(_ownerId, _draft, _disposeCts.Token);
            _gaps = result.Gaps.ToList();

            if (result.IsSuccess)
            {
                _saveCompleted = true;
                _successMessage = result.Message;
                return;
            }

            _errorMessage = result.Message;
        }
        catch (OperationCanceledException) when (_disposeCts.IsCancellationRequested)
        {
        }
        catch (Exception)
        {
            _errorMessage = "Saving the onboarding profile failed. Please try again.";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private Task ReviewSummaryAsync()
    {
        _saveCompleted = false;
        CurrentStepIndex = Steps.Count - 1;
        return RefreshInsightsAsync();
    }

    private async Task SetCommunicationStyleAsync(string value)
    {
        _draft.CommunicationStyle = value;
        await RefreshInsightsAsync();
    }

    private async Task HandleDomainKeyDown(KeyboardEventArgs args)
    {
        if (string.Equals(args.Key, "Enter", StringComparison.Ordinal))
        {
            await AddDomainAsync();
        }
    }

    private Task AddDomainAsync()
        => AddDomainAsync(_domainInput);

    private async Task AddDomainAsync(string? value)
    {
        var normalized = NormalizeEntry(value);
        if (string.IsNullOrWhiteSpace(normalized))
        {
            return;
        }

        if (!_draft.Domains.Any(domain => string.Equals(domain, normalized, StringComparison.OrdinalIgnoreCase)))
        {
            _draft.Domains.Add(normalized);
        }

        _domainInput = string.Empty;
        await RefreshInsightsAsync();
    }

    private async Task RemoveDomainAsync(string domain)
    {
        _draft.Domains.RemoveAll(existing => string.Equals(existing, domain, StringComparison.OrdinalIgnoreCase));
        await RefreshInsightsAsync();
    }

    private bool IsGoalSelected(string goal)
        => _draft.Goals.Any(existing => string.Equals(existing, goal, StringComparison.OrdinalIgnoreCase));

    private async Task ToggleGoalAsync(string goal, ChangeEventArgs args)
    {
        var isChecked = args.Value is bool selected && selected;
        if (isChecked)
        {
            if (!IsGoalSelected(goal))
            {
                _draft.Goals.Add(goal);
            }
        }
        else
        {
            _draft.Goals.RemoveAll(existing => string.Equals(existing, goal, StringComparison.OrdinalIgnoreCase));
        }

        await RefreshInsightsAsync();
    }

    private async Task RemoveGoalAsync(string goal)
    {
        _draft.Goals.RemoveAll(existing => string.Equals(existing, goal, StringComparison.OrdinalIgnoreCase));
        await RefreshInsightsAsync();
    }

    private async Task RefreshInsightsAsync()
    {
        if (string.IsNullOrWhiteSpace(_ownerId))
        {
            return;
        }

        try
        {
            _gaps = (await OnboardingService.DetectGapsAsync(_ownerId, _draft, _disposeCts.Token)).ToList();
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) when (_disposeCts.IsCancellationRequested)
        {
        }
        catch (Exception)
        {
            // Gap guidance is advisory; keep the wizard usable if detection is temporarily unavailable.
        }
    }

    private async Task<string> GetOrCreateOwnerIdAsync()
    {
        var existingOwnerId = await JS.InvokeAsync<string?>("leanKernelChat.storage.get", OwnerStorageKey);
        if (!string.IsNullOrWhiteSpace(existingOwnerId))
        {
            return existingOwnerId;
        }

        var ownerId = Guid.NewGuid().ToString("N");
        await JS.InvokeVoidAsync("leanKernelChat.storage.set", OwnerStorageKey, ownerId);
        return ownerId;
    }

    private string GetDomainRecommendation()
        => _draft.Domains.Count > 0
            ? "Your selected domains will help LeanKernel bias retrieval toward your core areas of interest."
            : "Add at least one domain later so retrieval can favor the topics you care about most.";

    private string GetGoalRecommendation()
        => _draft.Goals.Count > 0 || !string.IsNullOrWhiteSpace(_draft.OtherGoals)
            ? "Your goals give LeanKernel clearer signals about the work you want help with most often."
            : "Choose one or more goals to help LeanKernel prioritize research, writing, coding, or planning support.";

    private static string NormalizeEntry(string? value)
        => string.Join(' ', (value ?? string.Empty)
            .Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries));

    private static string GetValueOrFallback(string? value, string fallback)
        => string.IsNullOrWhiteSpace(value) ? fallback : value;

    public async ValueTask DisposeAsync()
    {
        if (!_disposeCts.IsCancellationRequested)
        {
            await _disposeCts.CancelAsync();
        }

        _disposeCts.Dispose();
    }

    private sealed record WizardStep(string Label, string Hint);

    private sealed record ChoiceOption(string Value, string Label, string Hint);
}
