@page "/onboarding"
@inject OnboardingService OnboardingService
@inject IJSRuntime JS
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>LeanKernel Setup</PageTitle>

@if (!_initialized)
{
    <section class="placeholder-page">
        <header class="page-header">
            <h1>Setup</h1>
            <p>Loading your onboarding profile…</p>
        </header>
    </section>
}
else
{
    <section class="onboarding-wizard">
        <header class="page-header onboarding-wizard__hero">
            <div>
                <h1>Guided setup</h1>
                <p>Tell LeanKernel how to address you, what domains matter most, and what outcomes you want help with.</p>
            </div>
            <span class="badge">Step @(CurrentStepIndex + 1) of @Steps.Count</span>
        </header>

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <div class="status-banner status-banner--error" role="alert">
                @_errorMessage
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_successMessage))
        {
            <div class="status-banner status-banner--success" role="status" aria-live="polite">
                @_successMessage
            </div>
        }

        <div class="onboarding-wizard__layout">
            <section class="onboarding-wizard__panel" aria-busy="@_isSaving">
                <ol class="onboarding-wizard__steps" aria-label="Onboarding progress">
                    @for (var index = 0; index < Steps.Count; index++)
                    {
                        var step = Steps[index];
                        var isActive = index == CurrentStepIndex;
                        var isComplete = index < CurrentStepIndex || (_saveCompleted && index == Steps.Count - 1);
                        var stepClass = $"onboarding-wizard__step{(isActive ? " onboarding-wizard__step--active" : string.Empty)}{(isComplete ? " onboarding-wizard__step--complete" : string.Empty)}";

                        <li class="@stepClass" aria-current="@(isActive ? "step" : null)">
                            <span class="onboarding-wizard__step-index">@(index + 1)</span>
                            <span class="onboarding-wizard__step-text">
                                <span class="onboarding-wizard__step-label">@step.Label</span>
                                <span class="onboarding-wizard__step-hint">@step.Hint</span>
                            </span>
                        </li>
                    }
                </ol>

                @if (_saveCompleted)
                {
                    <section class="onboarding-wizard__success">
                        <h2>Profile saved</h2>
                        <p>Your onboarding profile is now written to the GBrain wiki pages for identity and goals.</p>
                        <div class="onboarding-wizard__actions onboarding-wizard__actions--stacked">
                            <a href="/chat" class="button button-primary" aria-label="Go to chat after completing onboarding">Go to Chat</a>
                            <button type="button"
                                    class="button button-secondary"
                                    aria-label="Review your saved onboarding summary"
                                    @onclick="ReviewSummaryAsync">
                                Review summary
                            </button>
                        </div>
                    </section>
                }
                else
                {
                    <div class="onboarding-wizard__content">
                        @switch (CurrentStepIndex)
                        {
                            case 0:
                                <section class="onboarding-wizard__section">
                                    <h2>Welcome to LeanKernel</h2>
                                    <p>This guided setup creates durable identity pages so LeanKernel can personalize retrieval, tone, and follow-up support without asking you to repeat yourself every session.</p>

                                    <div class="onboarding-wizard__intro-grid">
                                        <article class="onboarding-wizard__card onboarding-wizard__card--inline">
                                            <h3>What we capture</h3>
                                            <ul class="onboarding-wizard__list">
                                                <li>How you want LeanKernel to address and respond to you</li>
                                                <li>Knowledge domains that should shape retrieval and memory</li>
                                                <li>Goals that help prioritize future support</li>
                                            </ul>
                                        </article>

                                        <article class="onboarding-wizard__card onboarding-wizard__card--inline">
                                            <h3>What gets written</h3>
                                            <ul class="onboarding-wizard__list">
                                                <li><code>@LeanKernel.Gateway.Services.OnboardingService.UserProfilePageKey</code></li>
                                                <li><code>@LeanKernel.Gateway.Services.OnboardingService.UserGoalsPageKey</code></li>
                                            </ul>
                                        </article>
                                    </div>
                                </section>
                                break;
                            case 1:
                                <section class="onboarding-wizard__section">
                                    <h2>Identity</h2>
                                    <p>Give LeanKernel the core profile details it should use across future conversations.</p>

                                    <EditForm EditContext="_editContext" class="onboarding-wizard__form">
                                        <DataAnnotationsValidator />

                                        <div class="onboarding-wizard__field-grid">
                                            <div class="onboarding-wizard__field-group">
                                                <label class="onboarding-wizard__label" for="onboarding-display-name">
                                                    Display name <span class="onboarding-wizard__required">*</span>
                                                </label>
                                                <InputText id="onboarding-display-name"
                                                           class="onboarding-wizard__input"
                                                           @bind-Value="_draft.DisplayName"
                                                           @bind-Value:event="oninput"
                                                           @onblur="RefreshInsightsAsync"
                                                           maxlength="120"
                                                           autocomplete="name" />
                                                <ValidationMessage class="onboarding-wizard__validation" For="@(() => _draft.DisplayName)" />
                                            </div>

                                            <div class="onboarding-wizard__field-group">
                                                <label class="onboarding-wizard__label" for="onboarding-role">Role or title</label>
                                                <InputText id="onboarding-role"
                                                           class="onboarding-wizard__input"
                                                           @bind-Value="_draft.RoleTitle"
                                                           @bind-Value:event="oninput"
                                                           @onblur="RefreshInsightsAsync"
                                                           maxlength="120"
                                                           autocomplete="organization-title" />
                                            </div>

                                            <div class="onboarding-wizard__field-group">
                                                <label class="onboarding-wizard__label" for="onboarding-timezone">Timezone</label>
                                                <InputText id="onboarding-timezone"
                                                           class="onboarding-wizard__input"
                                                           @bind-Value="_draft.Timezone"
                                                           @bind-Value:event="oninput"
                                                           @onblur="RefreshInsightsAsync"
                                                           maxlength="120"
                                                           placeholder="UTC, America/New_York, GMT+1…"
                                                           autocomplete="off" />
                                            </div>

                                            <div class="onboarding-wizard__field-group">
                                                <label class="onboarding-wizard__label" for="onboarding-language">Preferred language</label>
                                                <InputText id="onboarding-language"
                                                           class="onboarding-wizard__input"
                                                           @bind-Value="_draft.PreferredLanguage"
                                                           @bind-Value:event="oninput"
                                                           @onblur="RefreshInsightsAsync"
                                                           maxlength="120"
                                                           autocomplete="language"
                                                           placeholder="English, French, Swahili…" />
                                            </div>
                                        </div>

                                        <fieldset class="onboarding-wizard__fieldset">
                                            <legend class="onboarding-wizard__legend">Communication style</legend>
                                            <div class="onboarding-wizard__choices" role="radiogroup" aria-label="Communication style">
                                                @foreach (var option in CommunicationStyles)
                                                {
                                                    <label class="onboarding-wizard__choice">
                                                        <input type="radio"
                                                               name="communication-style"
                                                               value="@option.Value"
                                                               checked="@string.Equals(_draft.CommunicationStyle, option.Value, StringComparison.OrdinalIgnoreCase)"
                                                               @onchange="() => SetCommunicationStyleAsync(option.Value)" />
                                                        <span>
                                                            <strong>@option.Label</strong>
                                                            <span class="onboarding-wizard__choice-hint">@option.Hint</span>
                                                        </span>
                                                    </label>
                                                }
                                            </div>
                                        </fieldset>
                                    </EditForm>
                                </section>
                                break;
                            case 2:
                                <section class="onboarding-wizard__section">
                                    <h2>Knowledge domains</h2>
                                    <p>Add the areas LeanKernel should treat as important context for retrieval and memory.</p>

                                    <div class="onboarding-wizard__field-group">
                                        <label class="onboarding-wizard__label" for="onboarding-domain-input">Add a domain</label>
                                        <div class="onboarding-wizard__tag-editor">
                                            <input id="onboarding-domain-input"
                                                   class="onboarding-wizard__input"
                                                   @bind="_domainInput"
                                                   @bind:event="oninput"
                                                   @onkeydown="HandleDomainKeyDown"
                                                   maxlength="120"
                                                   placeholder="Type a domain and press Enter"
                                                   autocomplete="off" />
                                            <button type="button"
                                                    class="button button-secondary"
                                                    aria-label="Add knowledge domain"
                                                    @onclick="AddDomainAsync"
                                                    disabled="@string.IsNullOrWhiteSpace(_domainInput)">
                                                Add
                                            </button>
                                        </div>
                                        <p class="onboarding-wizard__helper">At least one domain is recommended to improve retrieval quality.</p>
                                    </div>

                                    @if (_draft.Domains.Count > 0)
                                    {
                                        <ul class="onboarding-wizard__tags" aria-label="Selected knowledge domains">
                                            @foreach (var domain in _draft.Domains)
                                            {
                                                <li class="onboarding-wizard__tag">
                                                    <span>@domain</span>
                                                    <button type="button"
                                                            class="onboarding-wizard__tag-remove"
                                                            aria-label="Remove @domain domain"
                                                            @onclick="() => RemoveDomainAsync(domain)">
                                                        Remove
                                                    </button>
                                                </li>
                                            }
                                        </ul>
                                    }

                                    <div class="onboarding-wizard__suggestions">
                                        <span class="onboarding-wizard__suggestions-label">Suggested domains</span>
                                        <div class="onboarding-wizard__chip-list">
                                            @foreach (var suggestion in DomainSuggestions)
                                            {
                                                <button type="button"
                                                        class="onboarding-wizard__chip"
                                                        aria-label="Add suggested domain @suggestion"
                                                        @onclick="() => AddDomainAsync(suggestion)">
                                                    @suggestion
                                                </button>
                                            }
                                        </div>
                                    </div>
                                </section>
                                break;
                            case 3:
                                <section class="onboarding-wizard__section">
                                    <h2>Goals</h2>
                                    <p>Choose the outcomes LeanKernel should optimize for when supporting you.</p>

                                    <fieldset class="onboarding-wizard__fieldset">
                                        <legend class="onboarding-wizard__legend">Common goals</legend>
                                        <div class="onboarding-wizard__checks">
                                            @foreach (var goal in GoalOptions)
                                            {
                                                <label class="onboarding-wizard__check">
                                                    <input type="checkbox"
                                                           checked="@IsGoalSelected(goal)"
                                                           @onchange="args => ToggleGoalAsync(goal, args)" />
                                                    <span>@goal</span>
                                                </label>
                                            }
                                        </div>
                                    </fieldset>

                                    @if (_draft.Goals.Count > 0)
                                    {
                                        <ul class="onboarding-wizard__tags" aria-label="Selected goals">
                                            @foreach (var goal in _draft.Goals)
                                            {
                                                <li class="onboarding-wizard__tag onboarding-wizard__tag--goal">
                                                    <span>@goal</span>
                                                    <button type="button"
                                                            class="onboarding-wizard__tag-remove"
                                                            aria-label="Remove @goal goal"
                                                            @onclick="() => RemoveGoalAsync(goal)">
                                                        Remove
                                                    </button>
                                                </li>
                                            }
                                        </ul>
                                    }

                                    <div class="onboarding-wizard__field-group">
                                        <label class="onboarding-wizard__label" for="onboarding-other-goals">Other goals</label>
                                        <textarea id="onboarding-other-goals"
                                                  class="onboarding-wizard__textarea"
                                                  @bind="_draft.OtherGoals"
                                                  @bind:event="oninput"
                                                  @onblur="RefreshInsightsAsync"
                                                  rows="4"
                                                  maxlength="1200"
                                                  placeholder="Anything else you want LeanKernel to help with?"></textarea>
                                    </div>
                                </section>
                                break;
                            case 4:
                                <section class="onboarding-wizard__section">
                                    <h2>Complete</h2>
                                    <p>Review what LeanKernel will save, then confirm to write your profile pages.</p>

                                    <div class="onboarding-wizard__summary-grid">
                                        <article class="onboarding-wizard__summary-card">
                                            <h3>Identity</h3>
                                            <dl class="onboarding-wizard__summary-list">
                                                <div>
                                                    <dt>Display name</dt>
                                                    <dd>@GetValueOrFallback(_draft.DisplayName, "Required")</dd>
                                                </div>
                                                <div>
                                                    <dt>Role or title</dt>
                                                    <dd>@GetValueOrFallback(_draft.RoleTitle, "Skipped for now")</dd>
                                                </div>
                                                <div>
                                                    <dt>Communication style</dt>
                                                    <dd>@GetValueOrFallback(_draft.CommunicationStyle, "Balanced")</dd>
                                                </div>
                                                <div>
                                                    <dt>Timezone</dt>
                                                    <dd>@GetValueOrFallback(_draft.Timezone, "Skipped for now")</dd>
                                                </div>
                                                <div>
                                                    <dt>Preferred language</dt>
                                                    <dd>@GetValueOrFallback(_draft.PreferredLanguage, "Skipped for now")</dd>
                                                </div>
                                            </dl>
                                        </article>

                                        <article class="onboarding-wizard__summary-card">
                                            <h3>Domains</h3>
                                            @if (_draft.Domains.Count == 0)
                                            {
                                                <p class="onboarding-wizard__empty">No domains added yet.</p>
                                            }
                                            else
                                            {
                                                <ul class="onboarding-wizard__tags onboarding-wizard__tags--summary">
                                                    @foreach (var domain in _draft.Domains)
                                                    {
                                                        <li class="onboarding-wizard__tag">@domain</li>
                                                    }
                                                </ul>
                                            }
                                        </article>

                                        <article class="onboarding-wizard__summary-card">
                                            <h3>Goals</h3>
                                            @if (_draft.Goals.Count == 0 && string.IsNullOrWhiteSpace(_draft.OtherGoals))
                                            {
                                                <p class="onboarding-wizard__empty">No goals selected yet.</p>
                                            }
                                            else
                                            {
                                                <ul class="onboarding-wizard__summary-points">
                                                    @foreach (var goal in _draft.Goals)
                                                    {
                                                        <li>@goal</li>
                                                    }
                                                </ul>

                                                @if (!string.IsNullOrWhiteSpace(_draft.OtherGoals))
                                                {
                                                    <p class="onboarding-wizard__summary-note">Other goals: @_draft.OtherGoals</p>
                                                }
                                            }
                                        </article>
                                    </div>
                                </section>
                                break;
                        }
                    </div>

                    <div class="onboarding-wizard__actions">
                        @if (CurrentStepIndex > 0)
                        {
                            <button type="button"
                                    class="button button-secondary"
                                    aria-label="Go to the previous onboarding step"
                                    @onclick="GoBackAsync">
                                Back
                            </button>
                        }

                        @if (IsOptionalStep)
                        {
                            <button type="button"
                                    class="button button-secondary"
                                    aria-label="Skip the @CurrentStep.Label step for now"
                                    @onclick="SkipOptionalStepAsync">
                                Skip for now
                            </button>
                        }

                        @if (CurrentStepIndex < Steps.Count - 1)
                        {
                            <button type="button"
                                    class="button button-primary"
                                    aria-label="Continue to the next onboarding step"
                                    @onclick="GoNextAsync">
                                Next
                            </button>
                        }
                        else
                        {
                            <button type="button"
                                    class="button button-primary"
                                    aria-label="Save onboarding profile"
                                    @onclick="SaveAsync"
                                    disabled="@_isSaving">
                                @(_isSaving ? "Saving…" : "Save Profile")
                            </button>
                        }
                    </div>
                }
            </section>

            <aside class="onboarding-wizard__aside" aria-label="Profile guidance">
                <section class="onboarding-wizard__card">
                    <h2>Identity gaps</h2>
                    <p>These suggestions reflect the profile fields this wizard uses to improve personalization quality.</p>

                    @if (_gaps.Count == 0)
                    {
                        <p class="onboarding-wizard__empty">No priority gaps detected for the current profile draft.</p>
                    }
                    else
                    {
                        <ul class="onboarding-wizard__gap-list">
                            @foreach (var gap in _gaps)
                            {
                                <li>
                                    <strong>@gap.Title</strong>
                                    <span>@gap.Detail</span>
                                </li>
                            }
                        </ul>
                    }
                </section>

                <section class="onboarding-wizard__card">
                    <h2>Recommended next context</h2>
                    <ul class="onboarding-wizard__recommendation-list">
                        <li>@GetDomainRecommendation()</li>
                        <li>@GetGoalRecommendation()</li>
                        <li>Re-open setup any time to keep your profile current as your work evolves.</li>
                    </ul>
                </section>
            </aside>
        </div>
    </section>
}

@code {
    private const string OwnerStorageKey = "leankernel.chat.owner-id";

    private static readonly IReadOnlyList<WizardStep> Steps =
    [
        new("Welcome", "What setup saves"),
        new("Identity", "Name, tone, locale"),
        new("Knowledge Domains", "Optional retrieval tags"),
        new("Goals", "Optional priorities"),
        new("Complete", "Review and save")
    ];

    private static readonly IReadOnlyList<ChoiceOption> CommunicationStyles =
    [
        new("formal", "Formal", "Structured, direct, and polished."),
        new("balanced", "Balanced", "Clear, friendly, and practical."),
        new("casual", "Casual", "Relaxed, conversational, and quick.")
    ];

    private static readonly IReadOnlyList<string> DomainSuggestions =
    [
        "Technology",
        "Business",
        "Science",
        "Health",
        "Finance",
        "Creative",
        "Education",
        "Operations"
    ];

    private static readonly IReadOnlyList<string> GoalOptions =
    [
        "Research & learning",
        "Writing assistance",
        "Code review & development",
        "Decision support",
        "Knowledge management",
        "Scheduling & planning"
    ];

    private readonly CancellationTokenSource _disposeCts = new();
    private EditContext _editContext = new(new OnboardingDraft());
    private OnboardingDraft _draft = new();
    private List<OnboardingGapInsight> _gaps = [];
    private bool _initialized;
    private bool _isSaving;
    private bool _saveCompleted;
    private int CurrentStepIndex;
    private string? _ownerId;
    private string _domainInput = string.Empty;
    private string? _errorMessage;
    private string? _successMessage;

    private WizardStep CurrentStep => Steps[CurrentStepIndex];

    private bool IsOptionalStep => CurrentStepIndex is 2 or 3;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await InitializeAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task InitializeAsync()
    {
        _errorMessage = null;
        _successMessage = null;

        try
        {
            _ownerId = await GetOrCreateOwnerIdAsync();
            var state = await OnboardingService.LoadAsync(_ownerId, _disposeCts.Token);
            _draft = state.Draft;
            _editContext = new EditContext(_draft);
            _gaps = state.Gaps.ToList();
            _successMessage = state.HasExistingProfile
                ? "Existing onboarding pages were loaded from GBrain."
                : null;
        }
        catch (OperationCanceledException) when (_disposeCts.IsCancellationRequested)
        {
            return;
        }
        catch (Exception)
        {
            _errorMessage = "The onboarding profile could not be loaded. You can still continue and save a new profile.";
            _draft = new OnboardingDraft();
            _editContext = new EditContext(_draft);
            _gaps = [];
        }
        finally
        {
            _initialized = true;
        }
    }

    private async Task GoNextAsync()
    {
        _errorMessage = null;
        _successMessage = null;

        if (CurrentStepIndex == 1 && !(_editContext.Validate()))
        {
            _errorMessage = "Display name is required before you continue.";
            return;
        }

        if (CurrentStepIndex >= Steps.Count - 1)
        {
            return;
        }

        CurrentStepIndex++;
        await RefreshInsightsAsync();
    }

    private async Task GoBackAsync()
    {
        _errorMessage = null;
        _successMessage = null;

        if (CurrentStepIndex == 0)
        {
            return;
        }

        CurrentStepIndex--;
        await RefreshInsightsAsync();
    }

    private async Task SkipOptionalStepAsync()
    {
        _errorMessage = null;
        _successMessage = null;

        if (!IsOptionalStep)
        {
            return;
        }

        if (CurrentStepIndex < Steps.Count - 1)
        {
            CurrentStepIndex++;
        }

        await RefreshInsightsAsync();
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_ownerId) || _isSaving)
        {
            return;
        }

        _errorMessage = null;
        _successMessage = null;

        if (string.IsNullOrWhiteSpace(_draft.DisplayName))
        {
            CurrentStepIndex = 1;
            _editContext.Validate();
            _errorMessage = "Display name is required before saving your profile.";
            return;
        }

        _isSaving = true;

        try
        {
            var result = await OnboardingService.SaveAsync(_ownerId, _draft, _disposeCts.Token);
            _gaps = result.Gaps.ToList();

            if (result.IsSuccess)
            {
                _saveCompleted = true;
                _successMessage = result.Message;
                return;
            }

            _errorMessage = result.Message;
        }
        catch (OperationCanceledException) when (_disposeCts.IsCancellationRequested)
        {
        }
        catch (Exception)
        {
            _errorMessage = "Saving the onboarding profile failed. Please try again.";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private Task ReviewSummaryAsync()
    {
        _saveCompleted = false;
        CurrentStepIndex = Steps.Count - 1;
        return RefreshInsightsAsync();
    }

    private async Task SetCommunicationStyleAsync(string value)
    {
        _draft.CommunicationStyle = value;
        await RefreshInsightsAsync();
    }

    private async Task HandleDomainKeyDown(KeyboardEventArgs args)
    {
        if (string.Equals(args.Key, "Enter", StringComparison.Ordinal))
        {
            await AddDomainAsync();
        }
    }

    private Task AddDomainAsync()
        => AddDomainAsync(_domainInput);

    private async Task AddDomainAsync(string? value)
    {
        var normalized = NormalizeEntry(value);
        if (string.IsNullOrWhiteSpace(normalized))
        {
            return;
        }

        if (!_draft.Domains.Any(domain => string.Equals(domain, normalized, StringComparison.OrdinalIgnoreCase)))
        {
            _draft.Domains.Add(normalized);
        }

        _domainInput = string.Empty;
        await RefreshInsightsAsync();
    }

    private async Task RemoveDomainAsync(string domain)
    {
        _draft.Domains.RemoveAll(existing => string.Equals(existing, domain, StringComparison.OrdinalIgnoreCase));
        await RefreshInsightsAsync();
    }

    private bool IsGoalSelected(string goal)
        => _draft.Goals.Any(existing => string.Equals(existing, goal, StringComparison.OrdinalIgnoreCase));

    private async Task ToggleGoalAsync(string goal, ChangeEventArgs args)
    {
        var isChecked = args.Value is bool selected && selected;
        if (isChecked)
        {
            if (!IsGoalSelected(goal))
            {
                _draft.Goals.Add(goal);
            }
        }
        else
        {
            _draft.Goals.RemoveAll(existing => string.Equals(existing, goal, StringComparison.OrdinalIgnoreCase));
        }

        await RefreshInsightsAsync();
    }

    private async Task RemoveGoalAsync(string goal)
    {
        _draft.Goals.RemoveAll(existing => string.Equals(existing, goal, StringComparison.OrdinalIgnoreCase));
        await RefreshInsightsAsync();
    }

    private async Task RefreshInsightsAsync()
    {
        if (string.IsNullOrWhiteSpace(_ownerId))
        {
            return;
        }

        try
        {
            _gaps = (await OnboardingService.DetectGapsAsync(_ownerId, _draft, _disposeCts.Token)).ToList();
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) when (_disposeCts.IsCancellationRequested)
        {
        }
        catch (Exception)
        {
            // Gap guidance is advisory; keep the wizard usable if detection is temporarily unavailable.
        }
    }

    private async Task<string> GetOrCreateOwnerIdAsync()
    {
        var existingOwnerId = await JS.InvokeAsync<string?>("leanKernelChat.storage.get", OwnerStorageKey);
        if (!string.IsNullOrWhiteSpace(existingOwnerId))
        {
            return existingOwnerId;
        }

        var ownerId = Guid.NewGuid().ToString("N");
        await JS.InvokeVoidAsync("leanKernelChat.storage.set", OwnerStorageKey, ownerId);
        return ownerId;
    }

    private string GetDomainRecommendation()
        => _draft.Domains.Count > 0
            ? "Your selected domains will help LeanKernel bias retrieval toward your core areas of interest."
            : "Add at least one domain later so retrieval can favor the topics you care about most.";

    private string GetGoalRecommendation()
        => _draft.Goals.Count > 0 || !string.IsNullOrWhiteSpace(_draft.OtherGoals)
            ? "Your goals give LeanKernel clearer signals about the work you want help with most often."
            : "Choose one or more goals to help LeanKernel prioritize research, writing, coding, or planning support.";

    private static string NormalizeEntry(string? value)
        => string.Join(' ', (value ?? string.Empty)
            .Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries));

    private static string GetValueOrFallback(string? value, string fallback)
        => string.IsNullOrWhiteSpace(value) ? fallback : value;

    public async ValueTask DisposeAsync()
    {
        if (!_disposeCts.IsCancellationRequested)
        {
            await _disposeCts.CancelAsync();
        }

        _disposeCts.Dispose();
    }

    private sealed record WizardStep(string Label, string Hint);

    private sealed record ChoiceOption(string Value, string Label, string Hint);
}
