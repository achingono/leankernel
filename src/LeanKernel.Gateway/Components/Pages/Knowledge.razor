                                        <FluentLabel Typo="Typography.Body" Style="display: block; white-space: pre-wrap; font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; max-height: 480px; overflow-y: auto; background: rgba(0,0,0,0.2); padding: 1rem; border-radius: 4px; width: 100%;">
