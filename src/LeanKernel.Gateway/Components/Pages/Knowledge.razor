                                                        @GetDocSourceFile()
                                                    </FluentBadge>
                                                </FluentStack>
                                                
                                                <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem;">
                                                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Tags</FluentLabel>
                                                    @if (_selectedDoc.Tags.Count == 0)
                                                    {
                                                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">No tags assigned</FluentLabel>
                                                    }
                                                    else
                                                    {
                                                        <FluentStack Orientation="Orientation.Horizontal" Wrap="true" Style="gap: 0.5rem;">
                                                            @foreach (var tag in _selectedDoc.Tags)
                                                            {
                                                                <FluentBadge Appearance="Appearance.Accent">@tag</FluentBadge>
                                                            }
                                                        </FluentStack>
                                                    }
                                                </FluentStack>

                                                <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem;">
                                                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Connected wiki references</FluentLabel>
                                                    @if (_selectedDoc.LinkedPages.Count == 0)
                                                    {
                                                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">No outgoing references</FluentLabel>
                                                    }
                                                    else
                                                    {
                                                        <FluentStack Orientation="Orientation.Horizontal" Wrap="true" Style="gap: 0.5rem;">
                                                            @foreach (var linkedPage in _selectedDoc.LinkedPages)
                                                            {
                                                                <FluentButton Appearance="Appearance.Outline" @onclick="() => NavigateToWikiPage(linkedPage)">@linkedPage</FluentButton>
                                                            }
                                                        </FluentStack>
                                                    }
                                                </FluentStack>
                                            </FluentStack>
                                        </FluentStack>
                                    </div>
                                </FluentStack>
                            </div>
                        </FluentStack>
                    }
                </FluentStack>
            </FluentCard>
        </div>

        <!-- Document Upload Dialog -->
        <FluentDialog @bind-Hidden:get="@(!_isUploadOpen)"
                      @bind-Hidden:set="@(value => { if (value) CloseUploadModal(); })"
                      aria-label="Upload document to library"
                      Modal="true"
                      TrapFocus="true"
                      PreventScroll="true">
            <FluentDialogBody>
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 1.25rem; min-width: min(90vw, 540px);">
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="justify-content: space-between; gap: 1rem; flex-wrap: wrap;">
                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0;">
                            <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">Upload & index document</FluentLabel>
                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Extract text (PDF, standard images, text) and index into memory.</FluentLabel>
                        </FluentStack>
                        <FluentButton Appearance="Appearance.Outline" @onclick="CloseUploadModal" Disabled="@_isUploading">Close</FluentButton>
                    </FluentStack>

                    @if (!string.IsNullOrWhiteSpace(_uploadError))
                    {
                        <FluentMessageBar Title="Ingestion failed" Intent="@MessageIntent.Error" Style="margin-bottom: 0.5rem;">
                            @_uploadError
                        </FluentMessageBar>
                    }

                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem;">
                        <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Document Title (Optional)</FluentLabel>
                        <FluentTextField @bind-Value="_uploadTitle"
                                         Placeholder="Defaults to the file name if blank"
                                         AutoComplete="off"
                                         Disabled="@_isUploading"
                                         Style="width: 100%;" />
                    </FluentStack>

                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem;">
                        <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Tags (Comma-separated)</FluentLabel>
                        <FluentTextField @bind-Value="_uploadTagsString"
                                         Placeholder="e.g. project, finance, reports"
                                         AutoComplete="off"
                                         Disabled="@_isUploading"
                                         Style="width: 100%;" />
                    </FluentStack>

                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.5rem; margin-top: 0.5rem;">
                        <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Select file</FluentLabel>
                        <div style="border: 2px dashed rgba(255,255,255,0.15); border-radius: 6px; padding: 2rem; text-align: center; background: rgba(255,255,255,0.01);">
                            <InputFile OnChange="HandleFileSelected" Disabled="@_isUploading" style="display: block; width: 100%; max-width: 320px; margin: 0 auto;" />
                            @if (_selectedBrowserFile != null)
                            {
                                <div style="margin-top: 1rem; font-weight: bold; color: var(--accent-fill-rest);">
                                    Selected: @_selectedBrowserFile.Name (@FormatFileSize(_selectedBrowserFile.Size))
                                </div>
                            }
                        </div>
                    </FluentStack>

                    @if (_isUploading)
                    {
                        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 12px; padding: 12px; background: rgba(255, 255, 255, 0.03); border-radius: 4px; border-left: 3px solid var(--accent-fill-rest);">
                            <FluentProgressRing Style="width: 20px; height: 20px;" />
                            <FluentLabel Typo="Typography.Body">Processing PaddleOCR text extraction and hybrid indexing...</FluentLabel>
                        </FluentStack>
                    }
                </FluentStack>
            </FluentDialogBody>
            <FluentDialogFooter>
                <FluentButton Appearance="Appearance.Outline" @onclick="CloseUploadModal" Disabled="@_isUploading">Cancel</FluentButton>
                <FluentButton Appearance="Appearance.Accent"
                              @onclick="UploadDocumentAsync"
                              Disabled="@IsUploadSubmitDisabled">
                    Upload & index
                </FluentButton>
            </FluentDialogFooter>
        </FluentDialog>

        <!-- Backfill Dialog -->
        <FluentDialog @bind-Hidden:get="@(!_isBackfillOpen)"
                      @bind-Hidden:set="@(value => { if (value) CloseBackfillModal(); })"
                      aria-label="Backfill documents from directory"
                      Modal="true"
                      TrapFocus="true"
                      PreventScroll="true">
            <FluentDialogBody>
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 1.25rem; min-width: min(90vw, 540px);">
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="justify-content: space-between; gap: 1rem; flex-wrap: wrap;">
                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0;">
                            <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">Backfill documents from directory</FluentLabel>
                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Batch-import a legacy corpus into the knowledge base.</FluentLabel>
                        </FluentStack>
                        <FluentButton Appearance="Appearance.Outline" @onclick="CloseBackfillModal" Disabled="@_isBackfilling">Close</FluentButton>
                    </FluentStack>

                    @if (!string.IsNullOrWhiteSpace(_backfillError))
                    {
                        <FluentMessageBar Title="Backfill failed" Intent="@MessageIntent.Error">
                            @_backfillError
                        </FluentMessageBar>
                    }

                    @if (!string.IsNullOrWhiteSpace(_backfillResultMessage))
                    {
                        <FluentMessageBar Title="Backfill complete" Intent="@(string.IsNullOrWhiteSpace(_backfillError) ? MessageIntent.Success : MessageIntent.Warning)">
                            @_backfillResultMessage
                        </FluentMessageBar>
                    }

                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem;">
                        <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Source directory</FluentLabel>
                        <FluentTextField @bind-Value="_backfillSourceDirectory"
                                         Placeholder="e.g. /app/data/managed-documents/legacy"
                                         AutoComplete="off"
                                         Disabled="@_isBackfilling"
                                         Style="width: 100%;" />
                    </FluentStack>

                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem;">
                        <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">File filter (glob pattern)</FluentLabel>
                        <FluentTextField @bind-Value="_backfillFilter"
                                         Placeholder="e.g. *.md, *.*"
                                         AutoComplete="off"
                                         Disabled="@_isBackfilling"
                                         Style="width: 100%;" />
                    </FluentStack>

                    <FluentStack Orientation="Orientation.Horizontal" Style="gap: 1rem;" Wrap="true">
                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem; min-width: 120px;">
                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Recursive</FluentLabel>
                            <FluentSwitch @bind-Value="_backfillRecursive" Disabled="@_isBackfilling" />
                        </FluentStack>

                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem; min-width: 120px;">
                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Max concurrency</FluentLabel>
                            <FluentNumberField @bind-Value="_backfillMaxConcurrency"
                                               Min="1"
                                               Max="8"
                                               Disabled="@_isBackfilling"
                                               Style="width: 100px;" />
                        </FluentStack>

                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem; min-width: 100px;">
                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Dry run</FluentLabel>
                            <FluentSwitch @bind-Value="_backfillDryRun" Disabled="@_isBackfilling" />
                        </FluentStack>
                    </FluentStack>

                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem;">
                        <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Tags (comma-separated)</FluentLabel>
                        <FluentTextField @bind-Value="_backfillTagsString"
                                         Placeholder="e.g. legacy, import, docs"
                                         AutoComplete="off"
                                         Disabled="@_isBackfilling"
                                         Style="width: 100%;" />
                    </FluentStack>

                    @if (_isBackfilling)
                    {
                        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 12px; padding: 12px; background: rgba(255, 255, 255, 0.03); border-radius: 4px; border-left: 3px solid var(--accent-fill-rest);">
                            <FluentProgressRing Style="width: 20px; height: 20px;" />
                            <FluentLabel Typo="Typography.Body">Processing backfill — ingesting files...</FluentLabel>
                        </FluentStack>
                    }
                </FluentStack>
            </FluentDialogBody>
            <FluentDialogFooter>
                <FluentButton Appearance="Appearance.Outline" @onclick="CloseBackfillModal" Disabled="@_isBackfilling">Cancel</FluentButton>
                <FluentButton Appearance="Appearance.Accent"
                              @onclick="RunBackfillAsync"
                              Disabled="@IsBackfillSubmitDisabled">
                    @(_backfillDryRun ? "Dry run" : "Start backfill")
                </FluentButton>
            </FluentDialogFooter>
        </FluentDialog>
    }
</FluentStack>

@code {
    private const int BrowsePageSize = 10;
    private const int DocumentsBrowsePageSize = 200;
    private readonly CancellationTokenSource _disposeCts = new();
    private CancellationTokenSource? _searchDebounceCts;

    private int _browsePageNumber = 1;
    private int _searchRequestVersion;
    private bool _isBrowseLoading = true;
    private bool _isCreateOpen;
    private bool _isCreating;
    private bool _isEditing;
    private bool _isPageLoading;
    private bool _isSaving;
    private bool _isSearching;
    private string _editContent = string.Empty;
    private string _newPageContent = string.Empty;
    private string _newPageSlug = string.Empty;
    private string _searchText = string.Empty;
    private string? _browseError;
    private string? _browseStatusMessage;
    private string? _createError;
    private string? _pageError;
    private string? _pageStatusMessage;
    private string? _searchError;
    private KnowledgeBrowseResult _browseResult = new()
    {
        Items = [],
        PageNumber = 1,
        PageSize = BrowsePageSize,
        TotalCount = 0,
        Sort = KnowledgeBrowseSort.RecentlyModified
    };
    private KnowledgeBrowseSort _browseSort = KnowledgeBrowseSort.RecentlyModified;
    private KnowledgePageDetail? _selectedPage;
    private IReadOnlyList<KnowledgePageSummary> _browseItems = [];
    private IReadOnlyList<KnowledgeSearchResult> _searchResults = [];
    private string BrowseSortValue => _browseSort.ToString();

    private bool IsCreateDisabled => _isCreating || string.IsNullOrWhiteSpace(_newPageSlug) || string.IsNullOrWhiteSpace(_newPageContent);

    private bool IsSaveDisabled
        => _isSaving || _selectedPage is null || string.IsNullOrWhiteSpace(_editContent);

    private async Task HandlePageCardKeyDownAsync(KeyboardEventArgs args, string slug)
    {
        if (!IsActivationKey(args))
        {
            return;
        }

        await OpenPageAsync(slug);
    }

    private static bool IsActivationKey(KeyboardEventArgs args)
        => string.Equals(args.Key, "Enter", StringComparison.Ordinal)
            || string.Equals(args.Key, " ", StringComparison.Ordinal)
            || string.Equals(args.Key, "Spacebar", StringComparison.Ordinal);

    protected override async Task OnInitializedAsync()
        => await LoadBrowseAsync(selectFirstPage: true);

    private async Task HandleSearchInputAsync(ChangeEventArgs args)
    {
        _searchText = args.Value?.ToString() ?? string.Empty;
        _searchError = null;
        _pageStatusMessage = null;

        var requestVersion = Interlocked.Increment(ref _searchRequestVersion);
        CancelPendingSearch();

        if (string.IsNullOrWhiteSpace(_searchText))
        {
            _isSearching = false;
            _searchResults = [];
            return;
        }

        var searchDebounceCts = CancellationTokenSource.CreateLinkedTokenSource(_disposeCts.Token);
        _searchDebounceCts = searchDebounceCts;
        _isSearching = true;

        try
        {
            await Task.Delay(300, searchDebounceCts.Token);
            var searchResults = await KnowledgeUiService.SearchPagesAsync(_searchText.Trim(), 8, searchDebounceCts.Token);
            if (requestVersion != _searchRequestVersion || _disposeCts.IsCancellationRequested)
            {
                return;
            }

            _searchResults = searchResults;
        }
        catch (OperationCanceledException) when (searchDebounceCts.IsCancellationRequested || _disposeCts.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            if (requestVersion != _searchRequestVersion || _disposeCts.IsCancellationRequested)
            {
                return;
            }

            _searchResults = [];
            _searchError = $"Search failed: {ex.Message}";
        }
        finally
        {
            if (ReferenceEquals(_searchDebounceCts, searchDebounceCts))
            {
                _searchDebounceCts = null;
            }

            searchDebounceCts.Dispose();

            if (requestVersion == _searchRequestVersion && !_disposeCts.IsCancellationRequested)
            {
                _isSearching = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task HandleSortChangedAsync(ChangeEventArgs args)
    {
        if (!Enum.TryParse<KnowledgeBrowseSort>(args.Value?.ToString(), out var sort) || sort == _browseSort)
        {
            return;
        }

        _browseSort = sort;
        _browsePageNumber = 1;
        await LoadBrowseAsync(selectFirstPage: _selectedPage is null);
    }

    private async Task ChangePageAsync(int pageNumber)
    {
        if (pageNumber < 1 || pageNumber == _browsePageNumber)
        {
            return;
        }

        _browsePageNumber = pageNumber;
        await LoadBrowseAsync(selectFirstPage: _selectedPage is null);
    }

    private async Task LoadBrowseAsync(bool selectFirstPage)
    {
        _isBrowseLoading = true;
        _browseError = null;
        _browseStatusMessage = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            _browseResult = await KnowledgeUiService.BrowsePagesAsync(_browsePageNumber, BrowsePageSize, _browseSort, _disposeCts.Token);
            _browseItems = _browseResult.Items;
            _browseStatusMessage = _browseResult.StatusMessage;

            if (selectFirstPage && _selectedPage is null && _browseItems.Count > 0)
            {
                await OpenPageAsync(_browseItems[0].Slug);
            }
        }
        catch (OperationCanceledException) when (_disposeCts.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            _browseItems = [];
            _browseError = $"Browse failed: {ex.Message}";
        }
        finally
        {
            _isBrowseLoading = false;
        }
    }

    private async Task OpenPageAsync(string slug)
    {
        _isPageLoading = true;
        _isEditing = false;
        _pageError = null;
        _pageStatusMessage = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var page = await KnowledgeUiService.GetPageDetailAsync(slug, _disposeCts.Token);
            if (page is null)
            {
                _selectedPage = null;
                _pageError = $"Page '{slug}' was not found.";
                return;
            }

            _selectedPage = page;
            _editContent = page.Content;
        }
        catch (OperationCanceledException) when (_disposeCts.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            _selectedPage = null;
            _pageError = $"Page load failed: {ex.Message}";
        }
        finally
        {
            _isPageLoading = false;
        }
    }

    private void StartEdit()
    {
        if (_selectedPage is null)
        {
            return;
        }

        _editContent = _selectedPage.Content;
        _pageStatusMessage = null;
        _isEditing = true;
    }

    private void CancelEdit()
    {
        _isEditing = false;
        _pageStatusMessage = null;

        if (_selectedPage is not null)
        {
            _editContent = _selectedPage.Content;
        }
    }

    private async Task SaveEditAsync()
    {
        if (_selectedPage is null || string.IsNullOrWhiteSpace(_editContent))
        {
            return;
        }

        _isSaving = true;
        _pageError = null;
        _pageStatusMessage = null;

        try
        {
            await KnowledgeUiService.SavePageAsync(_selectedPage.Slug, _editContent, _disposeCts.Token);
            await LoadBrowseAsync(selectFirstPage: false);
            await OpenPageAsync(_selectedPage.Slug);
            _pageStatusMessage = $"Saved {_selectedPage.Slug}.";
            _isEditing = false;
        }
        catch (OperationCanceledException) when (_disposeCts.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            _pageError = $"Save failed: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void OpenCreateModal()
    {
        _createError = null;
        _newPageSlug = string.Empty;
        _newPageContent = string.Empty;
        _isCreateOpen = true;
    }

    private void CloseCreateModal()
    {
        if (_isCreating)
        {
            return;
        }

        _isCreateOpen = false;
        _createError = null;
    }

    private async Task CreatePageAsync()
    {
        if (IsCreateDisabled)
        {
            return;
        }

        _isCreating = true;
        _createError = null;

        var slug = _newPageSlug.Trim();

        try
        {
            await KnowledgeUiService.SavePageAsync(slug, _newPageContent, _disposeCts.Token);
            _browsePageNumber = 1;
            await LoadBrowseAsync(selectFirstPage: false);
            await OpenPageAsync(slug);
            _pageStatusMessage = $"Created {slug}.";
            _isCreateOpen = false;
        }
        catch (OperationCanceledException) when (_disposeCts.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            _createError = $"Create failed: {ex.Message}";
        }
        finally
        {
            _isCreating = false;
        }
    }

    private void CancelPendingSearch()
    {
        _searchDebounceCts?.Cancel();
        _searchDebounceCts = null;
    }

    private bool IsSelected(string slug)
        => _selectedPage is not null && string.Equals(_selectedPage.Slug, slug, StringComparison.OrdinalIgnoreCase);

    private string GetSelectedPageSubtitle()
        => _selectedPage is null
            ? string.Empty
            : _selectedPage.LastModified is { } lastModified
                ? $"Last updated {lastModified.LocalDateTime:g}"
                : "Last modified date unavailable";

    private static string FormatTimestamp(DateTimeOffset? value)
        => value is { } timestamp
            ? timestamp.LocalDateTime.ToString("g", CultureInfo.CurrentCulture)
            : "Unknown";

    public async ValueTask DisposeAsync()
    {
        CancelPendingSearch();

        if (!_disposeCts.IsCancellationRequested)
        {
            await _disposeCts.CancelAsync();
        }

        _disposeCts.Dispose();
    }

    // =========================================================================
    // Document Library Tab Methods & Backing Logic
    // =========================================================================

    private enum TabMode { Wiki, Documents }
    private TabMode _currentTab = TabMode.Wiki;

    private List<KnowledgePageSummary> _documentsList = [];
    private bool _isDocsLoading;
    private string? _docsError;
    private KnowledgePageDetail? _selectedDoc;
    private string? _downloadUrl;

    // Upload & Ingestion variables
    private bool _isUploadOpen;
    private bool _isUploading;
    private string? _uploadError;
    private string _uploadTitle = string.Empty;
    private string _uploadTagsString = string.Empty;
    private Microsoft.AspNetCore.Components.Forms.IBrowserFile? _selectedBrowserFile;

    private bool IsUploadSubmitDisabled => _isUploading || _selectedBrowserFile is null;

    private void SetTab(TabMode mode)
    {
        _currentTab = mode;
        _pageStatusMessage = null;
        _pageError = null;
        
        if (mode == TabMode.Documents)
        {
            _ = LoadDocumentsAsync(selectFirst: _selectedDoc is null);
        }
        else
        {
            _ = LoadBrowseAsync(selectFirstPage: _selectedPage is null);
        }
    }

    private async Task LoadDocumentsAsync(bool selectFirst)
    {
        _isDocsLoading = true;
        _docsError = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            _documentsList = await DocumentUiService.BrowseDocumentsAsync(
                pageNumber: 1,
                pageSize: DocumentsBrowsePageSize,
                ct: _disposeCts.Token);
            if (selectFirst && _documentsList.Count > 0)
            {
                await OpenDocumentAsync(_documentsList[0].Slug);
            }
        }
        catch (Exception ex)
        {
            _docsError = $"Failed to load documents: {ex.Message}";
        }
        finally
        {
            _isDocsLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OpenDocumentAsync(string slug)
    {
        _isPageLoading = true;
        _pageError = null;
        _pageStatusMessage = null;
        _downloadUrl = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var page = await KnowledgeUiService.GetPageDetailAsync(slug, _disposeCts.Token);
            if (page is null)
            {
                _selectedDoc = null;
                _pageError = $"Document '{slug}' was not found.";
                return;
            }

            _selectedDoc = page;

            var parsedDocument = ParseFrontmatter(page.Content);
            string? storagePath = null;
            if (parsedDocument.Metadata.TryGetValue("storage_path", out var resolvedStoragePath)
                && !string.IsNullOrWhiteSpace(resolvedStoragePath))
            {
                storagePath = resolvedStoragePath;
            }
            else if (parsedDocument.Metadata.TryGetValue("source_file", out var sourceFile)
                     && !string.IsNullOrWhiteSpace(sourceFile))
            {
                storagePath = sourceFile;
            }

            if (!string.IsNullOrEmpty(storagePath))
            {
                _downloadUrl = await DocumentUiService.GetDownloadUrlAsync(storagePath, _disposeCts.Token);
            }
        }
        catch (Exception ex)
        {
            _selectedDoc = null;
            _pageError = $"Document load failed: {ex.Message}";
        }
        finally
        {
            _isPageLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private bool IsDocSelected(string slug)
        => _selectedDoc is not null && string.Equals(_selectedDoc.Slug, slug, StringComparison.OrdinalIgnoreCase);

    private string FormatDocSlug(string slug)
    {
        if (slug.StartsWith("doc/"))
        {
            return slug["doc/".Length..];
        }
        return slug;
    }

    private string GetCleanDocContent(string fullContent)
        => ParseFrontmatter(fullContent).Body;

    private string GetDocSourceFile()
    {
        if (_selectedDoc == null)
        {
            return "Unknown";
        }

        var parsedDocument = ParseFrontmatter(_selectedDoc.Content);
        if (parsedDocument.Metadata.TryGetValue("source_file", out var sourcePath)
            && !string.IsNullOrWhiteSpace(sourcePath))
        {
            return sourcePath;
        }

        if (parsedDocument.Metadata.TryGetValue("storage_path", out var storagePath)
            && !string.IsNullOrWhiteSpace(storagePath))
        {
            return storagePath;
        }

        return "Unknown";
    }

    private void NavigateToWikiPage(string slug)
    {
        SetTab(TabMode.Wiki);
        _ = OpenPageAsync(slug);
    }

    private void OpenUploadModal()
    {
        _uploadError = null;
        _uploadTitle = string.Empty;
        _uploadTagsString = string.Empty;
        _selectedBrowserFile = null;
        _isUploadOpen = true;
    }

    private void CloseUploadModal()
    {
        if (_isUploading)
        {
            return;
        }
        _isUploadOpen = false;
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        _selectedBrowserFile = e.File;
        _uploadError = null;
    }

    private async Task UploadDocumentAsync()
    {
        if (IsUploadSubmitDisabled || _selectedBrowserFile is null)
        {
            return;
        }

        _isUploading = true;
        _uploadError = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var tagsList = _uploadTagsString
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToList();

            using var stream = _selectedBrowserFile.OpenReadStream(15 * 1024 * 1024); // max 15MB file read
            
            var queuedJob = DocumentIngestionQueue.Queue(
                _selectedBrowserFile.Name,
                stream,
                string.IsNullOrWhiteSpace(_uploadTitle) ? null : _uploadTitle,
                tagsList
            );

            _isUploadOpen = false;
            _pageStatusMessage = $"Document queued for ingestion (Job ID: {queuedJob.JobId}). Processing will complete in the background.";
            
            await LoadDocumentsAsync(selectFirst: false);
        }
        catch (OperationCanceledException ex)
        {
            _logger.LogWarning(ex, "UI document upload cancelled.");
            _uploadError = "Upload cancelled.";
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "UI document upload and queueing failed.");
            _uploadError = $"Queueing failed: {ex.Message}";
        }
        finally
        {
            _isUploading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    // =========================================================================
    // Backfill Dialog Fields & Methods
    // =========================================================================

    private bool _isBackfillOpen;
    private bool _isBackfilling;
    private string? _backfillError;
    private string? _backfillResultMessage;
    private string _backfillSourceDirectory = string.Empty;
    private string _backfillFilter = "*.*";
    private bool _backfillRecursive = true;
    private int _backfillMaxConcurrency = 2;
    private bool _backfillDryRun;
    private string _backfillTagsString = string.Empty;

    private bool IsBackfillSubmitDisabled => _isBackfilling || string.IsNullOrWhiteSpace(_backfillSourceDirectory);

    private void OpenBackfillModal()
    {
        _backfillError = null;
        _backfillResultMessage = null;
        _backfillSourceDirectory = string.Empty;
        _backfillFilter = "*.*";
        _backfillRecursive = true;
        _backfillMaxConcurrency = 2;
        _backfillDryRun = false;
        _backfillTagsString = string.Empty;
        _isBackfillOpen = true;
    }

    private void CloseBackfillModal()
    {
        if (_isBackfilling)
        {
            return;
        }
        _isBackfillOpen = false;
    }

    private async Task RunBackfillAsync()
    {
        if (IsBackfillSubmitDisabled)
        {
            return;
        }

        _isBackfilling = true;
        _backfillError = null;
        _backfillResultMessage = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var tagsList = string.IsNullOrWhiteSpace(_backfillTagsString)
                ? null
                : _backfillTagsString
                    .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                    .ToList();

            var count = await DocumentBackfillService.RunBackfillAsync(
                _backfillSourceDirectory.Trim(),
                _backfillFilter.Trim(),
                _backfillRecursive,
                tagsList,
                _backfillMaxConcurrency,
                checkpointPath: null,
                _backfillDryRun,
                _disposeCts.Token).ConfigureAwait(false);

            _backfillResultMessage = _backfillDryRun
                ? $"Dry-run complete: would import {count} documents from '{_backfillSourceDirectory}'."
                : $"Backfill complete: {count} documents ingested from '{_backfillSourceDirectory}'.";

            if (!_backfillDryRun)
            {
                await LoadDocumentsAsync(selectFirst: false);
            }
        }
        catch (OperationCanceledException) when (_disposeCts.IsCancellationRequested)
        {
            _backfillError = "Backfill cancelled.";
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Backfill failed for {SourceDirectory}", _backfillSourceDirectory);
            _backfillError = $"Backfill failed: {ex.Message}";
        }
        finally
        {
            _isBackfilling = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string FormatFileSize(long bytes)
    {
        string[] suffixes = { "B", "KB", "MB", "GB" };
        int counter = 0;
        decimal number = bytes;
        while (Math.Round(number / 1024) >= 1)
        {
            number /= 1024;
            counter++;
        }
        return $"{number:n1} {suffixes[counter]}";
    }

    private static ParsedFrontmatter ParseFrontmatter(string? content)
    {
        var normalized = NormalizeNewLines(content);
        if (string.IsNullOrWhiteSpace(normalized))
        {
            return new ParsedFrontmatter(
                new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase),
                string.Empty);
        }

        if (!normalized.StartsWith("---\n", StringComparison.Ordinal))
        {
            return new ParsedFrontmatter(
                new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase),
                normalized.Trim());
        }

        var closingIndex = normalized.IndexOf("\n---\n", 4, StringComparison.Ordinal);
        if (closingIndex < 0)
        {
            return new ParsedFrontmatter(
                new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase),
                normalized.Trim());
        }

        var metadata = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        var frontmatter = normalized[4..closingIndex];
        foreach (var line in frontmatter.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            if (line.StartsWith('#'))
            {
                continue;
            }

            var separatorIndex = line.IndexOf(':');
            if (separatorIndex <= 0)
            {
                continue;
            }

            var key = line[..separatorIndex].Trim();
            var value = line[(separatorIndex + 1)..].Trim();
            metadata[key] = UnquoteYaml(value);
        }

        return new ParsedFrontmatter(
            metadata,
            normalized[(closingIndex + 5)..].Trim());
    }

    private static string NormalizeNewLines(string? value)
        => (value ?? string.Empty).Replace("\r\n", "\n", StringComparison.Ordinal).Replace('\r', '\n');

    private static string UnquoteYaml(string value)
    {
        if (value.Length >= 2
            && value[0] == '"'
            && value[^1] == '"')
        {
            return value[1..^1]
                .Replace("\\\"", "\"", StringComparison.Ordinal)
                .Replace("\\\\", "\\", StringComparison.Ordinal);
        }

        return value;
    }

    private sealed record ParsedFrontmatter(
        IReadOnlyDictionary<string, string> Metadata,
        string Body);
}
