@page "/knowledge"
@using System.Globalization
@using System.Threading
@using Microsoft.AspNetCore.Components.Web
@using LeanKernel.Tools
@inject KnowledgeUiService KnowledgeUiService
@inject DocumentUiService DocumentUiService
@inject IDocumentIngestionQueue DocumentIngestionQueue
@inject ILogger<Knowledge> _logger
@inject DocumentBackfillService DocumentBackfillService
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>LeanKernel Knowledge</PageTitle>

<FluentStack Orientation="Orientation.Vertical" Class="lk-page">
    <PageHeader Title="Knowledge" Subtitle="Browse GBrain wiki pages, inspect linked knowledge, and curate durable context.">
        <Actions>
            @if (_currentTab == TabMode.Wiki)
            {
                <FluentButton Appearance="Appearance.Accent" @onclick="OpenCreateModal" AriaLabel="Create new page" id="knowledge-create-button">
                    <FluentIcon Value="@(new Icons.Regular.Size16.DocumentAdd())" />
                </FluentButton>
                <FluentTooltip Anchor="knowledge-create-button" Position="TooltipPosition.Top" Delay="150">
                    Create new page
                </FluentTooltip>
            }
            else
            {
                <FluentButton Appearance="Appearance.Accent" @onclick="OpenUploadModal" AriaLabel="Upload document" id="knowledge-upload-button">
                    <FluentIcon Value="@(new Icons.Regular.Size16.ArrowUpload())" />
                </FluentButton>
                <FluentTooltip Anchor="knowledge-upload-button" Position="TooltipPosition.Top" Delay="150">
                    Upload document
                </FluentTooltip>
            }
        </Actions>
    </PageHeader>

    <FluentStack Orientation="Orientation.Horizontal" Class="lk-tab-toggle-group">
        <FluentButton Appearance="@(_currentTab == TabMode.Wiki ? Appearance.Accent : Appearance.Neutral)" 
                      Class="lk-tab-toggle"
                      @onclick="() => SetTab(TabMode.Wiki)">
            Wiki Pages
        </FluentButton>
        <FluentButton Appearance="@(_currentTab == TabMode.Documents ? Appearance.Accent : Appearance.Neutral)" 
                      Class="lk-tab-toggle"
                      @onclick="() => SetTab(TabMode.Documents)">
            Document Library
        </FluentButton>
    </FluentStack>

    @if (_currentTab == TabMode.Wiki)
    {
        <FluentCard aria-labelledby="knowledge-search-title">
            <FluentStack Orientation="Orientation.Vertical" Class="lk-card-content">
                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Class="lk-card-header">
                    <FluentStack Orientation="Orientation.Vertical" Class="lk-card-header-copy">
                        <FluentLabel Id="knowledge-search-title" Typo="Typography.Subject" Weight="FontWeight.Bold">Search knowledge</FluentLabel>
                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Find pages by slug, facts, and compiled truth.</FluentLabel>
                    </FluentStack>
                    @if (_isSearching)
                    {
                        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Class="lk-badge-group" role="status">
                            <FluentProgressRing Style="width: 20px; height: 20px;" />
                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Searching…</FluentLabel>
                        </FluentStack>
                    }
                </FluentStack>

                <FluentStack Orientation="Orientation.Vertical" Class="lk-form-field">
                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Search query</FluentLabel>
                    <FluentSearch Id="knowledge-search-input"
                                  @bind-Value="_searchText"
                                  @bind-Value:after="@(async () => await HandleSearchInputAsync(new ChangeEventArgs { Value = _searchText }))"
                                  Placeholder="Search wiki pages..."
                                  AutoComplete="off"
                                  Immediate="true"
                                  AriaLabel="Search query"
                                  Style="width: 100%;" />
                </FluentStack>

                @if (!string.IsNullOrWhiteSpace(_searchError))
                {
                    <FluentMessageBar Title="Search failed" Intent="@MessageIntent.Error">
                        @_searchError
                    </FluentMessageBar>
                }

                <FluentStack Orientation="Orientation.Vertical" Class="lk-section" aria-live="polite">
                    @if (string.IsNullOrWhiteSpace(_searchText) && _searchResults.Count == 0 && !_isSearching)
                    {
                        <div class="lk-empty-state">
                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Start with a question</FluentLabel>
                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Search by topic, slug, or relationship to jump directly into the knowledge base.</FluentLabel>
                        </div>
                    }
                    else if (_searchResults.Count == 0 && !_isSearching)
                    {
                        <div class="lk-empty-state">
                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">No matches found</FluentLabel>
                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Try another keyword or create a new page for this topic.</FluentLabel>
                        </div>
                    }
                    else
                    {
                        @foreach (var result in _searchResults)
                        {
                            <div class="lk-list-item lk-card-interactive"
                                 role="button"
                                 tabindex="0"
                                 aria-label="@($"Open knowledge page {result.Slug}")"
                                 @onclick="() => OpenPageAsync(result.Slug)"
                                 @onkeydown="@(args => HandlePageCardKeyDownAsync(args, result.Slug))">
                                <FluentStack Orientation="Orientation.Vertical" Class="lk-card-compact">
                                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Class="lk-card-header">
                                        <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">@result.Slug</FluentLabel>
                                        <FluentBadge Appearance="Appearance.Neutral">Score @result.Score.ToString("0.000", CultureInfo.InvariantCulture)</FluentBadge>
                                    </FluentStack>
                                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@result.Preview</FluentLabel>
                                </FluentStack>
                            </div>
                        }
                    }
                </FluentStack>
            </FluentStack>
        </FluentCard>

        <div class="lk-split-panel" style="--lk-sidebar-width: 340px;">
            <FluentCard aria-labelledby="knowledge-browse-title" Class="lk-responsive-card">
                <FluentStack Orientation="Orientation.Vertical" Class="lk-card-content">
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Bottom" Class="lk-card-header">
                        <FluentStack Orientation="Orientation.Vertical" Class="lk-card-header-copy">
                            <FluentLabel Id="knowledge-browse-title" Typo="Typography.Subject" Weight="FontWeight.Bold">Browse pages</FluentLabel>
                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Page through the wiki and jump into recently changed knowledge.</FluentLabel>
                        </FluentStack>

                        <FluentStack Orientation="Orientation.Vertical" Class="lk-form-field" Style="min-width: 180px;">
                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Sort</FluentLabel>
                            <FluentSelect Id="knowledge-sort-select"
                                          TOption="string"
                                          @bind-Value:get="@BrowseSortValue"
                                          @bind-Value:set="@(async value => await HandleSortChangedAsync(new ChangeEventArgs { Value = value }))"
                                          Disabled="@_isBrowseLoading"
                                          Style="width: 100%;">
                                <FluentOption Value="@KnowledgeBrowseSort.RecentlyModified.ToString()">Recently modified</FluentOption>
                                <FluentOption Value="@KnowledgeBrowseSort.Alphabetical.ToString()">Alphabetical</FluentOption>
                            </FluentSelect>
                        </FluentStack>
                    </FluentStack>

                    @if (!string.IsNullOrWhiteSpace(_browseError))
                    {
                        <FluentMessageBar Title="Browse failed" Intent="@MessageIntent.Error">
                            @_browseError
                        </FluentMessageBar>
                    }
                    else if (!string.IsNullOrWhiteSpace(_browseStatusMessage))
                    {
                        <FluentMessageBar Title="Browse status" Intent="@MessageIntent.Info">
                            @_browseStatusMessage
                        </FluentMessageBar>
                    }

                    @if (_isBrowseLoading)
                    {
                        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Class="lk-loading" role="status">
                            <FluentProgressRing />
                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Loading pages…</FluentLabel>
                        </FluentStack>
                    }
                    else if (_browseItems.Count == 0)
                    {
                        <div class="lk-empty-state">
                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">No pages available</FluentLabel>
                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Use search or create a new page to start building knowledge.</FluentLabel>
                        </div>
                    }
                    else
                    {
                        <FluentStack Orientation="Orientation.Vertical" Class="lk-section-tight">
                            @foreach (var item in _browseItems)
                            {
                                <div class="@($"lk-list-item lk-card-interactive{(IsSelected(item.Slug) ? " lk-active" : "")}")"
                                     role="button"
                                     tabindex="0"
                                     aria-label="@($"Open knowledge page {item.Slug}")"
                                     @onclick="() => OpenPageAsync(item.Slug)"
                                     @onkeydown="@(args => HandlePageCardKeyDownAsync(args, item.Slug))">
                                    <FluentStack Orientation="Orientation.Vertical" Class="lk-card-compact">
                                        <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">@item.Slug</FluentLabel>
                                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@FormatTimestamp(item.LastModified)</FluentLabel>
                                        <FluentBadge Appearance="Appearance.Neutral">@item.TagCount tag@(item.TagCount == 1 ? string.Empty : "s")</FluentBadge>
                                    </FluentStack>
                                </div>
                            }
                        </FluentStack>
                    }

                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Class="lk-card-header">
                        <FluentButton Appearance="Appearance.Outline"
                                      @onclick="() => ChangePageAsync(_browsePageNumber - 1)"
                                      Disabled="@(!_browseResult.HasPreviousPage || _isBrowseLoading)">
                            Previous
                        </FluentButton>
                        <FluentBadge Appearance="Appearance.Neutral">Page @_browsePageNumber</FluentBadge>
                        <FluentButton Appearance="Appearance.Outline"
                                      @onclick="() => ChangePageAsync(_browsePageNumber + 1)"
                                      Disabled="@(!_browseResult.HasNextPage || _isBrowseLoading)">
                            Next
                        </FluentButton>
                    </FluentStack>
                </FluentStack>
            </FluentCard>

            <FluentCard aria-busy="@(_isPageLoading || _isSaving || _isCreating)" Class="lk-responsive-card">
                <FluentStack Orientation="Orientation.Vertical" Class="lk-card-content">
                    @if (!string.IsNullOrWhiteSpace(_pageError))
                    {
                        <FluentMessageBar Title="Page error" Intent="@MessageIntent.Error">
                            @_pageError
                        </FluentMessageBar>
                    }

                    @if (!string.IsNullOrWhiteSpace(_pageStatusMessage))
                    {
                        <FluentMessageBar Title="Page updated" Intent="@MessageIntent.Success">
                            @_pageStatusMessage
                        </FluentMessageBar>
                    }

                    @if (_isPageLoading)
                    {
                        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Class="lk-loading" role="status">
                            <FluentProgressRing />
                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Loading page details…</FluentLabel>
                        </FluentStack>
                    }
                    else if (_selectedPage is null)
                    {
                        <div class="lk-empty-state">
                            <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">Select a page</FluentLabel>
                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Choose a browse result or run a search to inspect wiki content, metadata, and linked relationships.</FluentLabel>
                        </div>
                    }
                    else
                    {
                        <FluentStack Orientation="Orientation.Vertical" Class="lk-section">
                            <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Class="lk-card-header">
                                <FluentStack Orientation="Orientation.Vertical" Class="lk-card-header-copy">
                                    <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">@_selectedPage.Slug</FluentLabel>
                                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@GetSelectedPageSubtitle()</FluentLabel>
                                </FluentStack>
                                <FluentStack Orientation="Orientation.Horizontal" Class="lk-badge-group">
                                    @if (_isEditing)
                                    {
                                        <FluentButton Appearance="Appearance.Accent"
                                                      @onclick="SaveEditAsync"
                                                      Disabled="@IsSaveDisabled">
                                            Save changes
                                        </FluentButton>
                                        <FluentButton Appearance="Appearance.Outline" @onclick="CancelEdit">Cancel</FluentButton>
                                    }
                                    else
                                    {
                                        <FluentButton Appearance="Appearance.Outline" @onclick="StartEdit">Edit</FluentButton>
                                    }
                                </FluentStack>
                            </FluentStack>

                            <div class="lk-split-panel" style="--lk-sidebar-width: 320px;">
                                <div class="lk-panel">
                                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 1rem;">
                                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0;">
                                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Page content</FluentLabel>
                                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Rendered as raw wiki text for now.</FluentLabel>
                                        </FluentStack>

                                        @if (_isEditing)
                                        {
                                            <FluentTextArea @bind-Value="_editContent"
                                                            Rows="20"
                                                            Maxlength="40000"
                                                            Style="width: 100%;" />
                                        }
                                        else
                                        {
                                            <FluentLabel Typo="Typography.Body" Style="display: block; white-space: pre-wrap; font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;">
                                                @_selectedPage.Content
                                            </FluentLabel>
                                        }
                                    </FluentStack>
                                </div>

                                <FluentStack Orientation="Orientation.Vertical" Class="lk-responsive-card" Style="gap: 1rem;">
                                    <div class="lk-panel">
                                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.75rem;">
                                            <FluentStack Orientation="Orientation.Vertical" Style="gap: 0;">
                                                <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Metadata</FluentLabel>
                                                <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Key page facts and navigation links.</FluentLabel>
                                            </FluentStack>

                                            <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.75rem;">
                                                <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem;">
                                                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Slug</FluentLabel>
                                                    <FluentBadge Appearance="Appearance.Neutral">@_selectedPage.Slug</FluentBadge>
                                                </FluentStack>
                                                <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem;">
                                                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Last modified</FluentLabel>
                                                    <FluentLabel Typo="Typography.Body">@FormatTimestamp(_selectedPage.LastModified)</FluentLabel>
                                                </FluentStack>
                                                <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem;">
                                                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Tags</FluentLabel>
                                                    @if (_selectedPage.Tags.Count == 0)
                                                    {
                                                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">No tags</FluentLabel>
                                                    }
                                                    else
                                                    {
                                                        <FluentStack Orientation="Orientation.Horizontal" Wrap="true" Style="gap: 0.5rem;">
                                                            @foreach (var tag in _selectedPage.Tags)
                                                            {
                                                                <FluentBadge Appearance="Appearance.Accent">@tag</FluentBadge>
                                                            }
                                                        </FluentStack>
                                                    }
                                                </FluentStack>
                                                <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem;">
                                                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Linked pages</FluentLabel>
                                                    @if (_selectedPage.LinkedPages.Count == 0)
                                                    {
                                                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">No linked pages</FluentLabel>
                                                    }
                                                    else
                                                    {
                                                        <FluentStack Orientation="Orientation.Horizontal" Wrap="true" Style="gap: 0.5rem;">
                                                            @foreach (var linkedPage in _selectedPage.LinkedPages)
                                                            {
                                                                <FluentButton Appearance="Appearance.Outline" @onclick="() => OpenPageAsync(linkedPage)">@linkedPage</FluentButton>
                                                            }
                                                        </FluentStack>
                                                    }
                                                </FluentStack>
                                            </FluentStack>
                                        </FluentStack>
                                    </div>

                                    <div class="lk-panel" role="group" aria-label="Knowledge graph">
                                        <FluentStack Orientation="Orientation.Vertical" Class="lk-graph-shell">
                                            <FluentStack Orientation="Orientation.Vertical" Style="gap: 0;">
                                                <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Relationship graph</FluentLabel>
                                                <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Quick navigation across linked wiki pages.</FluentLabel>
                                            </FluentStack>

                                            <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center" Class="lk-graph-node-list">
                                                <FluentButton Appearance="Appearance.Accent" Class="lk-graph-node-main" @onclick="() => OpenPageAsync(_selectedPage.Slug)">
                                                    @_selectedPage.Slug
                                                </FluentButton>

                                                @if (_selectedPage.LinkedPages.Count == 0)
                                                {
                                                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Add links to this page to expand the graph.</FluentLabel>
                                                }
                                                else
                                                {
                                                    <FluentStack Orientation="Orientation.Horizontal" Wrap="true" HorizontalAlignment="HorizontalAlignment.Center" Class="lk-graph-link-list">
                                                        @foreach (var linkedPage in _selectedPage.LinkedPages)
                                                        {
                                                            <FluentButton Appearance="Appearance.Outline" Class="lk-graph-node-link" @onclick="() => OpenPageAsync(linkedPage)">@linkedPage</FluentButton>
                                                        }
                                                    </FluentStack>
                                                }
                                            </FluentStack>
                                        </FluentStack>
                                    </div>
                                </FluentStack>
                            </div>
                        </FluentStack>
                    }
                </FluentStack>
            </FluentCard>
        </div>

        <FluentDialog @bind-Hidden:get="@(!_isCreateOpen)"
                      @bind-Hidden:set="@(value => { if (value) CloseCreateModal(); })"
                      aria-label="Create knowledge page"
                      Modal="true"
                      TrapFocus="true"
                      PreventScroll="true">
            <FluentDialogBody>
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 1rem; min-width: min(90vw, 720px);">
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="justify-content: space-between; gap: 1rem; flex-wrap: wrap;">
                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0;">
                            <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">Create knowledge page</FluentLabel>
                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Add a new wiki page and immediately open it in the browser.</FluentLabel>
                        </FluentStack>
                        <FluentButton Appearance="Appearance.Outline" @onclick="CloseCreateModal" Disabled="@_isCreating">Close</FluentButton>
                    </FluentStack>

                    @if (!string.IsNullOrWhiteSpace(_createError))
                    {
                        <FluentMessageBar Title="Create failed" Intent="@MessageIntent.Error">
                            @_createError
                        </FluentMessageBar>
                    }

                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem;">
                        <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Slug</FluentLabel>
                        <FluentTextField Id="knowledge-create-slug"
                                         @bind-Value="_newPageSlug"
                                         Maxlength="256"
                                         AutoComplete="off"
                                         Autofocus="true"
                                         Disabled="@_isCreating"
                                         Style="width: 100%;" />
                    </FluentStack>

                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem;">
                        <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Content</FluentLabel>
                        <FluentTextArea Id="knowledge-create-content"
                                        @bind-Value="_newPageContent"
                                        Rows="12"
                                        Maxlength="40000"
                                        Disabled="@_isCreating"
                                        Style="width: 100%;" />
                    </FluentStack>
                </FluentStack>
            </FluentDialogBody>
            <FluentDialogFooter>
                <FluentButton Appearance="Appearance.Outline" @onclick="CloseCreateModal" Disabled="@_isCreating">Cancel</FluentButton>
                <FluentButton Appearance="Appearance.Accent"
                              @onclick="CreatePageAsync"
                              Disabled="@IsCreateDisabled">
                    Create page
                </FluentButton>
            </FluentDialogFooter>
        </FluentDialog>
    }
    else
    {
        <div class="lk-split-panel" style="--lk-sidebar-width: 340px;">
            <!-- Left panel: Browse documents -->
            <FluentCard aria-labelledby="documents-browse-title" Class="lk-responsive-card">
                <FluentStack Orientation="Orientation.Vertical" Class="lk-card-content">
                    <FluentStack Orientation="Orientation.Vertical" Class="lk-card-header-copy">
                        <FluentLabel Id="documents-browse-title" Typo="Typography.Subject" Weight="FontWeight.Bold">Browse documents</FluentLabel>
                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">View and manage rich documents indexed inside GBrain.</FluentLabel>
                    </FluentStack>

                    <FluentButton Appearance="Appearance.Accent" @onclick="OpenUploadModal" Style="width: 100%; margin-top: 1rem; margin-bottom: 1rem;">
                        Upload document
                    </FluentButton>

                    <FluentButton Appearance="Appearance.Outline" @onclick="OpenBackfillModal" Style="width: 100%; margin-bottom: 1rem;">
                        Backfill from directory
                    </FluentButton>

                    @if (_isDocsLoading)
                    {
                        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Class="lk-loading" role="status">
                            <FluentProgressRing />
                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Loading documents…</FluentLabel>
                        </FluentStack>
                    }
                    else if (_docsError != null)
                    {
                        <FluentMessageBar Title="Error" Intent="@MessageIntent.Error">
                            @_docsError
                        </FluentMessageBar>
                    }
                    else if (_documentsList.Count == 0)
                    {
                        <div class="lk-empty-state">
                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">No documents found</FluentLabel>
                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Upload a PDF, image, or text file to start building your AI memory index.</FluentLabel>
                        </div>
                    }
                    else
                    {
                        <FluentStack Orientation="Orientation.Vertical" Class="lk-section-tight" Style="max-height: 520px; overflow-y: auto;">
                            @foreach (var doc in _documentsList)
                            {
                                <div class="@($"lk-list-item lk-card-interactive{(IsDocSelected(doc.Slug) ? " lk-active" : "")}")"
                                     role="button"
                                     tabindex="0"
                                     @onclick="() => OpenDocumentAsync(doc.Slug)">
                                    <FluentStack Orientation="Orientation.Vertical" Class="lk-card-compact">
                                        <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">@FormatDocSlug(doc.Slug)</FluentLabel>
                                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@FormatTimestamp(doc.LastModified)</FluentLabel>
                                        @if (doc.Tags.Count > 0)
                                        {
                                            <FluentStack Orientation="Orientation.Horizontal" Style="gap: 4px; margin-top: 4px;" Wrap="true">
                                                @foreach (var tag in doc.Tags)
                                                {
                                                    <FluentBadge Appearance="Appearance.Neutral" Style="font-size: 10px;">@tag</FluentBadge>
                                                }
                                            </FluentStack>
                                        }
                                    </FluentStack>
                                </div>
                            }
                        </FluentStack>
                    }
                </FluentStack>
            </FluentCard>

            <!-- Right panel: Document Details -->
            <FluentCard aria-busy="@(_isPageLoading || _isUploading)" Class="lk-responsive-card">
                <FluentStack Orientation="Orientation.Vertical" Class="lk-card-content">
                    @if (!string.IsNullOrWhiteSpace(_pageError))
                    {
                        <FluentMessageBar Title="Document error" Intent="@MessageIntent.Error">
                            @_pageError
                        </FluentMessageBar>
                    }

                    @if (!string.IsNullOrWhiteSpace(_pageStatusMessage))
                    {
                        <FluentMessageBar Title="Document ingested" Intent="@MessageIntent.Success">
                            @_pageStatusMessage
                        </FluentMessageBar>
                    }

                    @if (_isPageLoading)
                    {
                        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Class="lk-loading" role="status">
                            <FluentProgressRing />
                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Loading document details…</FluentLabel>
                        </FluentStack>
                    }
                    else if (_selectedDoc is null)
                    {
                        <div class="lk-empty-state">
                            <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">Select a document</FluentLabel>
                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Choose a document from the left browser to view its details, tags, and extracted text index.</FluentLabel>
                        </div>
                    }
                    else
                    {
                        <FluentStack Orientation="Orientation.Vertical" Class="lk-section">
                            <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Class="lk-card-header">
                                <FluentStack Orientation="Orientation.Vertical" Class="lk-card-header-copy">
                                    <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">@FormatDocSlug(_selectedDoc.Slug)</FluentLabel>
                                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@GetSelectedPageSubtitle()</FluentLabel>
                                </FluentStack>
                                <FluentStack Orientation="Orientation.Horizontal" Class="lk-badge-group">
                                    @if (!string.IsNullOrWhiteSpace(_downloadUrl))
                                    {
                                        <FluentAnchor Appearance="Appearance.Accent" Href="@_downloadUrl" target="_blank">Download original</FluentAnchor>
                                    }
                                </FluentStack>
                            </FluentStack>

                            <div class="lk-split-panel" style="--lk-sidebar-width: 320px;">
