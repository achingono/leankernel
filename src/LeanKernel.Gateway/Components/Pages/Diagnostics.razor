@page "/diagnostics"
@using System.Globalization
@using LeanKernel.Abstractions.Enums
@inject DiagnosticsService DiagnosticsApi
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>LeanKernel Diagnostics</PageTitle>

<FluentStack Orientation="Orientation.Vertical" Class="lk-page">
    <PageHeader Title="Diagnostics explorer"
                Subtitle="Inspect the latest persisted context audit, budget usage, history shaping, and routing decisions for any session." />

    <FluentCard>
        <FluentStack Orientation="Orientation.Vertical" Class="lk-card-content">
            <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Bottom" Class="lk-form-group lk-form-row">
                <FluentTextField @bind-Value="_sessionId"
                                 Label="Session ID"
                                 Placeholder="Enter a session id"
                                 Disabled="@_isLoading"
                                 Style="flex: 1;" />
                <FluentButton Appearance="Appearance.Accent"
                              Id="diagnostics-load-button"
                              OnClick="LoadDiagnosticsAsync"
                              Disabled="@IsLoadDisabled"
                              Title="Search session"
                              AriaLabel="@(_isLoading ? "Searching session" : "Search session")"
                              aria-busy="@_isLoading">
                    @if (_isLoading)
                    {
                        <FluentProgressRing Style="width: 16px; height: 16px;" />
                    }
                    else
                    {
                        <FluentIcon Value="@(new Icons.Regular.Size16.Search())" />
                    }
                </FluentButton>
            </FluentStack>
            <FluentLabel Typo="Typography.Body" Color="Color.Neutral" Style="margin-top: var(--lk-space-xs);">
                The latest persisted turn is loaded unless a turn-specific diagnostics record is the only one available.
            </FluentLabel>
        </FluentStack>
    </FluentCard>

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <FluentMessageBar Title="Error" Intent="@MessageIntent.Error">
            @_errorMessage
        </FluentMessageBar>
    }

    @if (_warnings.Count > 0)
    {
        <FluentMessageBar Title="Some diagnostics are missing" Intent="@MessageIntent.Warning">
            <FluentStack Orientation="Orientation.Vertical" Class="lk-section-tight">
                @foreach (var warning in _warnings)
                {
                    <FluentLabel Typo="Typography.Body">• @warning</FluentLabel>
                }
            </FluentStack>
        </FluentMessageBar>
    }

    @if (_isLoading)
    {
        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Class="lk-loading">
            <FluentProgressRing />
            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Loading diagnostics…</FluentLabel>
        </FluentStack>
    }
    else if (_model is null)
    {
        <div class="lk-empty-state">
            <FluentLabel Typo="Typography.Subject">Load a session to inspect turn diagnostics</FluentLabel>
            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">
                Use a persisted session id to view context admission decisions, budget usage, history shaping, and model routing telemetry.
            </FluentLabel>
        </div>
    }
    else
    {
        <FluentStack Orientation="Orientation.Horizontal" Wrap="true" Style="gap: 1rem;">
            <FluentBadge Appearance="Appearance.Neutral">Session: @_model.SessionId</FluentBadge>
            <FluentBadge Appearance="Appearance.Neutral">Turn: @(_model.TurnId ?? "Latest available")</FluentBadge>
            <FluentBadge Appearance="Appearance.Neutral">Captured: @FormatTimestamp(_model.Timestamp)</FluentBadge>
            <FluentBadge Appearance="Appearance.Neutral">Entries: @_model.RawEntryCount</FluentBadge>
            <FluentBadge Appearance="Appearance.Neutral">Context candidates: @(_model.Context?.TotalCandidatesConsidered ?? 0)</FluentBadge>
            <FluentBadge Appearance="Appearance.Neutral">Tokens saved: @(_model.History?.TokensSaved ?? 0)</FluentBadge>
        </FluentStack>

        <FluentStack Orientation="Orientation.Vertical" Style="gap: 1rem;">
            @* Context Audit Card *@
            <FluentCard>
                <FluentStack Orientation="Orientation.Vertical" Class="lk-card-content">
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="justify-content: space-between; margin-bottom: 1rem;">
                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0;">
                            <FluentLabel Typo="Typography.Subject">Context audit</FluentLabel>
                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Review what the context gate admitted into the prompt versus what it excluded.</FluentLabel>
                        </FluentStack>
                        @if (_model.Context is not null)
                        {
                            <FluentStack Orientation="Orientation.Horizontal" Style="gap: 0.5rem;">
                                <FluentBadge Appearance="Appearance.Accent">@_model.Context.TotalAdmitted admitted</FluentBadge>
                                <FluentBadge Appearance="Appearance.Neutral">@_model.Context.TotalExcluded excluded</FluentBadge>
                            </FluentStack>
                        }
                    </FluentStack>

                    <div class="lk-split-panel" style="--lk-sidebar-width: 50%;">
                        <FluentStack Orientation="Orientation.Vertical" Style="flex: 1; gap: 0.5rem;">
                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Admitted</FluentLabel>
                            @if (AdmittedItems.Count == 0)
                            {
                                <FluentLabel Typo="Typography.Body" Color="Color.Neutral">No admitted context items were recorded for this turn.</FluentLabel>
                            }
                            else
                            {
                                @foreach (var item in AdmittedItems)
                                {
                                    <div class="lk-list-item lk-card-interactive">
                                        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="justify-content: space-between;">
                                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">@item.Key</FluentLabel>
                                            <FluentBadge Appearance="Appearance.Accent">@GetCategoryLabel(item.Source)</FluentBadge>
                                        </FluentStack>
                                        <FluentStack Orientation="Orientation.Horizontal" Style="gap: 1rem; margin-top: 0.25rem;">
                                            <FluentLabel Typo="Typography.Body">Score: @FormatScore(item.Score)</FluentLabel>
                                            <FluentLabel Typo="Typography.Body">Tokens: @item.TokenCount</FluentLabel>
                                        </FluentStack>
                                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@GetAuditReason(item)</FluentLabel>
                                    </div>
                                }
                            }
                        </FluentStack>

                        <FluentStack Orientation="Orientation.Vertical" Style="flex: 1; gap: 0.5rem;">
                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Excluded</FluentLabel>
                            @if (ExcludedItems.Count == 0)
                            {
                                <FluentLabel Typo="Typography.Body" Color="Color.Neutral">No exclusions were recorded for this turn.</FluentLabel>
                            }
                            else
                            {
                                @foreach (var item in ExcludedItems)
                                {
                                    <div class="lk-list-item lk-card-interactive">
                                        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="justify-content: space-between;">
                                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">@item.Key</FluentLabel>
                                            <FluentBadge Appearance="Appearance.Neutral">@GetCategoryLabel(item.Source)</FluentBadge>
                                        </FluentStack>
                                        <FluentStack Orientation="Orientation.Horizontal" Style="gap: 1rem; margin-top: 0.25rem;">
                                            <FluentLabel Typo="Typography.Body">Score: @FormatScore(item.Score)</FluentLabel>
                                            <FluentLabel Typo="Typography.Body">Tokens: @item.TokenCount</FluentLabel>
                                        </FluentStack>
                                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@GetAuditReason(item)</FluentLabel>
                                    </div>
                                }
                            }
                        </FluentStack>
                    </div>

                    @if (_model.Context?.RetrievalDiagnostics is { } retrieval)
                    {
                        <FluentStack Orientation="Orientation.Horizontal" Wrap="true" Style="gap: 0.5rem; margin-top: 1rem; padding-top: 0.75rem; border-top: 1px solid var(--neutral-stroke-rest);">
                            <FluentBadge Appearance="Appearance.Accent">Scope: @retrieval.EffectiveScope</FluentBadge>
                            <FluentBadge Appearance="Appearance.Neutral">@retrieval.TotalConsidered candidates</FluentBadge>
                            <FluentBadge Appearance="Appearance.Neutral">@retrieval.TotalAdmitted admitted</FluentBadge>
                            <FluentBadge Appearance="Appearance.Neutral">@retrieval.TotalExcludedByScope scope-filtered</FluentBadge>
                            <FluentBadge Appearance="Appearance.Neutral">@retrieval.TotalExcludedByScore score-filtered</FluentBadge>
                        </FluentStack>
                    }
                </FluentStack>
            </FluentCard>

            @* Budget Usage Card *@
            <FluentCard>
                <FluentStack Orientation="Orientation.Vertical" Class="lk-card-content">
                    <FluentLabel Typo="Typography.Subject">Budget usage</FluentLabel>
                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral" Style="margin-bottom: 1rem;">Compare token usage against each context budget and the reserved response headroom.</FluentLabel>

                    @if (BudgetMetrics.Count == 0)
                    {
                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">No budget telemetry is available for this turn.</FluentLabel>
                    }
                    else
                    {
                        @foreach (var metric in BudgetMetrics)
                        {
                            <div class="@($"lk-budget-metric lk-budget-{GetBudgetModifier(metric)}")" role="group" aria-label="@GetBudgetTooltip(metric)">
                                <FluentStack Orientation="Orientation.Vertical" Class="lk-card-compact">
                                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="justify-content: space-between; gap: var(--lk-space-xs);">
                                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0;">
                                            <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: var(--lk-space-xs);">
                                                <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">@metric.Label</FluentLabel>
                                                @if (metric.IsOverBudget)
                                                {
                                                    <FluentBadge Appearance="Appearance.Lightweight">Over budget</FluentBadge>
                                                }
                                            </FluentStack>
                                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@metric.Description</FluentLabel>
                                        </FluentStack>
                                        <FluentLabel Typo="Typography.Body">@metric.Used / @metric.Allocated (@metric.UtilizationLabel)</FluentLabel>
                                    </FluentStack>
                                    <FluentProgress Class="@($"lk-budget-progress{(metric.IsOverBudget ? " lk-budget-progress-over" : string.Empty)}")"
                                                    Min="0"
                                                    Max="@metric.Allocated"
                                                    Value="@metric.Used"
                                                    Style="width: 100%;" />
                                    @if (metric.IsOverBudget)
                                    {
                                        <FluentLabel Typo="Typography.Body" Color="Color.Error">Over budget by @(metric.Used - metric.Allocated) tokens.</FluentLabel>
                                    }
                                </FluentStack>
                            </div>
                        }
                    }
                </FluentStack>
            </FluentCard>

            @* History Shaping Card *@
            <FluentCard>
                <FluentStack Orientation="Orientation.Vertical" Class="lk-card-content">
                    <FluentLabel Typo="Typography.Subject">History shaping</FluentLabel>
                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral" Style="margin-bottom: 1rem;">See how earlier turns were kept verbatim, compacted, summarized, or dropped to fit budget.</FluentLabel>

                    @if (_model.History is null)
                    {
                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">No history shaping telemetry is available for this turn.</FluentLabel>
                    }
                    else
                    {
                        <FluentStack Orientation="Orientation.Horizontal" Wrap="true" Style="gap: 0.5rem; margin-bottom: 1rem;">
                            <FluentBadge Appearance="Appearance.Accent">@_model.History.VerbatimTurns verbatim</FluentBadge>
                            <FluentBadge Appearance="Appearance.Neutral">@_model.History.CompactedTurns compacted</FluentBadge>
                            <FluentBadge Appearance="Appearance.Neutral">@_model.History.SummarizedTurns summarized</FluentBadge>
                            <FluentBadge Appearance="Appearance.Lightweight">@_model.History.DroppedTurns dropped</FluentBadge>
                            <FluentBadge Appearance="Appearance.Neutral">Saved @_model.History.TokensSaved tokens</FluentBadge>
                        </FluentStack>

                        @if (HistoryTimeline.Count == 0)
                        {
                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">History shaping counts were recorded, but no timeline markers were persisted.</FluentLabel>
                        }
                        else
                        {
                            @foreach (var item in HistoryTimeline)
                            {
                                <div class="lk-timeline-item">
                                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 0.5rem;">
                                        <FluentBadge Appearance="Appearance.Accent">@item.Index.ToString("00")</FluentBadge>
                                        <FluentStack Orientation="Orientation.Vertical" Style="flex: 1; gap: 0;">
                                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">@item.Label</FluentLabel>
                                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@item.Summary</FluentLabel>
                                        </FluentStack>
                                        <FluentLabel Typo="Typography.Body">@item.CompressionLabel</FluentLabel>
                                    </FluentStack>
                                    <FluentProgress Min="0" Max="100" Value="@((int)item.CompressionPercent)" Style="width: 100%; margin-top: 0.25rem;" />
                                </div>
                            }
                        }
                    }
                </FluentStack>
            </FluentCard>

            @* Routing Decisions Card *@
            <FluentCard>
                <FluentStack Orientation="Orientation.Vertical" Class="lk-card-content">
                    <FluentLabel Typo="Typography.Subject">Routing decisions</FluentLabel>
                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral" Style="margin-bottom: 1rem;">Inspect the selected model, complexity score, alternatives considered, and quality-gate result.</FluentLabel>

                    @if (_model.RoutingDecision is null && _model.QualityGate is null && _model.ShadowRouting is null)
                    {
                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">No model-routing diagnostics were recorded for this turn.</FluentLabel>
                    }
                    else
                    {
                        @if (_model.RoutingDecision is { } routing)
                        {
                            <FluentStack Orientation="Orientation.Horizontal" Wrap="true" Style="gap: 1rem; margin-bottom: 1rem;">
                                <FluentStack Orientation="Orientation.Vertical" Style="gap: 0;">
                                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Model</FluentLabel>
                                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">@routing.SelectedModel</FluentLabel>
                                </FluentStack>
                                <FluentStack Orientation="Orientation.Vertical" Style="gap: 0;">
                                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Tier</FluentLabel>
                                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">@routing.SelectedTier</FluentLabel>
                                </FluentStack>
                                <FluentStack Orientation="Orientation.Vertical" Style="gap: 0;">
                                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Complexity</FluentLabel>
                                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">@routing.ComplexityScore.ToString("0.00", CultureInfo.InvariantCulture)</FluentLabel>
                                </FluentStack>
                            </FluentStack>

                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Reason</FluentLabel>
                            <FluentLabel Typo="Typography.Body">@routing.Reason</FluentLabel>

                            <div class="lk-split-panel" style="--lk-sidebar-width: 50%; margin-top: 1rem;">
                                <FluentStack Orientation="Orientation.Vertical" Style="flex: 1; gap: 0.25rem;">
                                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Decision factors</FluentLabel>
                                    @if (routing.Factors.Count == 0)
                                    {
                                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">No routing factors were persisted.</FluentLabel>
                                    }
                                    else
                                    {
                                        <ul style="margin: 0; padding-left: 1.25rem;">
                                            @foreach (var factor in routing.Factors)
                                            {
                                                <li>@factor</li>
                                            }
                                        </ul>
                                    }
                                </FluentStack>

                                <FluentStack Orientation="Orientation.Vertical" Style="flex: 1; gap: 0.25rem;">
                                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Alternatives considered</FluentLabel>
                                    @if (RoutingAlternatives.Count == 0)
                                    {
                                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">No alternative routing paths were recorded.</FluentLabel>
                                    }
                                    else
                                    {
                                        @foreach (var alternative in RoutingAlternatives)
                                        {
                                            <FluentStack Orientation="Orientation.Vertical" Style="gap: 0;">
                                                <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">@alternative.Title</FluentLabel>
                                                <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@alternative.Detail</FluentLabel>
                                            </FluentStack>
                                        }
                                    }
                                </FluentStack>
                            </div>
                        }

                        @if (_model.QualityGate is { } qualityGate)
                        {
                            <div class="lk-inline-panel">
                                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="justify-content: space-between; margin-bottom: 0.5rem;">
                                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Quality gate</FluentLabel>
                                    <FluentBadge Appearance="@(qualityGate.Passed ? Appearance.Accent : Appearance.Lightweight)">@GetQualityLabel(qualityGate)</FluentBadge>
                                </FluentStack>
                                <FluentStack Orientation="Orientation.Horizontal" Style="gap: 1rem; margin-bottom: 0.5rem;">
                                    <FluentLabel Typo="Typography.Body">Score: @qualityGate.OverallScore.ToString("0.00", CultureInfo.InvariantCulture)</FluentLabel>
                                    <FluentLabel Typo="Typography.Body">Status: @(qualityGate.Passed ? "Passed" : "Needs escalation")</FluentLabel>
                                </FluentStack>
                                <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@(qualityGate.FailureReason ?? "The response cleared all configured checks.")</FluentLabel>

                                @if (qualityGate.Checks.Count > 0)
                                {
                                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem; margin-top: 0.5rem;">
                                        @foreach (var check in qualityGate.Checks)
                                        {
                                            <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="justify-content: space-between;">
                                                <FluentStack Orientation="Orientation.Horizontal" Style="gap: 0.5rem;">
                                                    <FluentBadge Appearance="@(check.Passed ? Appearance.Accent : Appearance.Lightweight)">@(check.Passed ? "✓" : "✗")</FluentBadge>
                                                    <FluentLabel Typo="Typography.Body">@check.CheckName</FluentLabel>
                                                    @if (!string.IsNullOrWhiteSpace(check.Details))
                                                    {
                                                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@check.Details</FluentLabel>
                                                    }
                                                </FluentStack>
                                                <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">@check.Score.ToString("0.00", CultureInfo.InvariantCulture)</FluentLabel>
                                            </FluentStack>
                                        }
                                    </FluentStack>
                                }
                            </div>
                        }

                        @if (_model.ShadowRouting is { } shadow)
                        {
                            <div class="lk-inline-panel">
                                <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold" Style="margin-bottom: 0.5rem;">Shadow comparison</FluentLabel>
                                <FluentStack Orientation="Orientation.Horizontal" Wrap="true" Style="gap: 1rem;">
                                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 0;">
                                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Primary model</FluentLabel>
                                        <FluentLabel Typo="Typography.Body">@shadow.PrimaryModel</FluentLabel>
                                    </FluentStack>
                                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 0;">
                                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Shadow model</FluentLabel>
                                        <FluentLabel Typo="Typography.Body">@shadow.ShadowModel</FluentLabel>
                                    </FluentStack>
                                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 0;">
                                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Primary tokens</FluentLabel>
                                        <FluentLabel Typo="Typography.Body">@shadow.PrimaryTokensUsed</FluentLabel>
                                    </FluentStack>
                                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 0;">
                                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Shadow tokens</FluentLabel>
                                        <FluentLabel Typo="Typography.Body">@shadow.ShadowTokensUsed</FluentLabel>
                                    </FluentStack>
                                </FluentStack>

                                @if (shadow.Comparison is { } comparison)
                                {
                                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral" Style="margin-top: 0.5rem;">
                                        Length ratio: @comparison.LengthRatio.ToString("0.00", CultureInfo.InvariantCulture) ·
                                        Primary refusal: @(comparison.PrimaryRefusal ? "Yes" : "No") ·
                                        Shadow refusal: @(comparison.ShadowRefusal ? "Yes" : "No")
                                    </FluentLabel>

                                    @if (!string.IsNullOrWhiteSpace(comparison.Notes))
                                    {
                                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@comparison.Notes</FluentLabel>
                                    }
                                }
                            </div>
                        }
                    }
                </FluentStack>
            </FluentCard>
        </FluentStack>
    }
</FluentStack>

@code {
    private CancellationTokenSource _loadCts = new();
    private string _sessionId = string.Empty;
    private bool _isLoading;
    private string? _errorMessage;
    private DiagnosticsService.DiagnosticsExplorerData? _model;
    private IReadOnlyList<string> _warnings = [];

    private bool IsLoadDisabled => _isLoading || string.IsNullOrWhiteSpace(_sessionId);
    private int TotalBudgetTokens => _model?.Budget?.TotalBudgetTokens ?? 0;
    private IReadOnlyList<ContextAdmissionRecord> AdmittedItems => _model?.Context?.Admissions
        .Where(item => item.Admitted)
        .OrderByDescending(item => item.Score)
        .ToList()
        ?? [];
    private IReadOnlyList<ContextAdmissionRecord> ExcludedItems => _model?.Context?.Admissions
        .Where(item => !item.Admitted)
        .OrderByDescending(item => item.Score)
        .ToList()
        ?? [];
    private IReadOnlyList<BudgetMetric> BudgetMetrics => BuildBudgetMetrics(_model?.Budget);
    private IReadOnlyList<HistoryTimelineEntry> HistoryTimeline => BuildHistoryTimeline(_model?.History);
    private IReadOnlyList<RoutingAlternative> RoutingAlternatives => BuildRoutingAlternatives(_model);

    private async Task LoadDiagnosticsAsync()
    {
        var sessionId = _sessionId.Trim();
        if (string.IsNullOrWhiteSpace(sessionId))
        {
            return;
        }

        var previousCts = _loadCts;
        await previousCts.CancelAsync();
        previousCts.Dispose();

        var loadCts = new CancellationTokenSource();
        _loadCts = loadCts;
        _isLoading = true;
        _errorMessage = null;
        _warnings = [];
        _model = null;

        try
        {
            var result = await DiagnosticsApi.LoadAsync(sessionId, loadCts.Token);
            _model = result.Data;
            _warnings = result.Data?.Warnings ?? [];
            _errorMessage = result.ErrorMessage;
        }
        catch (OperationCanceledException) when (loadCts.IsCancellationRequested)
        {
        }
        finally
        {
            if (ReferenceEquals(_loadCts, loadCts))
            {
                _isLoading = false;
            }
        }
    }

    private static string FormatTimestamp(DateTimeOffset? timestamp)
        => timestamp is null ? "Not recorded" : timestamp.Value.LocalDateTime.ToString("g", CultureInfo.CurrentCulture);

    private static string FormatScore(double score) => score.ToString("0.00", CultureInfo.InvariantCulture);

    private static string GetAuditReason(ContextAdmissionRecord item)
        => item.Admitted
            ? $"Included from {GetCategoryLabel(item.Source).ToLowerInvariant()} context after scoring and budget checks."
            : item.ExclusionReason ?? "Excluded during context admission.";

    private static string GetCategoryModifier(string source)
    {
        var normalized = source.Trim().ToLowerInvariant();
        return normalized switch
        {
            var value when value.Contains("system", StringComparison.Ordinal) || value.Contains("prompt", StringComparison.Ordinal) => "system",
            var value when value.Contains("wiki", StringComparison.Ordinal) || value.Contains("knowledge", StringComparison.Ordinal) || value.Contains("fact", StringComparison.Ordinal) => "wiki",
            var value when value.Contains("history", StringComparison.Ordinal) || value.Contains("conversation", StringComparison.Ordinal) || value.Contains("turn", StringComparison.Ordinal) => "history",
            var value when value.Contains("retrieval", StringComparison.Ordinal) || value.Contains("gbrain", StringComparison.Ordinal) || value.Contains("search", StringComparison.Ordinal) => "retrieval",
            var value when value.Contains("tool", StringComparison.Ordinal) => "tools",
            _ => "default"
        };
    }

    private static string GetCategoryLabel(string source)
        => GetCategoryModifier(source) switch
        {
            "system" => "System",
            "wiki" => "Wiki",
            "history" => "History",
            "retrieval" => "Retrieval",
            "tools" => "Tools",
            _ => string.IsNullOrWhiteSpace(source) ? "Unknown" : source
        };

    private static IReadOnlyList<BudgetMetric> BuildBudgetMetrics(BudgetDiagnosticsResponse? budget)
    {
        if (budget is null)
        {
            return [];
        }

        var headroomTokens = Math.Max(budget.TotalBudgetTokens - budget.UsableBudgetTokens, 0);

        return
        [
            new BudgetMetric("System", budget.SystemPrompt.Used, budget.SystemPrompt.Allocated, "system", "System prompt instructions."),
            new BudgetMetric("Wiki", budget.WikiFacts.Used, budget.WikiFacts.Allocated, "wiki", "Persisted wiki facts admitted into the prompt."),
            new BudgetMetric("History", budget.Conversation.Used, budget.Conversation.Allocated, "history", "Conversation history retained after shaping."),
            new BudgetMetric("Retrieval", budget.Retrieval.Used, budget.Retrieval.Allocated, "retrieval", "Retrieved documents and evidence."),
            new BudgetMetric("Tools", budget.Tools.Used, budget.Tools.Allocated, "tools", "Tool metadata exposed for the turn."),
            new BudgetMetric("Response headroom", headroomTokens, headroomTokens, "headroom", $"Reserved output budget ({budget.ResponseHeadroomRatio:P0}).", true)
        ];
    }

    private static IReadOnlyList<HistoryTimelineEntry> BuildHistoryTimeline(HistoryDiagnosticsResponse? history)
    {
        if (history is null)
        {
            return [];
        }

        var entries = new List<HistoryTimelineEntry>();

        if (history.VerbatimTurns > 0)
        {
            entries.Add(new HistoryTimelineEntry(0, "Verbatim turns", "verbatim", $"{history.VerbatimTurns} recent {Pluralize("turn", history.VerbatimTurns)} kept in full.", 100, "100% retained"));
        }

        if (history.Shaping?.Markers.Count > 0)
        {
            foreach (var marker in history.Shaping.Markers.OrderBy(marker => marker.CompactedAt))
            {
                var modifier = string.Equals(marker.MarkerType, "summarized", StringComparison.OrdinalIgnoreCase)
                    ? "summarized"
                    : "compacted";
                var ratio = marker.OriginalTokenCount > 0
                    ? (double)marker.CompactedTokenCount / marker.OriginalTokenCount * 100
                    : 0;
                var actor = string.IsNullOrWhiteSpace(marker.CompactedBy)
                    ? string.Empty
                    : $" by {marker.CompactedBy}";

                entries.Add(new HistoryTimelineEntry(
                    0,
                    modifier == "summarized" ? "Summarized block" : "Compacted block",
                    modifier,
                    $"{marker.OriginalTurnCount} {Pluralize("turn", marker.OriginalTurnCount)} compressed from {marker.OriginalTokenCount} to {marker.CompactedTokenCount} tokens{actor}.",
                    ratio,
                    $"{marker.CompactedTokenCount}/{marker.OriginalTokenCount} tokens"));
            }
        }
        else
        {
            if (history.CompactedTurns > 0)
            {
                entries.Add(new HistoryTimelineEntry(0, "Compacted turns", "compacted", $"{history.CompactedTurns} {Pluralize("turn", history.CompactedTurns)} compacted into shorter history slices.", 60, "Compaction recorded"));
            }

            if (history.SummarizedTurns > 0)
            {
                entries.Add(new HistoryTimelineEntry(0, "Summarized turns", "summarized", $"{history.SummarizedTurns} {Pluralize("turn", history.SummarizedTurns)} summarized into higher-level notes.", 35, "Summary recorded"));
            }
        }

        if (history.DroppedTurns > 0)
        {
            entries.Add(new HistoryTimelineEntry(0, "Dropped turns", "dropped", $"{history.DroppedTurns} oldest {Pluralize("turn", history.DroppedTurns)} removed from prompt assembly.", 0, "0% retained"));
        }

        return entries
            .Select((item, index) => item with { Index = index + 1 })
            .ToList();
    }

    private static IReadOnlyList<RoutingAlternative> BuildRoutingAlternatives(DiagnosticsService.DiagnosticsExplorerData? model)
    {
        if (model is null)
        {
            return [];
        }

        var alternatives = new List<RoutingAlternative>();

        if (model.RoutingDecision?.EscalatedFrom is { } escalatedFrom)
        {
            alternatives.Add(new RoutingAlternative($"Escalated from {escalatedFrom}", "A lower-cost tier was attempted before the selected model tier."));
        }

        if (model.ShadowRouting is { } shadow)
        {
            var comparisonNotes = shadow.Comparison?.Notes;
            var detail = string.IsNullOrWhiteSpace(comparisonNotes)
                ? $"Shadow model {shadow.ShadowModel} ran in parallel for comparison."
                : comparisonNotes;
            alternatives.Add(new RoutingAlternative($"Shadow model: {shadow.ShadowModel}", detail));
        }

        return alternatives;
    }

    private static string GetBudgetModifier(BudgetMetric metric)
        => metric.IsOverBudget ? "over" : metric.Modifier;

    private static string GetBudgetTooltip(BudgetMetric metric)
        => $"{metric.Label}: {metric.Used} of {metric.Allocated} tokens ({metric.UtilizationLabel})";

    private static string GetQualityModifier(QualityGateResult qualityGate)
        => qualityGate.Passed
            ? "quality-pass"
            : qualityGate.Outcome == QualityOutcome.Escalated
                ? "quality-warn"
                : "quality-fail";

    private static string GetQualityLabel(QualityGateResult qualityGate)
        => qualityGate.Outcome switch
        {
            QualityOutcome.Passed => "Passed",
            QualityOutcome.Escalated => "Escalated",
            QualityOutcome.FailedEmpty => "Failed: empty",
            QualityOutcome.FailedTooShort => "Failed: too short",
            QualityOutcome.FailedLowCoverage => "Failed: low coverage",
            QualityOutcome.FailedRefusal => "Failed: refusal",
            _ => qualityGate.Outcome.ToString()
        };

    private static string GetSegmentStyle(int value, int total)
    {
        if (total <= 0 || value <= 0)
        {
            return "width: 0%;";
        }

        var percent = (double)value / total * 100;
        return GetWidthStyle(percent);
    }

    private static string GetWidthStyle(double percent)
        => $"width: {Math.Clamp(percent, 0, 100).ToString("0.##", CultureInfo.InvariantCulture)}%;";

    private static string Pluralize(string noun, int count) => count == 1 ? noun : $"{noun}s";

    public async ValueTask DisposeAsync()
    {
        if (!_loadCts.IsCancellationRequested)
        {
            await _loadCts.CancelAsync();
        }

        _loadCts.Dispose();
    }

    private sealed record BudgetMetric(string Label, int Used, int Allocated, string Modifier, string Description, bool IsReserved = false)
    {
        public bool IsOverBudget => !IsReserved && Allocated > 0 && Used > Allocated;
        public double UtilizationPercent => Allocated > 0 ? (double)Used / Allocated * 100 : 0;
        public double WidthPercent => Math.Clamp(UtilizationPercent, 0, 100);
        public string UtilizationLabel => IsReserved ? "Reserved" : $"{UtilizationPercent.ToString("0.#", CultureInfo.InvariantCulture)}%";
    }

    private sealed record HistoryTimelineEntry(int Index, string Label, string Modifier, string Summary, double CompressionPercent, string CompressionLabel);

    private sealed record RoutingAlternative(string Title, string Detail);
}
