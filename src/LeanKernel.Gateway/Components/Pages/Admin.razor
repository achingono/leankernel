@page "/admin"
@using System.Globalization
@implements IAsyncDisposable
@inject AdminService AdminService
@rendermode InteractiveServer

<PageTitle>LeanKernel Admin</PageTitle>

<FluentStack Orientation="Orientation.Vertical" Class="lk-page lk-page-wide">
    <PageHeader Title="Admin Console" Subtitle="Govern provider health, model routing, tool access, spend, and scheduled jobs from one runtime surface.">
        <Actions>
            <FluentStack Orientation="Orientation.Vertical" Style="align-items: flex-end; gap: var(--lk-space-xs);">
                <FluentBadge Appearance="Appearance.Accent">Live</FluentBadge>
                @if (_dashboard is not null)
                {
                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">
                        <time datetime="@FormatTimestampAttribute(_dashboard.GeneratedAt)">Updated @FormatDateTime(_dashboard.GeneratedAt)</time>
                    </FluentLabel>
                }
            </FluentStack>
        </Actions>
    </PageHeader>

    <FluentCard>
        <FluentStack Orientation="Orientation.Vertical" Class="lk-card-content">
            <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Wrap="true" Class="lk-card-header">
                <FluentStack Orientation="Orientation.Vertical" Class="lk-card-header-copy">
                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Runtime governance</FluentLabel>
                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@(_statusMessage ?? "Tool governance and health data are sourced from the live runtime. Spend tracking uses projected estimates until the accounting API is available.")</FluentLabel>
                </FluentStack>
                <FluentBadge Appearance="Appearance.Neutral">Session-scoped toggles</FluentBadge>
            </FluentStack>
        </FluentStack>
    </FluentCard>

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <FluentMessageBar Title="Error" Intent="@MessageIntent.Error">
            @_errorMessage
        </FluentMessageBar>
    }

    <section aria-labelledby="admin-health-heading" aria-busy="@(_isLoading || _isRefreshingHealth)">
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical" Class="lk-card-content">
                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Wrap="true" Class="lk-card-header">
                    <FluentStack Orientation="Orientation.Vertical" Class="lk-card-header-copy">
                        <FluentLabel Id="admin-health-heading" Typo="Typography.Subject" Weight="FontWeight.Bold">System health overview</FluentLabel>
                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Provider reachability, routing readiness, and the latest heartbeat checks.</FluentLabel>
                    </FluentStack>
                    <FluentButton Appearance="Appearance.Outline"
                                  Id="admin-refresh-health"
                                  OnClick="RefreshProviderHealthAsync"
                                  Disabled="@(_isLoading || _isRefreshingHealth)"
                                  Title="Refresh provider health checks"
                                  AriaLabel="Refresh provider health checks">
                        <FluentIcon Value="@(new Icons.Regular.Size16.ArrowClockwise())" />
                    </FluentButton>
                </FluentStack>

                @if (_isLoading || _dashboard is null)
                {
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Class="lk-loading">
                        <FluentProgressRing />
                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Loading provider health…</FluentLabel>
                    </FluentStack>
                }
                else
                {
                    <div class="lk-auto-grid" style="--lk-grid-min: 260px;">
                        @foreach (var provider in _dashboard.ProviderHealth)
                        {
                            <div class="lk-panel lk-responsive-card">
                                <FluentStack Orientation="Orientation.Vertical" Class="lk-section">
                                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Wrap="true" Class="lk-card-header">
                                        <FluentStack Orientation="Orientation.Vertical" Class="lk-card-header-copy">
                                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">@provider.Name</FluentLabel>
                                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@provider.Summary</FluentLabel>
                                        </FluentStack>
                                        <FluentBadge Appearance="@(provider.Status == AdminProviderStatus.Healthy ? Appearance.Accent : provider.Status == AdminProviderStatus.Degraded ? Appearance.Neutral : Appearance.Lightweight)">
                                            @GetProviderStatusLabel(provider.Status)
                                        </FluentBadge>
                                    </FluentStack>
                                    <FluentStack Orientation="Orientation.Horizontal" Wrap="true" Class="lk-data-row">
                                        <FluentStack Orientation="Orientation.Vertical" Class="lk-data-pair" Style="min-width: 90px;">
                                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Latency</FluentLabel>
                                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">@provider.LatencyMs ms</FluentLabel>
                                        </FluentStack>
                                        <FluentStack Orientation="Orientation.Vertical" Class="lk-data-pair" Style="min-width: 160px;">
                                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Last check</FluentLabel>
                                            <FluentLabel Typo="Typography.Body">
                                                <time datetime="@FormatTimestampAttribute(provider.LastCheckedAt)">@FormatDateTime(provider.LastCheckedAt)</time>
                                            </FluentLabel>
                                        </FluentStack>
                                    </FluentStack>
                                </FluentStack>
                            </div>
                        }
                    </div>
                }
            </FluentStack>
        </FluentCard>
    </section>

    <section aria-labelledby="admin-routing-heading" aria-busy="@_isLoading">
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical" Class="lk-card-content">
                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Wrap="true" Class="lk-card-header">
                    <FluentStack Orientation="Orientation.Vertical" Class="lk-card-header-copy">
                        <FluentLabel Id="admin-routing-heading" Typo="Typography.Subject" Weight="FontWeight.Bold">Model routing configuration</FluentLabel>
                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Current tier-to-model mapping prepared for future inline editing.</FluentLabel>
                    </FluentStack>
                    <FluentBadge Appearance="Appearance.Neutral">Read only</FluentBadge>
                </FluentStack>

                @if (_isLoading || _dashboard is null)
                {
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Class="lk-loading">
                        <FluentProgressRing />
                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Loading routing configuration…</FluentLabel>
                    </FluentStack>
                }
                else
                {
                    <div class="lk-scroll-region" style="--lk-table-min-width: 760px;">
                        <FluentDataGrid Items="@(_dashboard.RoutingRules.AsQueryable())" TGridItem="AdminRoutingRule" Style="width: 100%;" GridTemplateColumns="1fr 2fr 2fr 1fr 1fr">
                            <PropertyColumn Property="@(rule => rule.Tier)" Title="Tier" Sortable="true" />
                            <TemplateColumn Title="Model">
                                <FluentBadge Appearance="Appearance.Neutral">@context.Model</FluentBadge>
                            </TemplateColumn>
                            <TemplateColumn Title="Fallback model">
                                <FluentBadge Appearance="Appearance.Neutral">@context.FallbackModel</FluentBadge>
                            </TemplateColumn>
                            <PropertyColumn Property="@(rule => rule.MaxTokens)" Title="Max tokens" Sortable="true" Format="N0" Align="Align.End" />
                            <TemplateColumn Title="Cost / 1k" Align="Align.End">
                                @FormatCurrency(context.CostPer1K)
                            </TemplateColumn>
                        </FluentDataGrid>
                    </div>
                }
            </FluentStack>
        </FluentCard>
    </section>

    <section aria-labelledby="admin-tools-heading" aria-busy="@(_isLoading || !string.IsNullOrWhiteSpace(_updatingToolName))">
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical" Class="lk-card-content">
                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Bottom" Wrap="true" Class="lk-card-header">
                    <FluentStack Orientation="Orientation.Vertical" Class="lk-card-header-copy">
                        <FluentLabel Id="admin-tools-heading" Typo="Typography.Subject" Weight="FontWeight.Bold">Tool governance</FluentLabel>
                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Filter the current registry and preview enablement changes before the admin API ships.</FluentLabel>
                    </FluentStack>
                    <FluentStack Orientation="Orientation.Vertical" Class="lk-form-field" Style="min-width: 220px;">
                        <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Category</FluentLabel>
                        <FluentSelect Id="admin-tool-filter"
                                      @bind-Value="_selectedToolCategory"
                                      TOption="string"
                                      AriaLabel="Filter tool governance table by category">
                            <FluentOption Value="@AllCategoriesValue">All categories</FluentOption>
                            @foreach (var category in ToolCategories)
                            {
                                <FluentOption Value="@category">@category</FluentOption>
                            }
                        </FluentSelect>
                    </FluentStack>
                </FluentStack>

                @if (_isLoading || _dashboard is null)
                {
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Class="lk-loading">
                        <FluentProgressRing />
                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Loading tool governance…</FluentLabel>
                    </FluentStack>
                }
                else
                {
                    <div class="lk-scroll-region" style="--lk-table-min-width: 920px;">
                        <FluentDataGrid Items="@(FilteredTools.AsQueryable())" TGridItem="AdminToolGovernanceItem" Style="width: 100%;" GridTemplateColumns="2fr 1fr auto 1fr 3fr">
                            <PropertyColumn Property="@(tool => tool.Name)" Title="Name" Sortable="true" />
                            <PropertyColumn Property="@(tool => tool.Category)" Title="Category" Sortable="true" />
                            <TemplateColumn Title="Enabled">
                                <FluentSwitch Value="@context.Enabled"
                                              ValueChanged="@(async enabled => await OnToolToggleChangedAsync(context.Name, new ChangeEventArgs { Value = enabled }))"
                                              Disabled="@(_isLoading || !string.IsNullOrWhiteSpace(_updatingToolName))"
                                              AriaLabel="@GetToggleAriaLabel(context)" />
                            </TemplateColumn>
                            <PropertyColumn Property="@(tool => tool.VisibilityScope)" Title="Visibility scope" Sortable="true" />
                            <TemplateColumn Title="Description">
                                <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@context.Description</FluentLabel>
                            </TemplateColumn>
                        </FluentDataGrid>
                    </div>
                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Tool toggles update in-memory governance state for the current session.</FluentLabel>
                }
            </FluentStack>
        </FluentCard>
    </section>

    <section aria-labelledby="admin-spend-heading" aria-busy="@_isLoading">
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical" Class="lk-card-content">
                <FluentStack Orientation="Orientation.Vertical" Class="lk-card-header-copy">
                    <FluentLabel Id="admin-spend-heading" Typo="Typography.Subject" Weight="FontWeight.Bold">Spend tracking dashboard</FluentLabel>
                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Daily spend trend, current rollups, and budget posture for model usage.</FluentLabel>
                </FluentStack>

                @if (_isLoading || _dashboard is null)
                {
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Class="lk-loading">
                        <FluentProgressRing />
                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Loading spend dashboard…</FluentLabel>
                    </FluentStack>
                }
                else
                {
                    <div class="lk-auto-grid" style="--lk-grid-min: 180px;">
                        <FluentCard Class="lk-stat-card">
                            <FluentStack Orientation="Orientation.Vertical" Class="lk-stat-card-content">
                                <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Today</FluentLabel>
                                <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">@FormatCurrency(_dashboard.Spend.TodaySpend)</FluentLabel>
                            </FluentStack>
                        </FluentCard>
                        <FluentCard Class="lk-stat-card">
                            <FluentStack Orientation="Orientation.Vertical" Class="lk-stat-card-content">
                                <FluentLabel Typo="Typography.Body" Color="Color.Neutral">This week</FluentLabel>
                                <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">@FormatCurrency(_dashboard.Spend.WeekSpend)</FluentLabel>
                            </FluentStack>
                        </FluentCard>
                        <FluentCard Class="lk-stat-card">
                            <FluentStack Orientation="Orientation.Vertical" Class="lk-stat-card-content">
                                <FluentLabel Typo="Typography.Body" Color="Color.Neutral">This month</FluentLabel>
                                <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">@FormatCurrency(_dashboard.Spend.MonthSpend)</FluentLabel>
                            </FluentStack>
                        </FluentCard>
                        <FluentCard Class="lk-stat-card">
                            <FluentStack Orientation="Orientation.Vertical" Class="lk-stat-card-content">
                                <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Budget status</FluentLabel>
                                <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">@GetBudgetSummary()</FluentLabel>
                            </FluentStack>
                        </FluentCard>
                    </div>

                    <div class="lk-split-panel" style="--lk-sidebar-width: 320px;">
                        <div class="lk-panel lk-responsive-card">
                            <FluentStack Orientation="Orientation.Vertical" Style="gap: 1rem; height: 100%;">
                                <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem;">
                                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Last 7 days</FluentLabel>
                                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Each bar represents total model spend for the day.</FluentLabel>
                                </FluentStack>

                                <div role="img" aria-label="@GetSpendChartSummary()" style="display: flex; align-items: end; gap: 1.25rem; flex-wrap: wrap; min-height: 220px; justify-content: space-around;">
                                    @foreach (var point in _dashboard.Spend.DailySpend)
                                    {
                                        var barId = $"bar-{point.Label.Replace(" ", "-").ToLowerInvariant()}";
                                        <FluentStack Orientation="Orientation.Vertical" VerticalAlignment="VerticalAlignment.Center" Style="gap: 0.35rem; align-items: center; min-width: 70px;">
                                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">@FormatCurrency(point.Amount)</FluentLabel>
                                            <button id="@barId"
                                                    type="button"
                                                    class="lk-spend-bar-container"
                                                    aria-label="@($"{point.Label} spend {FormatCurrency(point.Amount)}{(point.IsToday ? ", today" : string.Empty)}")"
                                                    title="@($"{point.Label}: {FormatCurrency(point.Amount)}")"
                                                    style="display: flex; align-items: end; width: 32px; height: 160px; background: var(--neutral-layer-3); border-radius: 999px; overflow: hidden;">
                                                <span class="lk-spend-bar-inner" style="@($"{GetSpendBarStyle(point)} width: 100%; display: block; background: {(point.IsToday ? "var(--accent-fill-rest)" : "var(--neutral-fill-rest)")};")"></span>
                                            </button>
                                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@point.Label</FluentLabel>
                                        </FluentStack>
                                        <FluentTooltip Anchor="@barId" Position="TooltipPosition.Top" Delay="150">
                                            @point.Label spend: @FormatCurrency(point.Amount) @(point.IsToday ? " (Today)" : "")
                                        </FluentTooltip>
                                    }
                                </div>
                            </FluentStack>
                        </div>

                        <div class="lk-panel lk-responsive-card">
                            <FluentStack Orientation="Orientation.Vertical" Style="gap: 1rem; height: 100%;">
                                <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem;">
                                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Budget limit</FluentLabel>
                                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@GetBudgetCaption()</FluentLabel>
                                </FluentStack>

                                @if (_dashboard.Spend.MonthlyBudgetLimit is decimal monthlyBudgetLimit)
                                {
                                    <FluentProgress Min="0" Max="100" Value="@((int)GetBudgetUsagePercentage())" Style="display: block; visibility: visible; width: 100%; min-width: 160px; min-height: 4px;" />
                                    <FluentLabel Typo="Typography.Body">@FormatCurrency(_dashboard.Spend.MonthSpend) of @FormatCurrency(monthlyBudgetLimit) used this month.</FluentLabel>
                                }
                                else
                                {
                                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">No budget limit is configured for this environment yet.</FluentLabel>
                                }
                            </FluentStack>
                        </div>
                    </div>
                }
            </FluentStack>
        </FluentCard>
    </section>

    <section aria-labelledby="admin-jobs-heading" aria-busy="@_isLoading">
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical" Class="lk-card-content">
                <FluentStack Orientation="Orientation.Vertical" Class="lk-card-header-copy">
                    <FluentLabel Id="admin-jobs-heading" Typo="Typography.Subject" Weight="FontWeight.Bold">Scheduled jobs</FluentLabel>
                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Active automation cadence, previous execution, and next expected run.</FluentLabel>
                </FluentStack>

                @if (_isLoading || _dashboard is null)
                {
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Class="lk-loading">
                        <FluentProgressRing />
                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Loading scheduled jobs…</FluentLabel>
                    </FluentStack>
                }
                else
                {
                    <div class="lk-scroll-region" style="--lk-table-min-width: 840px;">
                        <FluentDataGrid Items="@(_dashboard.ScheduledJobs.AsQueryable())" TGridItem="AdminScheduledJob" Style="width: 100%;" GridTemplateColumns="2fr 1.5fr 1.5fr 1.5fr auto">
                            <PropertyColumn Property="@(job => job.Name)" Title="Name" Sortable="true" />
                            <TemplateColumn Title="Schedule">
                                <code>@context.Schedule</code>
                            </TemplateColumn>
                            <TemplateColumn Title="Last run">
                                <time datetime="@FormatTimestampAttribute(context.LastRunAt)">@FormatDateTime(context.LastRunAt)</time>
                            </TemplateColumn>
                            <TemplateColumn Title="Next run">
                                <time datetime="@FormatTimestampAttribute(context.NextRunAt)">@FormatDateTime(context.NextRunAt)</time>
                            </TemplateColumn>
                            <TemplateColumn Title="Status">
                                <FluentBadge Appearance="@(context.Status == AdminJobStatus.Running ? Appearance.Accent : context.Status == AdminJobStatus.Idle || context.Status == AdminJobStatus.Disabled ? Appearance.Neutral : Appearance.Lightweight)">
                                    @GetJobStatusLabel(context.Status)
                                </FluentBadge>
                            </TemplateColumn>
                        </FluentDataGrid>
                    </div>
                }
            </FluentStack>
        </FluentCard>
    </section>
</FluentStack>

@code {
    private const string AllCategoriesValue = "__all";
    private readonly CancellationTokenSource _disposeCts = new();
    private AdminDashboardSnapshot? _dashboard;
    private bool _isLoading = true;
    private bool _isRefreshingHealth;
    private string _selectedToolCategory = AllCategoriesValue;
    private string? _statusMessage;
    private string? _errorMessage;
    private string? _updatingToolName;

    private IReadOnlyList<string> ToolCategories => _dashboard is null
        ? []
        : [.. _dashboard.Tools.Select(tool => tool.Category).Distinct(StringComparer.Ordinal).OrderBy(category => category, StringComparer.Ordinal)];

    private IEnumerable<AdminToolGovernanceItem> FilteredTools => _dashboard?.Tools.Where(tool =>
            string.Equals(_selectedToolCategory, AllCategoriesValue, StringComparison.Ordinal)
            || string.Equals(tool.Category, _selectedToolCategory, StringComparison.Ordinal))
        ?? [];

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        try
        {
            _errorMessage = null;
            _dashboard = await AdminService.GetDashboardAsync(_disposeCts.Token);
            _statusMessage = $"Dashboard loaded {FormatDateTime(_dashboard.GeneratedAt)}.";
        }
        catch (OperationCanceledException) when (_disposeCts.IsCancellationRequested)
        {
        }
        catch (Exception)
        {
            _errorMessage = "The admin preview could not be loaded. Please refresh the page and try again.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task RefreshProviderHealthAsync()
    {
        try
        {
            _isRefreshingHealth = true;
            _errorMessage = null;
            _dashboard = await AdminService.RefreshProviderHealthAsync(_disposeCts.Token);
            _statusMessage = $"Provider health re-checked {FormatDateTime(_dashboard.GeneratedAt)}.";
        }
        catch (OperationCanceledException) when (_disposeCts.IsCancellationRequested)
        {
        }
        catch (Exception)
        {
            _errorMessage = "Provider health could not be refreshed right now.";
        }
        finally
        {
            _isRefreshingHealth = false;
        }
    }

    private async Task OnToolToggleChangedAsync(string toolName, ChangeEventArgs args)
    {
        var enabled = args.Value switch
        {
            bool boolValue => boolValue,
            string stringValue when bool.TryParse(stringValue, out var parsed) => parsed,
            _ => false,
        };

        try
        {
            _updatingToolName = toolName;
            _errorMessage = null;
            _dashboard = await AdminService.SetToolEnabledAsync(toolName, enabled, _disposeCts.Token);
            _statusMessage = $"{toolName} {(enabled ? "enabled" : "disabled")} for this session.";
        }
        catch (OperationCanceledException) when (_disposeCts.IsCancellationRequested)
        {
        }
        catch (Exception)
        {
            _errorMessage = $"The preview toggle for {toolName} could not be updated.";
        }
        finally
        {
            _updatingToolName = null;
        }
    }

    private static string FormatDateTime(DateTimeOffset value)
        => value.LocalDateTime.ToString("MMM d, h:mm tt", CultureInfo.CurrentCulture);

    private static string FormatTimestampAttribute(DateTimeOffset value)
        => value.ToString("O", CultureInfo.InvariantCulture);

    private static string FormatCurrency(decimal value)
        => value.ToString("C", CultureInfo.CurrentCulture);

    private static string GetToggleAriaLabel(AdminToolGovernanceItem tool)
        => tool.Enabled ? $"Disable {tool.Name}" : $"Enable {tool.Name}";

    private static string GetProviderStatusLabel(AdminProviderStatus status)
        => status switch
        {
            AdminProviderStatus.Healthy => "Healthy",
            AdminProviderStatus.Degraded => "Degraded",
            _ => "Unavailable",
        };

    private static string GetJobStatusLabel(AdminJobStatus status)
        => status switch
        {
            AdminJobStatus.Running => "Running",
            AdminJobStatus.Idle => "Idle",
            AdminJobStatus.Disabled => "Disabled",
            _ => "Failed",
        };

    private decimal GetMaxDailySpend()
        => _dashboard?.Spend.DailySpend.Max(point => point.Amount) ?? 0m;

    private string GetSpendBarStyle(AdminSpendPoint point)
    {
        var maxValue = GetMaxDailySpend();
        if (maxValue <= 0m)
        {
            return "height: 0%;";
        }

        var height = Math.Round((point.Amount / maxValue) * 100m, 2);
        if (point.Amount > 0m)
        {
            height = Math.Max(height, 14m);
        }

        return $"height: {height.ToString("0.##", CultureInfo.InvariantCulture)}%;";
    }

    private decimal GetBudgetUsagePercentage()
    {
        if (_dashboard?.Spend.MonthlyBudgetLimit is not decimal monthlyBudgetLimit || monthlyBudgetLimit <= 0m)
        {
            return 0m;
        }

        return Math.Min(Math.Round((_dashboard.Spend.MonthSpend / monthlyBudgetLimit) * 100m, 2), 100m);
    }

    private string GetBudgetSummary()
    {
        if (_dashboard?.Spend.MonthlyBudgetLimit is not decimal monthlyBudgetLimit || monthlyBudgetLimit <= 0m)
        {
            return "Not set";
        }

        return $"{GetBudgetUsagePercentage():0}% used";
    }

    private string GetBudgetCaption()
        => _dashboard?.Spend.MonthlyBudgetLimit is decimal monthlyBudgetLimit && monthlyBudgetLimit > 0m
            ? $"Tracking against a {FormatCurrency(monthlyBudgetLimit)} monthly spend threshold."
            : "Add a budget threshold when the admin API exposes spend guardrails.";

    private string GetSpendChartSummary()
    {
        if (_dashboard is null)
        {
            return "Spend trend unavailable.";
        }

        var highest = _dashboard.Spend.DailySpend.OrderByDescending(point => point.Amount).First();
        return $"Daily spend for the last 7 days. Highest spend was {FormatCurrency(highest.Amount)} on {highest.Label}.";
    }

    public async ValueTask DisposeAsync()
    {
        if (!_disposeCts.IsCancellationRequested)
        {
            await _disposeCts.CancelAsync();
        }

        _disposeCts.Dispose();
    }
}
