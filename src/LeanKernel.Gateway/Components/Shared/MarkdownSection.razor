@using System.Text.RegularExpressions
@using Markdig

<div class="@CssClass">@((MarkupString)RenderedHtml)</div>

@code {
    private static readonly MarkdownPipeline Pipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .DisableHtml()
        .Build();

    private static readonly Regex AnchorHrefPattern = new(
        "<a\\s+href=\"(?<href>[^\"]*)\"(?<attrs>[^>]*)>",
        RegexOptions.Compiled | RegexOptions.IgnoreCase);

    [Parameter]
    public string Content { get; set; } = string.Empty;

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public bool EnableCopy { get; set; } = true;

    private string CssClass => string.IsNullOrWhiteSpace(Class)
        ? "lk-markdown"
        : $"lk-markdown {Class}";

    private string RenderedHtml => RenderMarkdown(Content);

    private static string RenderMarkdown(string content)
    {
        var html = Markdown.ToHtml(content ?? string.Empty, Pipeline);
        return SanitizeAnchors(html);
    }

    private static string SanitizeAnchors(string html)
    {
        return AnchorHrefPattern.Replace(html, match =>
        {
            var href = match.Groups["href"].Value;
            if (!IsAllowedHref(href))
            {
                return "<a>";
            }

            var attrs = match.Groups["attrs"].Value;
            if (IsExternalHttp(href))
            {
                attrs += " target=\"_blank\" rel=\"noopener noreferrer\"";
            }

            return $"<a href=\"{href}\"{attrs}>";
        });
    }

    private static bool IsAllowedHref(string href)
    {
        if (string.IsNullOrWhiteSpace(href))
        {
            return false;
        }

        if (href.StartsWith('#') || href.StartsWith('/'))
        {
            return true;
        }

        return Uri.TryCreate(href, UriKind.Absolute, out var uri)
            && (uri.Scheme == Uri.UriSchemeHttp
                || uri.Scheme == Uri.UriSchemeHttps
                || uri.Scheme == Uri.UriSchemeMailto);
    }

    private static bool IsExternalHttp(string href)
    {
        return Uri.TryCreate(href, UriKind.Absolute, out var uri)
            && (uri.Scheme == Uri.UriSchemeHttp || uri.Scheme == Uri.UriSchemeHttps);
    }
}
