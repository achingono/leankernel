@using Microsoft.AspNetCore.Components.Web

<FluentStack Orientation="Orientation.Vertical" Class="lk-session-list">
    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Class="lk-card-header">
        <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">Sessions</FluentLabel>
        <FluentButton Appearance="Appearance.Accent" OnClick="CreateNewAsync">New</FluentButton>
    </FluentStack>

    @if (Sessions.Count == 0)
    {
        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">No sessions yet. Start a conversation to populate this list.</FluentLabel>
    }
    else
    {
        <FluentStack Orientation="Orientation.Vertical" Class="lk-section-tight">
            @foreach (var session in Sessions)
            {
                var isActive = string.Equals(session.SessionId, ActiveSessionId, StringComparison.Ordinal);
                <div class="@($"lk-session-item lk-card-interactive{(isActive ? " lk-active" : string.Empty)}")"
                     role="button"
                     tabindex="0"
                     aria-label="@($"Open session {session.Title}")"
                     @onclick="() => SelectAsync(session.SessionId)"
                     @onkeydown="@(args => HandleSessionKeyDownAsync(args, session.SessionId))">
                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">@session.Title</FluentLabel>
                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@session.Preview</FluentLabel>
                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@FormatTimestamp(session.UpdatedAt)</FluentLabel>
                </div>
            }
        </FluentStack>
    }
</FluentStack>

@code {
    [Parameter]
    public IReadOnlyList<ChatSessionSummary> Sessions { get; set; } = [];

    [Parameter]
    public string? ActiveSessionId { get; set; }

    [Parameter]
    public EventCallback OnNewSession { get; set; }

    [Parameter]
    public EventCallback<string> OnSelectSession { get; set; }

    private Task CreateNewAsync() => OnNewSession.InvokeAsync();

    private Task SelectAsync(string sessionId) => OnSelectSession.InvokeAsync(sessionId);

    private Task HandleSessionKeyDownAsync(KeyboardEventArgs args, string sessionId)
        => IsActivationKey(args)
            ? SelectAsync(sessionId)
            : Task.CompletedTask;

    private static bool IsActivationKey(KeyboardEventArgs args)
        => string.Equals(args.Key, "Enter", StringComparison.Ordinal)
            || string.Equals(args.Key, " ", StringComparison.Ordinal)
            || string.Equals(args.Key, "Spacebar", StringComparison.Ordinal);

    private static string FormatTimestamp(DateTimeOffset value)
    {
        var local = value.ToLocalTime();
        var now = DateTimeOffset.Now;

        if (local.Date == now.Date)
        {
            return local.ToString("t");
        }

        if (local.Year == now.Year)
        {
            return local.ToString("MMM d");
        }

        return local.ToString("g");
    }
}
