@inject IJSRuntime JS

<FluentCard Class="@($"{(IsUser ? "lk-chat-bubble-user" : "lk-chat-bubble-assistant")}")">
    <FluentStack Orientation="Orientation.Vertical" Class="lk-card-content">
        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="justify-content: space-between; margin-bottom: 0.5rem;">
            <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 0.5rem;">
                <FluentBadge Appearance="Appearance.Accent">@(IsUser ? "You" : "LeanKernel")</FluentBadge>
                @if (!string.IsNullOrWhiteSpace(Message.CompactionLabel))
                {
                    <FluentBadge Appearance="Appearance.Neutral">@Message.CompactionLabel</FluentBadge>
                }
                @if (Message.Status == ChatMessageStatus.Pending)
                {
                    <FluentBadge Appearance="Appearance.Lightweight">Sending</FluentBadge>
                }
            </FluentStack>

            <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 0.75rem;">
                <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@GetTimestampLabel()</FluentLabel>
                @if (!IsUser)
                {
                    <FluentButton Appearance="Appearance.Lightweight"
                                  IconEnd="@(new Icons.Regular.Size16.Copy())"
                                  OnClick="CopyMessageToClipboardAsync"
                                  AriaLabel="Copy assistant response"
                                  Title="Copy to clipboard"
                                  Style="height: 24px; padding: 0 var(--lk-space-xxs);" />
                }
            </FluentStack>
        </FluentStack>

        <MarkdownSection Content="@Message.Content" Class="@(IsUser ? "lk-markdown-user" : "lk-markdown-assistant")" />
    </FluentStack>
</FluentCard>

@code {
    [Parameter]
    public required ChatMessageViewModel Message { get; set; }

    private bool IsUser => string.Equals(Message.Role, "user", StringComparison.OrdinalIgnoreCase);

    private string GetTimestampLabel() => Message.Timestamp.LocalDateTime.ToString("g");

    private async Task CopyMessageToClipboardAsync()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", Message.Content);
    }
}
