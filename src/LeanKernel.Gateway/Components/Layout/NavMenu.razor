@inject ChatService ChatService
@inject NavigationManager Navigation
@implements IDisposable

<FluentNavLink Href="/chat" Match="NavLinkMatch.Prefix" Icon="@(new Icons.Regular.Size20.Chat())" IconColor="Color.Accent">Chat</FluentNavLink>

@if (ShowSessions)
{
    <FluentNavGroup @bind-Expanded="_sessionsExpanded" Icon="@(new Icons.Regular.Size20.History())">
        <TitleTemplate>
            <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Wrap="false" Style="justify-content: space-between; width: 100%;">
                <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Sessions</FluentLabel>
                <FluentButton Appearance="Appearance.Lightweight"
                              Id="nav-new-session-button"
                              OnClick="CreateNewSessionAsync"
                              AriaLabel="New session"
                              Title="New session"
                              Style="height: 24px; min-width: 24px; padding: 0;">
                    <FluentIcon Value="@(new Icons.Regular.Size16.Add())" />
                </FluentButton>
            </FluentStack>
        </TitleTemplate>

        <ChildContent>
            @if (ChatService.Sessions.Count == 0)
            {
                <FluentLabel Typo="Typography.Body" Color="Color.Neutral">No sessions yet</FluentLabel>
            }
            else
            {
                @foreach (var session in ChatService.Sessions)
                {
                    <FluentNavLink Href="@($"/chat/{session.SessionId}")" Match="NavLinkMatch.All" Tooltip="@session.Preview">
                        @session.Title
                    </FluentNavLink>
                }
            }
        </ChildContent>
    </FluentNavGroup>
}

<FluentNavLink Href="/diagnostics" Icon="@(new Icons.Regular.Size20.BugArrowCounterclockwise())" IconColor="Color.Accent">Diagnostics</FluentNavLink>
<FluentNavLink Href="/knowledge" Icon="@(new Icons.Regular.Size20.Book())" IconColor="Color.Accent">Knowledge</FluentNavLink>
<FluentNavLink Href="/admin" Icon="@(new Icons.Regular.Size20.Settings())" IconColor="Color.Accent">Admin</FluentNavLink>
<FluentNavLink Href="/onboarding" Icon="@(new Icons.Regular.Size20.PersonAdd())" IconColor="Color.Accent">Setup</FluentNavLink>

@code {
    private bool _sessionsExpanded = true;

    private bool ShowSessions
    {
        get
        {
            var path = Navigation.ToBaseRelativePath(Navigation.Uri);
            return string.IsNullOrWhiteSpace(path)
                || path.Equals("chat", StringComparison.OrdinalIgnoreCase)
                || path.StartsWith("chat/", StringComparison.OrdinalIgnoreCase);
        }
    }

    protected override void OnInitialized()
    {
        ChatService.SessionsChanged += HandleSessionsChanged;
        Navigation.LocationChanged += HandleLocationChanged;
    }

    private async Task CreateNewSessionAsync()
    {
        try
        {
            var sessionId = await ChatService.CreateNewSessionAsync();
            Navigation.NavigateTo($"/chat/{sessionId}");
        }
        catch (InvalidOperationException)
        {
            Navigation.NavigateTo("/chat");
        }
    }

    private void HandleSessionsChanged() => _ = InvokeAsync(StateHasChanged);

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
        => _ = InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        ChatService.SessionsChanged -= HandleSessionsChanged;
        Navigation.LocationChanged -= HandleLocationChanged;
    }
}
