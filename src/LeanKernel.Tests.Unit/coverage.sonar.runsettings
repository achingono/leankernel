<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat Code Coverage">
        <Configuration>
          <Format>opencover</Format>
          <ExcludeByAttribute>ExcludeFromCodeCoverageAttribute,GeneratedCodeAttribute,CompilerGeneratedAttribute</ExcludeByAttribute>
          <ExcludeByFile>**/*.g.cs,**/*.Designer.cs,**/*.razor,**/Data/Migrations/*.cs,**/LeanKernelFeatureServiceCollectionExtensions.cs,**/Services/Auth/AuthRegistration.cs,**/Services/Auth/OidcRegistration.cs,**/Services/Auth/BearerTokenAuthHandler.cs,**/Services/EngagementAuthorizationFilter.cs,**/Services/ChannelInitializationService.cs,**/Services/Skills/SkillHostedService.cs,**/Services/AttachmentTextExtractionService.cs,**/EngagementRulesProvider.cs,**/SignalRestApiAdapter.cs,**/DynamicSkillTool.cs,**/BinaryResolver.cs,**/DynamicSkillToolFactory.cs,**/EgressPolicy.cs,**/RuntimeSkillRegistry.cs</ExcludeByFile>
          <Exclude>[LeanKernel.Host]Program</Exclude>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
