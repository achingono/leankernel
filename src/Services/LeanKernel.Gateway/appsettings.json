{
  "ConnectionStrings": {
    "Sqlite": "Data Source=leankernel.db"
  },
  "OpenAI": {
    "ApiKey": "",
    "BaseUrl": "https://api.openai.com/v1",
    "DefaultModel": "gpt-4o-mini",
    "ToolModel": "tool",
    "Memory": {
      "ModelId": "gpt-4o-mini",
      "MaxOutputTokens": 512,
      "MaxConcurrency": 4,
      "TimeoutSeconds": 15,
      "Enabled": true
    },
    "FactExtraction": {
      "ModelId": "gpt-4o-mini",
      "Temperature": 0.1,
      "MaxOutputTokens": 1024
    }
  },
  "Agents": {
    "RootPath": "agents",
    "DefaultName": "leankernel",
    "DefaultDescription": "LeanKernel assistant",
    "DefaultInstructions": "You are a helpful AI assistant.",
    "Tools": {
      "Enabled": true,
      "WebSearch": {
        "Provider": "brave",
        "ApiKeyEnv": "BRAVE_API_KEY",
        "AllowHosts": [ "api.search.brave.com", "api.duckduckgo.com" ]
      },
      "AllowedToolNames": [],
      "AllowedCategories": [],
      "SkillBasePaths": [ "/app/data/skills" ],
      "DynamicHttp": {
        "AllowHosts": []
      },
      "BuiltIns": {
        "Calculation": {
          "Enabled": true,
          "MaxInputItems": 1000
        }
      },
      "DocumentIngestion": {
        "Enabled": false,
        "MaxConcurrentJobs": 3,
        "QueueCapacity": 100,
        "EnqueueTimeoutSeconds": 30,
        "WatchSettleDelaySeconds": 2,
        "WatchMaxRetries": 3,
        "WatchRetryBaseDelaySeconds": 1,
        "WatchRetryMaxDelaySeconds": 60
      },
      "McpServers": [
        {
          "Name": "webwright",
          "Endpoint": "http://localhost:8000/mcp",
          "Enabled": false,
          "TransportMode": "AutoDetect",
          "ConnectionTimeoutSeconds": 30,
          "Required": false
        }
      ]
    },
    "Channels": {
      "Enabled": true,
      "TrustedIssuers": [],
      "MemoryPolicyDefaults": {
        "Share": [ "*" ],
        "Access": [ "*" ]
      }
    },
    "Telemetry": {
      "Enabled": true,
      "Currency": "USD",
      "RetainRawMetadata": true,
      "UseCostEstimate": true,
      "CostEstimate": {
        "CostPer1kInputTokens": {
          "gpt-4o": 0.0025,
          "gpt-4o-mini": 0.00015,
          "gpt-4-turbo": 0.01,
          "claude-3-opus": 0.015,
          "claude-3-sonnet": 0.003,
          "claude-3-haiku": 0.00025
        },
        "CostPer1kOutputTokens": {
          "gpt-4o": 0.01,
          "gpt-4o-mini": 0.0006,
          "gpt-4-turbo": 0.03,
          "claude-3-opus": 0.075,
          "claude-3-sonnet": 0.015,
          "claude-3-haiku": 0.00125
        }
      }
    }
  },
  "Identity": {
    "AnonymousUserName": "anonymous",
    "AnonymousFullName": "Anonymous User",
    "AuthenticationScheme": "Bearer",
    "AuthenticationType": "Bearer",
    "Token": {
      "SecretKey": "",
      "Issuer": "",
      "Audience": "",
      "TimeoutMinutes": 30,
      "PersistentTimeoutInDays": 365
    },
    "OpenId": {
      "Authority": "",
      "ClientId": "",
      "ClientSecret": "",
      "RequireHttpsMetadata": false
    },
    "ClaimsContext": {
      "Enabled": true,
      "AllowedCustomClaims": [],
      "PromptFields": [
        "full_name",
        "email",
        "preferred_username",
        "locale",
        "timezone",
        "organization",
        "roles",
        "groups",
        "custom_claims"
      ],
      "MaxRoles": 10,
      "MaxGroups": 20,
      "MaxCustomClaimValuesPerClaim": 5,
      "MaxPromptTokens": 256
    }
  },
  "Files": {
    "RootPath": "./data",
    "ScratchRoot": "./scratch",
    "MaxDownloadBytes": 10000000,
    "MaxExtractedCharacters": 20000,
    "PythonExecutable": "python3",
    "WatchFolders": [
      // {
      //   "Path": "./watch/invoices",
      //   "TenantId": "00000000-0000-0000-0000-000000000001",
      //   "PersonId": "00000000-0000-0000-0000-000000000002",
      //   "UserId": "00000000-0000-0000-0000-000000000003",
      //   "ChannelId": "00000000-0000-0000-0000-000000000004",
      //   "AvailabilityScope": "Tenant",
      //   "FilePattern": "*"
      // }
    ],
    "UploadMaxFileSizeBytes": 10485760,
    "UploadAllowedContentTypes": [
      "text/plain",
      "text/markdown",
      "application/pdf",
      "image/png",
      "image/jpeg",
      "text/csv",
      "application/json",
      "application/xml"
    ]
  },
  "Cors": {
    "Policy": {
      "Name": "AllowLocal",
      "Origins": [
        "http://localhost:3000"
      ]
    }
  },
  "GBrain": {
    "BaseUrl": "http://localhost:8789",
    "AuthToken": "",
    "TimeoutSeconds": 30
  }
}
