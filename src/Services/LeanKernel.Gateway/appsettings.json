{
  "ConnectionStrings": {
    "Sqlite": "Data Source=leankernel.db"
  },
  "OpenAI": {
    "ApiKey": "",
    "BaseUrl": "https://api.openai.com/v1",
    "DefaultModel": "gpt-4o-mini",
    "ToolModel": "tool",
    "Memory": {
      "ModelId": "gpt-4o-mini",
      "MaxOutputTokens": 512,
      "MaxConcurrency": 4,
      "TimeoutSeconds": 15,
      "Enabled": true
    },
    "FactExtraction": {
      "ModelId": "gpt-4o-mini",
      "Temperature": 0.1,
      "MaxOutputTokens": 1024
    }
  },
  "Agents": {
    "RootPath": "agents",
    "DefaultName": "leankernel",
    "DefaultDescription": "LeanKernel assistant",
    "DefaultInstructions": "You are a helpful AI assistant.",
    "Tools": {
      "Enabled": true,
      "WebSearch": {
        "Provider": "brave",
        "ApiKeyEnv": "BRAVE_API_KEY",
        "AllowHosts": [ "api.search.brave.com", "api.duckduckgo.com" ]
      },
      "AllowedToolNames": [],
      "AllowedCategories": [],
      "SkillBasePaths": [ "/app/data/skills" ],
      "DynamicHttp": {
        "AllowHosts": []
      },
      "BuiltIns": {
        "Calculation": {
          "Enabled": true,
          "MaxInputItems": 1000
        }
      },
      "McpServers": [
        {
          "Name": "webwright",
          "Endpoint": "http://localhost:8000/mcp",
          "Enabled": false,
          "TransportMode": "AutoDetect",
          "ConnectionTimeoutSeconds": 30,
          "Required": false
        }
      ]
    },
    "Channels": {
      "Enabled": true,
      "TrustedIssuers": [],
      "MemoryPolicyDefaults": {
        "Share": [ "*" ],
        "Access": [ "*" ]
      }
    },
    "Telemetry": {
      "Enabled": true,
      "Currency": "USD",
      "RetainRawMetadata": true,
      "UseCostEstimate": true,
      "CostEstimate": {
        "CostPer1kInputTokens": {
          "gpt-4o": 0.0025,
          "gpt-4o-mini": 0.00015,
          "gpt-4-turbo": 0.01,
          "claude-3-opus": 0.015,
          "claude-3-sonnet": 0.003,
          "claude-3-haiku": 0.00025
        },
        "CostPer1kOutputTokens": {
          "gpt-4o": 0.01,
          "gpt-4o-mini": 0.0006,
          "gpt-4-turbo": 0.03,
          "claude-3-opus": 0.075,
          "claude-3-sonnet": 0.015,
          "claude-3-haiku": 0.00125
        }
      }
    }
  },
  "Identity": {
    "AnonymousUserName": "anonymous",
    "AnonymousFullName": "Anonymous User",
    "AuthenticationScheme": "Bearer",
    "AuthenticationType": "Bearer",
    "Token": {
      "SecretKey": "",
      "Issuer": "",
      "Audience": "",
      "TimeoutMinutes": 30,
      "PersistentTimeoutInDays": 365
    },
    "OpenId": {
      "Authority": "",
      "ClientId": "",
      "ClientSecret": "",
      "RequireHttpsMetadata": false
    }
  },
  "Files": {
    "RootPath": "./data"
  },
  "Cors": {
    "Policy": {
      "Name": "AllowLocal",
      "Origins": [
        "http://localhost:3000"
      ]
    }
  },
  "GBrain": {
    "BaseUrl": "http://localhost:8789",
    "AuthToken": "",
    "TimeoutSeconds": 30
  }
}
