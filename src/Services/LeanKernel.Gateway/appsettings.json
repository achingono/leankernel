{
  "ConnectionStrings": {
    "Sqlite": "Data Source=leankernel.db"
  },
  "OpenAI": {
    "ApiKey": "",
    "BaseUrl": "https://api.openai.com/v1",
    "DefaultModel": "gpt-4o-mini",
    "ToolModel": "tool",
    "Memory": {
      "ModelId": "gpt-4o-mini",
      "MaxOutputTokens": 512,
      "MaxConcurrency": 4,
      "TimeoutSeconds": 15,
      "Enabled": true
    },
    "FactExtraction": {
      "ModelId": "gpt-4o-mini",
      "Temperature": 0.1,
      "MaxOutputTokens": 1024
    }
  },
  "Agents": {
    "RootPath": "agents",
    "DefaultName": "leankernel",
    "DefaultDescription": "LeanKernel assistant",
    "DefaultInstructions": "You are a helpful AI assistant.",
    "Tools": {
      "Enabled": true,
      "WebSearch": {
        "Provider": "brave",
        "ApiKeyEnv": "BRAVE_API_KEY",
        "AllowHosts": [ "api.search.brave.com", "api.duckduckgo.com" ]
      },
      "AllowedToolNames": [],
      "AllowedCategories": [],
      "SkillBasePaths": [ "/app/data/skills" ],
      "DynamicHttp": {
        "AllowHosts": []
      },
      "BuiltIns": {
        "Calculation": {
          "Enabled": true,
          "MaxInputItems": 1000
        }
      }
    },
    "Channels": {
      "Enabled": true,
      "TrustedIssuers": [],
      "MemoryPolicyDefaults": {
        "Share": [ "*" ],
        "Access": [ "*" ]
      }
    }
  },
  "Identity": {
    "AnonymousUserName": "anonymous",
    "AnonymousFullName": "Anonymous User",
    "AuthenticationScheme": "Bearer",
    "AuthenticationType": "Bearer",
    "Token": {
      "SecretKey": "",
      "Issuer": "",
      "Audience": "",
      "TimeoutMinutes": 30,
      "PersistentTimeoutInDays": 365
    },
    "OpenId": {
      "Authority": "",
      "ClientId": "",
      "ClientSecret": "",
      "RequireHttpsMetadata": false
    }
  },
  "Files": {
    "RootPath": "./data"
  },
  "Cors": {
    "Policy": {
      "Name": "AllowLocal",
      "Origins": [
        "http://localhost:3000"
      ]
    }
  },
  "GBrain": {
    "BaseUrl": "http://localhost:8789",
    "AuthToken": "",
    "TimeoutSeconds": 30
  }
}
