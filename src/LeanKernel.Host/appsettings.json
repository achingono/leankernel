{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "LeanKernel": {
    "LiteLlm": {
      "BaseUrl": "http://litellm:4000",
      "ApiKey": "sk-LeanKernel-local",
      "DefaultModel": "small",
      "EmbeddingModel": "embedding-small",
      "ContextWindowTokens": 128000
    },
    "Qdrant": {
      "Host": "qdrant",
      "Port": 6334,
      "CollectionName": "LEANKERNEL_knowledge",
      "EmbeddingDimension": 1536
    },
    "Knowledge": {
      "Enabled": true,
      "CollectionName": "LEANKERNEL_knowledge",
      "WikiCollectionName": "LEANKERNEL_knowledge",
      "DocumentsCollectionName": "documents",
      "EmbeddingDimension": 1536,
      "DefaultDocumentTags": ["wiki", "documents", "general"],
      "TagRules": [
        {
          "pathPattern": "wiki/**",
          "tags": ["wiki"]
        },
        {
          "pathPattern": "documents/**",
          "tags": ["documents"]
        }
      ],
      "AgentScopes": {
        "default": {
          "tags": ["wiki", "documents", "general"]
        }
      }
    },
    "Signal": {
      "CliPath": "/usr/bin/signal-cli",
      "Account": "",
      "Enabled": true,
      "AllowedSenders": []
    },
    "Wiki": {
      "BasePath": "/app/data/wiki",
      "MaxFactsPerEntry": 20,
      "StaleFactDays": 30,
      "MinConfidenceThreshold": 0.5
    },
    "Skills": {
      "BasePaths": "/app/data/skills",
      "CacheDurationMinutes": 60,
      "WatchForChanges": true
    },
    "Context": {
      "SemanticSimilarityWeight": 0.40,
      "RecencyDecayWeight": 0.20,
      "DimensionMatchWeight": 0.25,
      "InteractionFrequencyWeight": 0.15,
      "MinRelevanceThreshold": 0.65,
      "MaxConversationTurns": 15,
      "EntitySubjectBoost": 0.45,
      "SupportingEntityThreshold": 0.35,
      "EntityExpansionDepth": 1,
      "LowConfidenceFallbackThreshold": 0.80,
      "DeprioritizedRecallMaxResults": 40,
      "AmbiguityLowConfidenceThreshold": 0.85,
      "AmbiguityConfidenceGapThreshold": 0.15,
      "Reranker": {
        "Enabled": true,
        "TopN": 12,
        "TopK": 6,
        "TimeoutMs": 1200,
        "MinAcceptanceScore": 0.0
      }
    },
    "Scheduler": {
      "Enabled": true,
      "WikiMaintenanceCron": "0 3 * * *",
      "ChatFactScrubCron": "30 2 * * *"
    }
  }
}
