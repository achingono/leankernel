{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "LeanKernel": {
    "LiteLlm": {
      "BaseUrl": "http://litellm:4000",
      "ApiKey": "sk-LeanKernel-local",
      "DefaultModel": "gpt-4o-mini",
      "EmbeddingModel": "text-embedding-3-small",
      "ContextWindowTokens": 128000
    },
    "Qdrant": {
      "Host": "qdrant",
      "Port": 6334,
      "CollectionName": "LEANKERNEL_wiki",
      "EmbeddingDimension": 1536
    },
    "Signal": {
      "CliPath": "/usr/local/bin/signal-cli",
      "Account": "",
      "Enabled": true
    },
    "Wiki": {
      "BasePath": "/app/data/wiki",
      "MaxFactsPerEntry": 20,
      "StaleFactDays": 30,
      "MinConfidenceThreshold": 0.5
    },
    "Context": {
      "SemanticSimilarityWeight": 0.40,
      "RecencyDecayWeight": 0.20,
      "DimensionMatchWeight": 0.25,
      "InteractionFrequencyWeight": 0.15,
      "MinRelevanceThreshold": 0.65,
      "MaxConversationTurns": 15
    },
    "Scheduler": {
      "Enabled": true,
      "WikiMaintenanceCron": "0 3 * * *"
    }
  }
}
