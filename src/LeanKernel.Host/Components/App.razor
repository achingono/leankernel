<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LeanKernel — AI Agent Console</title>
    <base href="/" />
    <link rel="icon" type="image/svg+xml" href="brand/logo.svg" />
    <link rel="icon" type="image/png" href="brand/favicon.png" sizes="32x32" />
    <link rel="apple-touch-icon" href="brand/logo-mark.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="@StylesheetHref" />
    <HeadOutlet />
</head>
<body class="LeanKernel-body">
    <Routes />
    <script src="_framework/blazor.web.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.52.0/min/vs/loader.min.js"></script>
</body>
</html>

@code {
    [Inject] private IWebHostEnvironment Environment { get; set; } = default!;

    private string StylesheetHref => $"css/LeanKernel.css?v={System.IO.File.GetLastWriteTimeUtc(System.IO.Path.Combine(Environment.WebRootPath, "css", "LeanKernel.css")).Ticks}";
}
