@page "/logs"
@inject HttpClient Http
@rendermode InteractiveServer

<div class="page-header">
    <h1><span class="text-neon">▣</span> Logs</h1>
    <p class="subtitle">Application log viewer with search and filtering</p>
</div>

<!-- Filters -->
<div style="display: flex; gap: 0.75rem; margin-bottom: 1rem; flex-wrap: wrap; align-items: center;">
    <div class="search-box" style="flex: 1; min-width: 200px; margin-bottom: 0;">
        <span class="search-icon">⌕</span>
        <input class="search-input"
               @bind="SearchQuery"
               @bind:event="oninput"
               placeholder="Search logs..." />
    </div>

    <select class="setting-input" style="max-width: 120px;" @bind="SelectedLevel">
        <option value="">All Levels</option>
        <option value="DBG">Debug</option>
        <option value="INF">Info</option>
        <option value="WRN">Warning</option>
        <option value="ERR">Error</option>
    </select>

    <button class="btn-primary" @onclick="LoadLogs">Search</button>
    <button class="btn-ghost" @onclick="async () => { SearchQuery = string.Empty; SelectedLevel = string.Empty; await LoadLogs(); }">Clear</button>
</div>

<!-- Log files info -->
<div style="margin-bottom: 0.5rem; font-size: 0.8rem; color: var(--text-muted);">
    @LogResult?.TotalFiles files · @LogResult?.Lines?.Count lines shown
</div>

<!-- Log viewer -->
<div class="glass-card log-viewer">
    @if (LogResult?.Lines is not null)
    {
        @foreach (var line in LogResult.Lines)
        {
            <div class="log-line @GetLogClass(line.Content)">@line.Content</div>
        }

        @if (LogResult.Lines.Count == 0)
        {
            <div style="text-align: center; padding: 2rem; color: var(--text-muted);">
                No log entries found
            </div>
        }
    }
    else
    {
        <div style="text-align: center; padding: 2rem; color: var(--text-muted);">
            Loading logs...
        </div>
    }
</div>

@code {
    private string SearchQuery = "";
    private string SelectedLevel = "";
    private LogSearchResultDto? LogResult;

    protected override async Task OnInitializedAsync()
    {
        await LoadLogs();
    }

    private async Task LoadLogs()
    {
        try
        {
            var query = new List<string>();
            if (!string.IsNullOrWhiteSpace(SearchQuery))
                query.Add($"q={Uri.EscapeDataString(SearchQuery)}");
            if (!string.IsNullOrEmpty(SelectedLevel))
                query.Add($"level={SelectedLevel}");

            var url = "api/logs";
            if (query.Count > 0)
                url += "?" + string.Join("&", query);

            LogResult = await Http.GetFromJsonAsync<LogSearchResultDto>(url);
        }
        catch { LogResult = new LogSearchResultDto(); }
    }

    private static string GetLogClass(string line)
    {
        if (line.Contains(" INF]") || line.Contains(" INF ")) return "log-INF";
        if (line.Contains(" WRN]") || line.Contains(" WRN ")) return "log-WRN";
        if (line.Contains(" ERR]") || line.Contains(" ERR ")) return "log-ERR";
        if (line.Contains(" DBG]") || line.Contains(" DBG ")) return "log-DBG";
        return "";
    }

    private record LogSearchResultDto
    {
        public List<LogLineDto>? Lines { get; init; }
        public int TotalFiles { get; init; }
    }

    private record LogLineDto
    {
        public string Content { get; init; } = "";
        public string File { get; init; } = "";
    }
}
