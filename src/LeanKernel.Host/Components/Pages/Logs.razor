@page "/logs"
@using System.Diagnostics.CodeAnalysis
@using LeanKernel.Host.Services
@attribute [ExcludeFromCodeCoverage]
@inject LogReaderService LogReader
@rendermode InteractiveServer

<div class="page-header">
    <h1><span class="text-neon"><LeanKernelIcon Name="logs" /></span> Logs</h1>
    <p class="subtitle">Application log viewer with search and filtering</p>
</div>

<!-- Filters -->
<div class="toolbar-row">
    <div class="search-box" style="flex: 1; min-width: 200px;">
        <LeanKernelIcon Name="search" Class="search-icon" />
        <input class="search-input"
               @bind="SearchQuery"
               @bind:event="oninput"
               placeholder="Search logs..." />
    </div>

    <select class="setting-input" style="max-width: 120px;" @bind="SelectedLevel">
        <option value="">All Levels</option>
        <option value="DBG">Debug</option>
        <option value="INF">Info</option>
        <option value="WRN">Warning</option>
        <option value="ERR">Error</option>
    </select>

    <button class="btn-primary" @onclick="LoadLogs">Search</button>
    <button class="btn-ghost" @onclick="async () => { SearchQuery = string.Empty; SelectedLevel = string.Empty; await LoadLogs(); }">Clear</button>
</div>

<!-- Log file stats -->
<p class="text-muted text-xs">
    @LogResult?.TotalFiles files · @LogResult?.Lines?.Count lines shown
</p>

<!-- Log viewer -->
<div class="glass-card log-viewer">
    @if (IsLoading)
    {
        <div class="loading-state" aria-live="polite">Loading logs...</div>
    }
    else if (!string.IsNullOrWhiteSpace(LoadError))
    {
        <div class="error-state" role="alert">@LoadError</div>
    }
    else if (LogResult?.Lines is not null)
    {
        @foreach (var line in LogResult.Lines)
        {
            <div class="log-line @GetLogClass(line.Content)">@line.Content</div>
        }

        @if (LogResult.Lines.Count == 0)
        {
            <div class="empty-state">
                No log entries found
            </div>
        }
    }
    else
    {
        <div class="empty-state">No logs available yet</div>
    }
</div>

@code {
    private string SearchQuery = "";
    private string SelectedLevel = "";
    private LogSearchResult? LogResult;
    private bool IsLoading;
    private string? LoadError;

    protected override async Task OnInitializedAsync()
    {
        await LoadLogs();
    }

    private async Task LoadLogs()
    {
        IsLoading = true;
        LoadError = null;

        try
        {
            LogResult = await LogReader.SearchAsync(
                string.IsNullOrWhiteSpace(SearchQuery) ? null : SearchQuery,
                string.IsNullOrWhiteSpace(SelectedLevel) ? null : SelectedLevel,
                since: null,
                limit: 300,
                ct: CancellationToken.None);
        }
        catch (Exception ex)
        {
            LoadError = ex.Message;
            LogResult = new LogSearchResult();
        }
        finally
        {
            IsLoading = false;
        }
    }

    private static string GetLogClass(string line)
    {
        if (line.Contains(" INF]") || line.Contains(" INF ")) return "log-INF";
        if (line.Contains(" WRN]") || line.Contains(" WRN ")) return "log-WRN";
        if (line.Contains(" ERR]") || line.Contains(" ERR ")) return "log-ERR";
        if (line.Contains(" DBG]") || line.Contains(" DBG ")) return "log-DBG";
        return "";
    }

}
