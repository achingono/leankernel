                    <input class="setting-input" value="@Config.Wiki?.BasePath" readonly />
                </div>
                <div class="setting-row">
                    <span class="setting-label">Max Facts/Entry</span>
                    <input class="setting-input" value="@Config.Wiki?.MaxFactsPerEntry" readonly />
                </div>
                <div class="setting-row">
                    <span class="setting-label">Stale Fact Days</span>
                    <input class="setting-input" value="@Config.Wiki?.StaleFactDays" readonly />
                </div>
                <div class="setting-row">
                    <span class="setting-label">Min Confidence</span>
                    <input class="setting-input" value="@Config.Wiki?.MinConfidenceThreshold" readonly />
                </div>
            </div>
        </div>

        <!-- Context Gatekeeper -->
        <div class="glass-card">
            <div class="setting-group">
                <h3 class="text-cyan">Context Gatekeeper</h3>
                <div class="setting-row">
                    <span class="setting-label">Semantic Weight</span>
                    <input class="setting-input" value="@Config.Context?.SemanticSimilarityWeight" readonly />
                </div>
                <div class="setting-row">
                    <span class="setting-label">Recency Weight</span>
                    <input class="setting-input" value="@Config.Context?.RecencyDecayWeight" readonly />
                </div>
                <div class="setting-row">
                    <span class="setting-label">Dimension Weight</span>
                    <input class="setting-input" value="@Config.Context?.DimensionMatchWeight" readonly />
                </div>
                <div class="setting-row">
                    <span class="setting-label">Frequency Weight</span>
                    <input class="setting-input" value="@Config.Context?.InteractionFrequencyWeight" readonly />
                </div>
                <div class="setting-row">
                    <span class="setting-label">Min Relevance</span>
                    <input class="setting-input" value="@Config.Context?.MinRelevanceThreshold" readonly />
                </div>
                <div class="setting-row">
                    <span class="setting-label">Max Turns</span>
                    <input class="setting-input" value="@Config.Context?.MaxConversationTurns" readonly />
                </div>
            </div>
        </div>

        <!-- Scheduler -->
        <div class="glass-card">
            <div class="setting-group">
                <h3 class="text-cyan">Scheduler</h3>
                <div class="setting-row">
                    <span class="setting-label">Enabled</span>
                    <span class="status-badge @(Config.Scheduler?.Enabled == true ? "status-healthy" : "status-warning")">
                        @(Config.Scheduler?.Enabled == true ? "● On" : "○ Off")
                    </span>
                </div>
                <div class="setting-row">
                    <span class="setting-label">Wiki Maintenance</span>
                    <input class="setting-input text-mono" value="@Config.Scheduler?.WikiMaintenanceCron" readonly />
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="glass-card card-center">
        <p class="text-muted">Loading configuration...</p>
    </div>
}

