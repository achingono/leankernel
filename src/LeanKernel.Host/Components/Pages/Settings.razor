@page "/settings"
@using System.Diagnostics.CodeAnalysis
@using System.Net.Http.Json
@using Microsoft.Extensions.Options
@using LeanKernel.Core.Configuration
@using LeanKernel.Host.Models.Admin
@attribute [ExcludeFromCodeCoverage]
@inject IOptions<LeanKernelConfig> LeanKernelConfig
@inject HttpClient Http
@rendermode InteractiveServer

<div class="page-header">
    <h1><span class="text-neon"><LeanKernelIcon Name="settings" /></span> Settings</h1>
    <p class="subtitle">Configuration &amp; administration</p>
</div>

@if (_saveResult != null)
{
    <div class="glass-card @(_saveResult.Success ? "border-success" : "border-warning")" style="margin-bottom: 1rem;">
        @if (_saveResult.Success && _saveResult.Changes?.Count > 0)
        {
            <p class="text-cyan m-0" style="margin-bottom: 0.5rem;">✓ @_saveResult.Changes.Count change(s) saved successfully.</p>
            <ul class="text-sm" style="margin: 0; padding-left: 1.5rem;">
                @foreach (var c in _saveResult.Changes)
                {
                    <li class="@(c.RestartRequired ? "text-warning" : "")">
                        <strong>@c.Section.@c.Field</strong>: @c.OldValue → @c.NewValue
                        @if (c.RestartRequired) { <span class="badge">restart required</span> }
                    </li>
                }
            </ul>
        }
        else if (_saveResult.Success)
        {
            <p class="text-muted m-0">No changes detected.</p>
        }
        else
        {
            <p class="text-warning m-0">⚠ @_saveResult.ErrorMessage</p>
        }
    </div>
}

@if (Config is not null)
{
    <div class="content-grid stagger-in">
        <!-- LiteLLM -->
        <div class="glass-card">
            <div class="setting-group">
