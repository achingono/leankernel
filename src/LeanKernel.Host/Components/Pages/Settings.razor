@code {
    private SettingsVm? Config;
    private bool _saving;
    private SaveResult? _saveResult;

    protected override void OnInitialized()
    {
        var cfg = LeanKernelConfig.Value;
        Config = new SettingsVm
        {
            LiteLlm = new LiteLlmVm
            {
                BaseUrl = cfg.LiteLlm.BaseUrl,
                ApiKey = MaskSecret(cfg.LiteLlm.ApiKey),
                DefaultModel = cfg.LiteLlm.DefaultModel,
                EmbeddingModel = cfg.LiteLlm.EmbeddingModel,
                ContextWindowTokens = cfg.LiteLlm.ContextWindowTokens
            },
            Qdrant = new QdrantVm
            {
                Host = cfg.Qdrant.Host,
                Port = cfg.Qdrant.Port,
                CollectionName = cfg.Qdrant.CollectionName,
                EmbeddingDimension = cfg.Qdrant.EmbeddingDimension
            },
            Signal = new SignalVm
            {
                CliPath = cfg.Signal.CliPath,
                Account = MaskSecret(cfg.Signal.Account),
                Enabled = cfg.Signal.Enabled,
                DaemonBaseUrl = cfg.Signal.DaemonBaseUrl,
                AllowedSendersInput = string.Join(",", cfg.Signal.AllowedSenders)
            },
            Unstructured = new UnstructuredVm
            {
                Enabled = cfg.Unstructured.Enabled,
                BaseUrl = cfg.Unstructured.BaseUrl,
                TimeoutSeconds = cfg.Unstructured.TimeoutSeconds
            },
            Wiki = new WikiVm
            {
                BasePath = cfg.Wiki.BasePath,
                MaxFactsPerEntry = cfg.Wiki.MaxFactsPerEntry,
                StaleFactDays = cfg.Wiki.StaleFactDays,
                MinConfidenceThreshold = cfg.Wiki.MinConfidenceThreshold
            },
            Context = new ContextVm
            {
                SemanticSimilarityWeight = cfg.Context.SemanticSimilarityWeight,
                RecencyDecayWeight = cfg.Context.RecencyDecayWeight,
                DimensionMatchWeight = cfg.Context.DimensionMatchWeight,
                InteractionFrequencyWeight = cfg.Context.InteractionFrequencyWeight,
                MinRelevanceThreshold = cfg.Context.MinRelevanceThreshold,
                MaxConversationTurns = cfg.Context.MaxConversationTurns
            },
            Scheduler = new SchedulerVm
            {
                Enabled = cfg.Scheduler.Enabled,
                WikiMaintenanceCron = cfg.Scheduler.WikiMaintenanceCron
            },
            Routing = new RoutingVm
            {
                Enabled = cfg.Routing.Enabled,
                ShadowMode = cfg.Routing.ShadowMode,
                SmallAlias = cfg.Routing.SmallAlias,
                MediumAlias = cfg.Routing.MediumAlias,
                LargeAlias = cfg.Routing.LargeAlias,
                DailyPaidRequestSoftLimit = cfg.Routing.SpendGuard.DailyPaidRequestSoftLimit,
                DailyPaidRequestHardLimit = cfg.Routing.SpendGuard.DailyPaidRequestHardLimit
            }
        };
    }

    private async Task SaveSection(SectionKey section)
    {
        if (Config is null) return;
        _saving = true;
        _saveResult = null;

        try
        {
            var patch = BuildPatch(section);
            var client = Http;
            var response = await client.PatchAsJsonAsync("/api/config", patch);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<AdminConfigPatchResponse>();
                _saveResult = new SaveResult { Success = true, Changes = result?.Changes ?? [] };
            }
            else
            {
                _saveResult = new SaveResult { Success = false, ErrorMessage = $"Save failed: {response.StatusCode}" };
            }
        }
        catch (Exception ex)
        {
            _saveResult = new SaveResult { Success = false, ErrorMessage = ex.Message };
        }
        finally
        {
            _saving = false;
        }
    }

    private AdminConfigPatchRequest BuildPatch(SectionKey section) => section switch
    {
        SectionKey.LiteLlm => new AdminConfigPatchRequest
        {
            LiteLlm = new LiteLlmPatch
            {
                BaseUrl = Config!.LiteLlm.BaseUrl,
                DefaultModel = Config.LiteLlm.DefaultModel,
                EmbeddingModel = Config.LiteLlm.EmbeddingModel,
                ContextWindowTokens = Config.LiteLlm.ContextWindowTokens
            }
        },
        SectionKey.Qdrant => new AdminConfigPatchRequest
        {
            Qdrant = new QdrantPatch
            {
                Host = Config!.Qdrant.Host,
                Port = Config.Qdrant.Port,
                CollectionName = Config.Qdrant.CollectionName,
                EmbeddingDimension = Config.Qdrant.EmbeddingDimension
            }
        },
        SectionKey.Signal => new AdminConfigPatchRequest
        {
            Signal = new SignalPatch
            {
                CliPath = Config!.Signal.CliPath,
                Enabled = Config.Signal.Enabled,
                DaemonBaseUrl = Config.Signal.DaemonBaseUrl,
                AllowedSenders = Config.Signal.AllowedSendersInput?
                    .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            }
        },
        SectionKey.Unstructured => new AdminConfigPatchRequest
        {
            Unstructured = new UnstructuredPatch
            {
                Enabled = Config!.Unstructured.Enabled,
                BaseUrl = Config.Unstructured.BaseUrl,
                TimeoutSeconds = Config.Unstructured.TimeoutSeconds
            }
        },
        SectionKey.Wiki => new AdminConfigPatchRequest
        {
            Wiki = new WikiPatch
            {
                BasePath = Config!.Wiki.BasePath,
                MaxFactsPerEntry = Config.Wiki.MaxFactsPerEntry,
                StaleFactDays = Config.Wiki.StaleFactDays,
                MinConfidenceThreshold = Config.Wiki.MinConfidenceThreshold
            }
        },
        SectionKey.Context => new AdminConfigPatchRequest
        {
            Context = new ContextPatch
            {
                SemanticSimilarityWeight = Config!.Context.SemanticSimilarityWeight,
                RecencyDecayWeight = Config.Context.RecencyDecayWeight,
                DimensionMatchWeight = Config.Context.DimensionMatchWeight,
                InteractionFrequencyWeight = Config.Context.InteractionFrequencyWeight,
                MinRelevanceThreshold = Config.Context.MinRelevanceThreshold,
                MaxConversationTurns = Config.Context.MaxConversationTurns
            }
        },
        SectionKey.Scheduler => new AdminConfigPatchRequest
        {
            Scheduler = new SchedulerPatch
            {
                Enabled = Config!.Scheduler.Enabled,
                WikiMaintenanceCron = Config.Scheduler.WikiMaintenanceCron
            }
        },
        SectionKey.Routing => new AdminConfigPatchRequest
        {
            Routing = new RoutingPatch
            {
                Enabled = Config!.Routing.Enabled,
                ShadowMode = Config.Routing.ShadowMode,
                SmallAlias = Config.Routing.SmallAlias,
                MediumAlias = Config.Routing.MediumAlias,
                LargeAlias = Config.Routing.LargeAlias,
                DailyPaidRequestSoftLimit = Config.Routing.DailyPaidRequestSoftLimit,
                DailyPaidRequestHardLimit = Config.Routing.DailyPaidRequestHardLimit
            }
        },
        _ => new AdminConfigPatchRequest()
    };

    private static string MaskSecret(string value)
    {
        if (string.IsNullOrEmpty(value) || value.Length < 8)
            return "***";
        return value[..4] + new string('*', value.Length - 4);
    }

    private enum SectionKey { LiteLlm, Qdrant, Signal, Unstructured, Wiki, Context, Scheduler, Routing }

    private sealed class SaveResult
    {
        public bool Success { get; init; }
        public List<ConfigChange>? Changes { get; init; }
        public string? ErrorMessage { get; init; }
    }

    // ── View Models ───────────────────────────────────────────────────────────

    private sealed class SettingsVm
    {
        public LiteLlmVm LiteLlm { get; init; } = new();
        public QdrantVm Qdrant { get; init; } = new();
        public SignalVm Signal { get; init; } = new();
        public UnstructuredVm Unstructured { get; init; } = new();
        public WikiVm Wiki { get; init; } = new();
        public ContextVm Context { get; init; } = new();
        public SchedulerVm Scheduler { get; init; } = new();
        public RoutingVm Routing { get; init; } = new();
    }

    private sealed class LiteLlmVm
    {
        public string BaseUrl { get; set; } = "";
        public string ApiKey { get; set; } = "";
        public string DefaultModel { get; set; } = "";
        public string EmbeddingModel { get; set; } = "";
        public int ContextWindowTokens { get; set; }
    }

    private sealed class QdrantVm
    {
        public string Host { get; set; } = "";
        public int Port { get; set; }
        public string CollectionName { get; set; } = "";
        public int EmbeddingDimension { get; set; }
    }

    private sealed class SignalVm
    {
        public string CliPath { get; set; } = "";
        public string Account { get; set; } = "";
        public bool Enabled { get; set; }
        public string DaemonBaseUrl { get; set; } = "";
        public string AllowedSendersInput { get; set; } = "";
    }

    private sealed class UnstructuredVm
    {
        public bool Enabled { get; set; }
        public string BaseUrl { get; set; } = "";
        public int TimeoutSeconds { get; set; }
    }

    private sealed class WikiVm
    {
        public string BasePath { get; set; } = "";
        public int MaxFactsPerEntry { get; set; }
        public int StaleFactDays { get; set; }
        public double MinConfidenceThreshold { get; set; }
    }

    private sealed class ContextVm
    {
        public double SemanticSimilarityWeight { get; set; }
        public double RecencyDecayWeight { get; set; }
        public double DimensionMatchWeight { get; set; }
        public double InteractionFrequencyWeight { get; set; }
        public double MinRelevanceThreshold { get; set; }
        public int MaxConversationTurns { get; set; }
    }

    private sealed class SchedulerVm
    {
        public bool Enabled { get; set; }
        public string WikiMaintenanceCron { get; set; } = "";
    }

    private sealed class RoutingVm
    {
        public bool Enabled { get; set; }
        public bool ShadowMode { get; set; }
        public string SmallAlias { get; set; } = "";
        public string MediumAlias { get; set; } = "";
        public string LargeAlias { get; set; } = "";
        public int DailyPaidRequestSoftLimit { get; set; }
        public int DailyPaidRequestHardLimit { get; set; }
    }
}


