@page "/login"
@using System.Diagnostics.CodeAnalysis
@using Microsoft.AspNetCore.WebUtilities
@attribute [ExcludeFromCodeCoverage]
@inject NavigationManager Nav

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <LeanKernelIcon Name="logo" Class="LeanKernel-logo" />
            <h1>LeanKernel ACCESS</h1>
            <p class="login-subtitle">Authenticate with your admin passcode</p>
        </div>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="login-error" role="alert">@ErrorMessage</div>
        }

        <form method="post" action="/api/auth/login-form" class="login-form">
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />
            <div class="login-field">
            <label for="passcode-input" class="login-label">Passcode</label>
                <input id="passcode-input"
                        name="passcode"
                        type="password"
                        placeholder="Passcode"
                        autocomplete="current-password"
                        autofocus
                        aria-label="Passcode" />
            <p class="login-help">Use your admin passcode to unlock dashboard access.</p>
            </div>
            <button type="submit" class="login-button">Login</button>
        </form>
    </div>
</div>

@code {
    private string? ErrorMessage { get; set; }
    private string ReturnUrl { get; set; } = "/";

    protected override void OnInitialized()
    {
        var uri = new Uri(Nav.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        var returnUrl = query.TryGetValue("returnUrl", out var returnUrlValue)
            ? returnUrlValue.ToString()
            : "/";
        ReturnUrl = string.IsNullOrWhiteSpace(returnUrl) ? "/" : returnUrl;
        var error = query.TryGetValue("error", out var errorValue) ? errorValue.ToString() : null;
        if (!string.IsNullOrWhiteSpace(error))
        {
            ErrorMessage = error switch
            {
                "invalid_passcode" => "Invalid passcode. Try again.",
                "not_configured" => "Passcode not configured. Complete onboarding first.",
                "auth_disabled" => "Authentication is disabled.",
                _ => "Authentication failed."
            };
        }
    }
}
