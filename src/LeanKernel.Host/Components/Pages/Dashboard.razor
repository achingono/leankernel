@page "/"
@using System.Text.Json
@inject HttpClient Http
@inject NavigationManager Nav

<div class="page-header">
    <h1><span class="text-neon">◆</span> Dashboard</h1>
    <p class="subtitle">System overview and health status</p>
</div>

<!-- Stats Grid -->
<div class="stats-grid stagger-in">
    <div class="glass-card stat-card">
        <div class="stat-value">@Stats?.Uptime</div>
        <div class="stat-label">Uptime</div>
    </div>
    <div class="glass-card stat-card">
        <div class="stat-value">@Stats?.Sessions?.Total</div>
        <div class="stat-label">Sessions</div>
    </div>
    <div class="glass-card stat-card">
        <div class="stat-value">@Stats?.Wiki?.TotalEntries</div>
        <div class="stat-label">Wiki Entries</div>
    </div>
    <div class="glass-card stat-card">
        <div class="stat-value">@Stats?.Wiki?.TotalFacts</div>
        <div class="stat-label">Facts</div>
    </div>
    <div class="glass-card stat-card">
        <div class="stat-value">@(Stats?.Environment?.ProcessMemoryMb.ToString("F0") ?? "—")MB</div>
        <div class="stat-label">Memory</div>
    </div>
    <div class="glass-card stat-card">
        <div class="stat-value">
            <span class="status-badge status-healthy">● Healthy</span>
        </div>
        <div class="stat-label">Status</div>
    </div>
</div>

<!-- System Info -->
<div class="content-grid stagger-in">
    <div class="glass-card">
        <h3 class="text-cyan" style="margin-bottom: 1rem;">System</h3>
        <div class="diagnostic-panel" style="border: none; background: transparent; padding: 0;">
            <div class="diagnostic-row">
                <span class="diagnostic-label">Model</span>
                <span class="diagnostic-value">@Stats?.Config?.Model</span>
            </div>
            <div class="diagnostic-row">
                <span class="diagnostic-label">Context Window</span>
                <span class="diagnostic-value">@(Stats?.Config?.ContextWindow.ToString("N0")) tokens</span>
            </div>
            <div class="diagnostic-row">
                <span class="diagnostic-label">.NET</span>
                <span class="diagnostic-value">@Stats?.Environment?.DotnetVersion</span>
            </div>
            <div class="diagnostic-row">
                <span class="diagnostic-label">Scheduler</span>
                <span class="diagnostic-value">@(Stats?.Config?.SchedulerEnabled == true ? "On" : "Off")</span>
            </div>
            <div class="diagnostic-row">
                <span class="diagnostic-label">Signal</span>
                <span class="diagnostic-value">@(Stats?.Config?.SignalEnabled == true ? "On" : "Off")</span>
            </div>
        </div>
    </div>

    <div class="glass-card">
        <h3 class="text-cyan" style="margin-bottom: 1rem;">Wiki Dimensions</h3>
        @if (Dimensions is not null)
        {
            <div class="diagnostic-panel" style="border: none; background: transparent; padding: 0;">
                @foreach (var dim in Dimensions)
                {
                    <div class="diagnostic-row">
                        <span class="diagnostic-label" style="text-transform: uppercase;">@dim.Dimension</span>
                        <span class="diagnostic-value">@dim.Count entries · @dim.TotalFacts facts</span>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private StatsResponse? Stats;
    private List<DimensionSummary>? Dimensions;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Stats = await Http.GetFromJsonAsync<StatsResponse>("api/stats");
            Dimensions = await Http.GetFromJsonAsync<List<DimensionSummary>>("api/wiki/dimensions");
        }
        catch { /* API might not be ready */ }
    }

    private record StatsResponse
    {
        public string? Uptime { get; init; }
        public SessionStats? Sessions { get; init; }
        public WikiStats? Wiki { get; init; }
        public ConfigStats? Config { get; init; }
        public EnvStats? Environment { get; init; }
    }

    private record SessionStats { public int Total { get; init; } }
    private record WikiStats { public int TotalEntries { get; init; } public int TotalFacts { get; init; } }
    private record ConfigStats
    {
        public string? Model { get; init; }
        public int ContextWindow { get; init; }
        public bool SchedulerEnabled { get; init; }
        public bool SignalEnabled { get; init; }
    }
    private record EnvStats { public string? DotnetVersion { get; init; } public double ProcessMemoryMb { get; init; } }
    private record DimensionSummary { public string? Dimension { get; init; } public int Count { get; init; } public int TotalFacts { get; init; } }
}
