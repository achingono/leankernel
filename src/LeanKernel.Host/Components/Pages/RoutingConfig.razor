@page "/admin/routing-config"
@using System.Diagnostics.CodeAnalysis
@using System.Net.Http.Json
@using LeanKernel.Host.Models.Routing
@attribute [ExcludeFromCodeCoverage]
@inject HttpClient Http
@rendermode InteractiveServer

<div class="page-header">
    <h1><span class="text-neon"><LeanKernelIcon Name="routing" /></span> Routing Config</h1>
    <p class="subtitle">Manage providers, models, route lanes, and aliases</p>
</div>

<!-- View toggle -->
<div class="dimension-tabs" style="margin-bottom: 1.25rem;">
    <button class="dimension-tab @(_viewMode == "structured" ? "active" : "")" @onclick='() => SwitchView("structured")'>
        Structured View
    </button>
    <button class="dimension-tab @(_viewMode == "yaml" ? "active" : "")" @onclick='() => SwitchView("yaml")'>
        Raw YAML
    </button>
</div>

@if (_loadError != null)
{
    <div class="glass-card border-warning" style="margin-bottom: 1rem;">
        <p class="text-warning m-0">⚠ Failed to load routing config: @_loadError</p>
    </div>
}

@if (_viewMode == "yaml")
{
    <!-- Raw YAML editor -->
    <div class="glass-card" style="margin-bottom: 1rem;">
        <div class="section-header">
            <div>
                <h3 class="text-cyan m-0">LiteLLM config.yaml</h3>
                <p class="text-muted text-xs">
                    Edit the raw YAML configuration. Changes are validated and applied immediately.
                </p>
            </div>
            <div class="flex-row">
                <button class="btn-ghost btn-sm" @onclick="ReloadRawYaml" disabled="@_yamlBusy">Reload</button>
                <button class="btn-primary btn-sm" @onclick="SaveRawYaml" disabled="@(_yamlBusy || string.IsNullOrEmpty(_rawYaml))">
                    @(_yamlBusy ? "Saving…" : "Save YAML")
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_yamlSaveError))
        {
            <p class="text-danger text-sm">⚠ @_yamlSaveError</p>
        }
        @if (_yamlSaveSuccess)
        {
            <p class="text-neon text-sm">✓ YAML saved successfully.</p>
        }

        <div class="monaco-container">
            <MonacoEditor @ref="_yamlEditor"
                          Language="yaml"
                          Value="@_rawYaml"
                          ValueChanged="v => _rawYaml = v"
                          Height="600px" />
        </div>
    </div>
}

@if (_viewMode == "structured" && _saveResult != null)
{
    <div class="glass-card @(_saveResult.HasErrors ? "border-warning" : "border-success")" style="margin-bottom: 1rem;">
        @if (_saveResult.Saved)
        {
        <p class="text-cyan m-0">✓ Configuration saved successfully.</p>
        }
        else if (_saveResult.IsDryRun && !_saveResult.HasErrors)
        {
        <p class="text-cyan m-0">✓ Dry-run complete — no validation errors.</p>
        }
        else if (_saveResult.HasErrors)
        {
        <p class="text-warning m-0">⚠ Validation errors prevented save.</p>
        }

        @if (_saveResult.ValidationErrors.Count > 0)
        {
            <ul class="text-sm" style="margin: 0.25rem 0 0; padding-left: 1.5rem;">
                @foreach (var e in _saveResult.ValidationErrors)
                {
                    <li class="@(e.Severity == "error" ? "text-warning" : "text-muted")">[@e.Severity] @e.Message</li>
                }
            </ul>
        }

        @if (!string.IsNullOrEmpty(_saveResult.Diff))
        {
            <details style="margin-top: 0.75rem;">
                <summary class="text-muted text-sm" style="cursor: pointer;">Show YAML diff</summary>
                <pre style="margin-top: 0.5rem; font-size: 0.75rem; overflow-x: auto; background: rgba(0,0,0,0.3); padding: 0.75rem; border-radius: 4px;">@_saveResult.Diff</pre>
            </details>
        }
    </div>
}

@if (_viewMode == "structured" && _loading)
{
    <div class="glass-card card-center">
        <p class="text-muted">Loading routing configuration...</p>
    </div>
}
else if (_viewMode == "structured" && _response != null)
{
    var config = _response.Config;

    <!-- Validation summary -->
    @if (_response.ValidationErrors.Count > 0)
    {
        <div class="glass-card border-warning" style="margin-bottom: 1rem;">
        <p class="text-warning m-0"><strong>Validation Issues</strong></p>
            <ul class="text-sm" style="margin: 0; padding-left: 1.5rem;">
                @foreach (var e in _response.ValidationErrors)
                {
                    <li class="@(e.Severity == "error" ? "text-warning" : "text-muted")">[@e.Severity] @e.Message</li>
                }
            </ul>
        </div>
    }

    <div class="content-grid stagger-in">

        <!-- Provider Inventory -->
        <div class="glass-card" style="grid-column: 1 / -1;">
            <div class="section-header">
                <h3 class="text-cyan">Provider Inventory</h3>
                @if (config.Providers.Count == 0)
                {
                    <button class="btn-ghost btn-sm" @onclick='() => SwitchView("yaml")'>Edit YAML &#x2192;</button>
                }
            </div>
            @if (config.Providers.Count == 0)
            {
                <div class="empty-hint">
                    <p class="text-muted m-0" style="margin-bottom: 0.5rem;">No providers configured.</p>
                    <p class="text-muted text-sm">
                        Switch to <button class="btn-link" @onclick='() => SwitchView("yaml")'>Raw YAML</button> to add provider configuration.
                    </p>
                </div>
            }
            @foreach (var (providerName, provider) in config.Providers)
            {
                <div class="glass-card">
                    <div class="flex-row" style="margin-bottom: 0.5rem;">
                        <strong>@providerName</strong>
                        @if (!string.IsNullOrEmpty(provider.LitellmProvider))
                        {
                            <span class="badge">via @provider.LitellmProvider</span>
                        }
                    </div>

                    <!-- Key Slots -->
                    <div style="margin-bottom: 0.5rem;">
                        <span class="setting-label text-xs">Key Slots</span>
                        <div class="flex-row" style="margin-top: 0.25rem;">
                            @foreach (var ks in GetKeyStatuses(providerName))
                            {
                                <span class="badge @(ks.Configured ? "badge-success" : "badge-warning")" title="@ks.EnvVar">
                                    @ks.SlotName @(ks.Configured ? "✓" : "✗")
                                    @if (!ks.Enabled) { <span style="opacity: 0.6;"> (disabled)</span> }
                                </span>
                            }
                            @if (!GetKeyStatuses(providerName).Any())
                            {
                <span class="text-muted text-xs">No key slots</span>
                            }
                        </div>
                    </div>

                    <!-- Model Catalog -->
                    <div>
                        <span class="setting-label text-xs">Models</span>
                        <div style="overflow-x: auto; margin-top: 0.25rem;">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Name</th>
                                        <th>Mode</th>
                                        <th class="text-right">Max Tokens</th>
                                        <th class="text-right">Dimensions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var model in provider.Models)
                                    {
                                        <tr>
                                            <td class="col-id">@model.Id</td>
                                            <td class="col-muted">@model.Name</td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(model.Mode))
                                                {
                                                    <span class="badge">@model.Mode</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">chat</span>
                                                }
                                            </td>
                                            <td class="text-right">@(model.MaxTokens > 0 ? model.MaxTokens.ToString("N0") : "—")</td>
                                            <td class="text-right">@(model.Dimensions.HasValue ? model.Dimensions.Value.ToString() : "—")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Route Lanes -->
        <div class="glass-card" style="grid-column: 1 / -1;">
            <div class="section-header">
                <h3 class="text-cyan">Route Lanes</h3>
                <div class="flex-row">
                    <button class="btn-secondary btn-sm" @onclick="() => DryRun()" disabled="@_saving">Validate</button>
                    <button class="btn-primary btn-sm" @onclick="() => Save()" disabled="@_saving">Save Config</button>
                </div>
            </div>

            @{
                var chatLanes = config.Routes.Where(r => !r.Key.StartsWith("embedding")).OrderBy(r => r.Key).ToList();
                var embeddingLanes = config.Routes.Where(r => r.Key.StartsWith("embedding")).OrderBy(r => r.Key).ToList();
            }

            @if (chatLanes.Any())
            {
                <h4 class="text-muted text-sm">Chat Lanes</h4>
                @foreach (var (lane, entries) in chatLanes)
                {
                    <div style="margin-bottom: 1.25rem;">
                        <div class="flex-row" style="margin-bottom: 0.5rem;">
                            <strong class="text-cyan">@lane</strong>
                            <span class="badge">@entries.Count route(s)</span>
                        </div>
                        <div style="overflow-x: auto;">
                            <table class="data-table">
                                <thead><tr><th>Order</th><th>Provider</th><th>Model</th><th>Key Slots</th></tr></thead>
                                <tbody>
                                    @foreach (var entry in entries.OrderBy(e => e.Order))
                                    {
                                        <tr>
                                            <td class="col-muted">@entry.Order</td>
                                            <td>@entry.Provider</td>
                                            <td class="col-id">@entry.Model</td>
                                            <td class="col-keys">@string.Join(", ", entry.Keys)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            }

            @if (embeddingLanes.Any())
            {
                <h4 class="text-muted text-sm">Embedding Lanes</h4>
                @foreach (var (lane, entries) in embeddingLanes)
                {
                    <div style="margin-bottom: 1.25rem;">
                        <div class="flex-row" style="margin-bottom: 0.5rem;">
                            <strong class="text-violet">@lane</strong>
                            <span class="badge">embedding</span>
                        </div>
                        <div style="overflow-x: auto;">
                            <table class="data-table">
                                <thead><tr><th>Order</th><th>Provider</th><th>Model</th><th>Key Slots</th></tr></thead>
                                <tbody>
                                    @foreach (var entry in entries.OrderBy(e => e.Order))
                                    {
                                        <tr>
                                            <td class="col-muted">@entry.Order</td>
                                            <td>@entry.Provider</td>
                                            <td class="col-violet">@entry.Model</td>
                                            <td class="col-keys">@string.Join(", ", entry.Keys)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- Aliases -->
        <div class="glass-card">
            <h3 class="text-cyan" style="margin-bottom: 1rem;">Alias Mappings</h3>
            @if (config.Aliases.Count == 0)
            {
                <p class="text-muted">No aliases defined.</p>
            }
            else
            {
                <div class="diagnostic-panel">
                    @foreach (var (alias, target) in config.Aliases)
                    {
                        <div class="diagnostic-row">
                            <span class="diagnostic-label" style="font-family: monospace;">@alias</span>
                            <span class="diagnostic-value" style="color: #00d4ff;">→ @target</span>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Model Limit Drift -->
        <div class="glass-card" style="grid-column: 1 / -1;">
            <div class="section-header">
                <h3 class="text-cyan">Model Limit Drift</h3>
                <button class="btn-secondary btn-sm" @onclick="PreviewDrift" disabled="@_driftLoading">
                    @if (_driftLoading) { <span>Checking…</span> } else { <span>Preview Drift</span> }
                </button>
            </div>
            <p class="text-muted text-sm">
                Checks live provider APIs (Groq, Gemini, Azure) and compares max_tokens and context_window against your config.
                Requires provider API keys to be available in the environment.
            </p>

            @if (_driftError != null)
            {
                <p class="text-warning">⚠ @_driftError</p>
            }
            else if (_driftReport != null)
            {
                @if (_driftReport.TotalChanges == 0)
                {
                    <p class="text-cyan">✓ No drift detected — all model limits are up-to-date.</p>
                }
                else
                {
                    <p class="text-muted text-sm">
                        @_driftReport.TotalChanges field(s) differ from live provider metadata.
                        Save the routing config after reviewing to apply.
                    </p>
                    <div style="overflow-x: auto;">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Provider</th>
                                    <th>Model</th>
                                    <th>Field</th>
                                    <th class="text-right">Current</th>
                                    <th class="text-right">Live</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in _driftReport.Changes)
                                {
                                    <tr>
                                        <td>@entry.Provider</td>
                                        <td class="col-id">@entry.ModelId</td>
                                        <td class="col-muted">@entry.Field</td>
                                        <td class="text-right col-muted">@FormatLimit(entry.OldValue)</td>
                                        <td class="text-right col-violet">@FormatLimit(entry.NewValue)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                <p class="text-muted text-xs" style="margin-top: 0.5rem;">Checked at @_driftReport.GeneratedAt</p>
            }
        </div>

        <!-- Router Policy -->
        <div class="glass-card">
            <h3 class="text-cyan">Router Policy</h3>
            <div class="diagnostic-panel">
                <div class="diagnostic-row">
                    <span class="diagnostic-label">Strategy</span>
                    <span class="diagnostic-value">@config.Router.RoutingStrategy</span>
                </div>
                <div class="diagnostic-row">
                    <span class="diagnostic-label">Pre-call Checks</span>
                    <span class="diagnostic-value">@config.Router.EnablePreCallChecks</span>
                </div>
                <div class="diagnostic-row">
                    <span class="diagnostic-label">Retries</span>
                    <span class="diagnostic-value">@config.Router.NumRetries</span>
                </div>
                <div class="diagnostic-row">
                    <span class="diagnostic-label">Retry After</span>
                    <span class="diagnostic-value">@config.Router.RetryAfter s</span>
                </div>
                <div class="diagnostic-row">
                    <span class="diagnostic-label">Timeout</span>
                    <span class="diagnostic-value">@config.Router.Timeout s</span>
                </div>
            </div>
        </div>

    </div>
}  @* end structured view *@

@code {
    private bool _loading = true;
    private string? _loadError;
    private bool _saving;
    private RoutingConfigResponse? _response;
    private SaveDisplayResult? _saveResult;
    private bool _driftLoading;
    private string? _driftError;
    private DriftReport? _driftReport;
    private string _viewMode = "structured";
    private string _rawYaml = "";
    private bool _yamlBusy;
    private string? _yamlSaveError;
    private bool _yamlSaveSuccess;
    private MonacoEditor? _yamlEditor;

    protected override async Task OnInitializedAsync()
    {
        await LoadConfig();
    }

    private async Task SwitchView(string mode)
    {
        _viewMode = mode;
        if (mode == "yaml" && string.IsNullOrEmpty(_rawYaml))
            await ReloadRawYaml();
    }

    private async Task ReloadRawYaml()
    {
        _yamlBusy = true;
        _yamlSaveError = null;
        _yamlSaveSuccess = false;
        try
        {
            var result = await Http.GetFromJsonAsync<RawYamlResponse>("/api/routing-config/raw");
            _rawYaml = result?.Yaml ?? "";
            if (_yamlEditor is not null)
                await _yamlEditor.SetValueAsync(_rawYaml);
        }
        catch (Exception ex)
        {
            _yamlSaveError = $"Failed to load YAML: {ex.Message}";
        }
        finally
        {
            _yamlBusy = false;
        }
    }

    private async Task SaveRawYaml()
    {
        _yamlBusy = true;
        _yamlSaveError = null;
        _yamlSaveSuccess = false;
        try
        {
            if (_yamlEditor is not null)
                _rawYaml = await _yamlEditor.GetValueAsync();

            var response = await Http.PutAsJsonAsync("/api/routing-config/raw", new { yaml = _rawYaml });
            if (response.IsSuccessStatusCode)
            {
                _yamlSaveSuccess = true;
                await LoadConfig();
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<RawYamlErrorResponse>();
                _yamlSaveError = error?.Error ?? $"Save failed ({(int)response.StatusCode})";
            }
        }
        catch (Exception ex)
        {
            _yamlSaveError = ex.Message;
        }
        finally
        {
            _yamlBusy = false;
        }
    }

    private async Task LoadConfig()
    {
        _loading = true;
        _loadError = null;
        try
        {
            _response = await Http.GetFromJsonAsync<RoutingConfigResponse>("/api/routing-config");
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task DryRun()
    {
        if (_response is null) return;
        await SendSave(dryRun: true);
    }

    private async Task Save()
    {
        if (_response is null) return;
        await SendSave(dryRun: false);
    }

    private async Task SendSave(bool dryRun)
    {
        if (_response is null) return;
        _saving = true;
        _saveResult = null;

        try
        {
            var request = new RoutingConfigSaveRequest { Config = _response.Config, DryRun = dryRun };
            var response = await Http.PutAsJsonAsync("/api/routing-config", request);
            var result = await response.Content.ReadFromJsonAsync<RoutingConfigSaveResponse>();

            _saveResult = new SaveDisplayResult
            {
                Saved = result?.Saved ?? false,
                IsDryRun = dryRun,
                Diff = result?.YamlDiff ?? "",
                ValidationErrors = result?.ValidationErrors ?? [],
                HasErrors = result?.ValidationErrors.Any(e => e.Severity == "error") ?? false
            };

            if (result?.Saved == true)
                await LoadConfig();
        }
        catch (Exception ex)
        {
            _saveResult = new SaveDisplayResult
            {
                HasErrors = true,
                ValidationErrors = [new RoutingValidationError { Code = "EXCEPTION", Message = ex.Message, Severity = "error" }]
            };
        }
        finally
        {
            _saving = false;
        }
    }

    private IEnumerable<ProviderKeyStatus> GetKeyStatuses(string providerName)
        => _response?.KeyStatuses.Where(k => k.Provider == providerName) ?? [];

    private async Task PreviewDrift()
    {
        _driftLoading = true;
        _driftError = null;
        _driftReport = null;
        try
        {
            _driftReport = await Http.GetFromJsonAsync<DriftReport>("/api/model-limit-drift");
            if (_driftReport?.Error is not null)
            {
                _driftError = _driftReport.Error;
                _driftReport = null;
            }
        }
        catch (Exception ex)
        {
            _driftError = ex.Message;
        }
        finally
        {
            _driftLoading = false;
        }
    }

    private static string FormatLimit(double? value) =>
        value.HasValue ? ((long)value.Value).ToString("N0") : "—";

    private sealed class SaveDisplayResult
    {
        public bool Saved { get; init; }
        public bool IsDryRun { get; init; }
        public string Diff { get; init; } = "";
        public List<RoutingValidationError> ValidationErrors { get; init; } = [];
        public bool HasErrors { get; init; }
    }

    private sealed class RawYamlResponse
    {
        public string Yaml { get; init; } = "";
    }

    private sealed class RawYamlErrorResponse
    {
        public string? Error { get; init; }
    }
}
