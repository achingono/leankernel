@page "/chat"
@using System.Diagnostics.CodeAnalysis
@using LeanKernel.Core.Interfaces
@using LeanKernel.Core.Models
@attribute [ExcludeFromCodeCoverage]
@inject IThinkerService Thinker
@inject ISessionStore SessionStore
@rendermode InteractiveServer

<div class="page-header">
    <h1><span class="text-neon"><LeanKernelIcon Name="chat" /></span> Chat</h1>
    <p class="subtitle">Conversation interface with tool diagnostics</p>
</div>

<div class="chat-container">
    <!-- Session selector -->
    <div style="display: flex; gap: 0.75rem; margin-bottom: 1rem; align-items: center;">
        <select class="setting-input" style="max-width: 300px;" @onchange="OnSessionChanged">
            <option value="">New Conversation</option>
            @foreach (var session in Sessions)
            {
                <option value="@session" selected="@(session == CurrentSession)">@session</option>
            }
        </select>
        <button class="btn-ghost" @onclick="LoadSessions">
            <LeanKernelIcon Name="refresh" Class="button-icon" /> Refresh
        </button>
    </div>

    <!-- Messages -->
    <div class="chat-messages glass-card" style="flex: 1; overflow-y: auto;" @ref="messagesContainer">
        @foreach (var msg in Messages)
        {
            <div>
                <div class="chat-bubble @msg.Role">
                    @msg.Content
                </div>
                @if (msg.Role == "assistant")
                {
                    <button class="diagnostic-toggle" @onclick="() => msg.ShowDiagnostics = !msg.ShowDiagnostics">
                        @if (msg.ShowDiagnostics)
                        {
                            <LeanKernelIcon Name="chevron-down" Class="button-icon" /> <span>Hide diagnostics</span>
                        }
                        else
                        {
                            <LeanKernelIcon Name="chevron-right" Class="button-icon" /> <span>Show diagnostics</span>
                        }
                    </button>
                    @if (msg.ShowDiagnostics)
                    {
                        <div class="diagnostic-panel">
                            <div class="diagnostic-row">
                                <span class="diagnostic-label">Timestamp</span>
                                <span class="diagnostic-value">@msg.Timestamp.ToString("HH:mm:ss.fff")</span>
                            </div>
                            <div class="diagnostic-row">
                                <span class="diagnostic-label">Session</span>
                                <span class="diagnostic-value">@(CurrentSession ?? "web")</span>
                            </div>
                            <div class="diagnostic-row">
                                <span class="diagnostic-label">Compacted</span>
                                <span class="diagnostic-value">@msg.IsCompacted</span>
                            </div>
                        </div>
                    }
                }
            </div>
        }

        @if (IsLoading)
        {
            <div class="chat-bubble assistant" style="opacity: 0.6;">
                <span class="text-neon">●</span> Thinking...
            </div>
        }
    </div>

    <!-- Input -->
    <div class="chat-input-area">
        <input class="chat-input"
               @bind="InputText"
               @bind:event="oninput"
               @onkeydown="OnKeyDown"
               placeholder="Type a message..."
               disabled="@IsLoading" />
        <button class="btn-primary" @onclick="SendMessage" disabled="@(IsLoading || string.IsNullOrWhiteSpace(InputText))">
            Send
        </button>
    </div>
</div>

@code {
    private List<ChatMessage> Messages = [];
    private List<string> Sessions = [];
    private string? CurrentSession;
    private string InputText = "";
    private bool IsLoading;
    private ElementReference messagesContainer;

    protected override async Task OnInitializedAsync()
    {
        await LoadSessions();
    }

    private async Task LoadSessions()
    {
        try
        {
            var list = await SessionStore.ListSessionsAsync(CancellationToken.None);
            Sessions = [.. list];
        }
        catch { }
    }

    private async Task OnSessionChanged(ChangeEventArgs e)
    {
        CurrentSession = e.Value?.ToString();
        Messages.Clear();

        if (!string.IsNullOrEmpty(CurrentSession))
        {
            try
            {
                var turns = await SessionStore.GetHistoryAsync(CurrentSession, CancellationToken.None);
                Messages = turns.Select(t => new ChatMessage
                {
                    Role = t.Role ?? "user",
                    Content = t.Content ?? "",
                    Timestamp = t.Timestamp,
                    IsCompacted = t.IsCompacted
                }).ToList();
            }
            catch { }
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendMessage();
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(InputText) || IsLoading) return;

        var userMsg = InputText.Trim();
        InputText = "";

        Messages.Add(new ChatMessage
        {
            Role = "user",
            Content = userMsg,
            Timestamp = DateTimeOffset.UtcNow
        });

        IsLoading = true;
        StateHasChanged();
        // Yield once so the loading indicator flushes to the UI before processing begins.
        await Task.Yield();

        try
        {
            var message = new LeanKernelMessage
            {
                Id = Guid.NewGuid().ToString("N"),
                ChannelId = "web",
                SenderId = "web-user",
                Content = userMsg,
                Timestamp = DateTimeOffset.UtcNow
            };

            var response = await Thinker.ProcessAsync(message, CancellationToken.None);

            Messages.Add(new ChatMessage
            {
                Role = "assistant",
                Content = response,
                Timestamp = DateTimeOffset.UtcNow
            });
        }
        catch (Exception ex)
        {
            Messages.Add(new ChatMessage
            {
                Role = "assistant",
                Content = $"Error: {ex.Message}",
                Timestamp = DateTimeOffset.UtcNow
            });
        }
        finally
        {
            IsLoading = false;
        }
    }

    private class ChatMessage
    {
        public string Role { get; set; } = "";
        public string Content { get; set; } = "";
        public DateTimeOffset Timestamp { get; set; }
        public bool IsCompacted { get; set; }
        public bool ShowDiagnostics { get; set; }
    }
}
