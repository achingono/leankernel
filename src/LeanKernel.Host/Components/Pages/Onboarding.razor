@page "/onboarding"
@using System.Diagnostics.CodeAnalysis
@attribute [ExcludeFromCodeCoverage]
@inject HttpClient Http
@inject NavigationManager Nav
@rendermode InteractiveServer

<div class="page-header">
    <h1><span class="text-neon"><LeanKernelIcon Name="onboarding" /></span> Onboarding</h1>
    <p class="subtitle">One-shot setup to get LeanKernel configured and operational</p>
</div>

@if (IsLoading)
{
    <div class="glass-card card-center">
        <p class="text-muted">Loading onboarding state...</p>
    </div>
}
else if (Completed)
{
    <div class="glass-card stagger-in">
        <h3 class="text-neon">&#x2713; Onboarding complete</h3>
        <p class="text-muted">@StatusMessage</p>
        <button class="btn-primary" @onclick='() => Nav.NavigateTo("/")'>Enter Dashboard</button>
    </div>
}
else
{
    <!-- Stepper header -->
    <div class="onboarding-stepper stagger-in">
        @for (var i = 0; i < Steps.Length; i++)
        {
            var idx = i;
            var stepState = idx < CurrentStep ? "done" : idx == CurrentStep ? "active" : "pending";
            <button class="stepper-item @stepState" @onclick="() => GoToStep(idx)"
                 aria-label="Step @(idx + 1): @Steps[idx]" type="button">
                <div class="stepper-circle">
                    @if (idx < CurrentStep)
                    {
                        <span>&#x2713;</span>
                    }
                    else
                    {
                        <span>@(idx + 1)</span>
                    }
                </div>
                <span class="stepper-label">@Steps[idx]</span>
                @if (idx < Steps.Length - 1)
                {
                    <div class="stepper-line @(idx < CurrentStep ? "done" : "")"></div>
                }
            </button>
        }
    </div>

    <!-- Step content -->
    <div class="glass-card stagger-in step-card">

        @if (CurrentStep == 0)
        {
            <div class="setting-group">
                <h3 class="text-cyan">LiteLLM</h3>
                <p class="text-muted text-sm">Configure the LiteLLM model proxy that routes requests to your AI providers.</p>
                <div class="setting-row">
                    <span class="setting-label">Base URL</span>
                    <input class="setting-input" @bind="Draft.LiteLlm.BaseUrl" />
                </div>
                <div class="setting-row">
                    <span class="setting-label">API Key</span>
                    <input class="setting-input" type="password" @bind="Draft.LiteLlm.ApiKey" />
                </div>
                <div class="setting-row">
                    <span class="setting-label">Default Model</span>
                    <input class="setting-input" @bind="Draft.LiteLlm.DefaultModel" />
                </div>
                <div class="setting-row">
                    <span class="setting-label">Embedding Model</span>
                    <input class="setting-input" @bind="Draft.LiteLlm.EmbeddingModel" />
                </div>
                <div class="setting-row">
                    <span class="setting-label">Context Window</span>
                    <input class="setting-input" type="number" min="1024" step="1024" @bind="Draft.LiteLlm.ContextWindowTokens" />
                </div>
            </div>
        }

        @if (CurrentStep == 1)
        {
            <div class="setting-group">
                <h3 class="text-cyan">Vector + Wiki</h3>
                <p class="text-muted text-sm">Set up Qdrant vector storage for semantic memory and the wiki knowledge base path.</p>
                <div class="setting-row">
                    <span class="setting-label">Qdrant Host</span>
                    <input class="setting-input" @bind="Draft.Qdrant.Host" />
                </div>
                <div class="setting-row">
                    <span class="setting-label">Qdrant Port</span>
                    <input class="setting-input" type="number" min="1" @bind="Draft.Qdrant.Port" />
                </div>
                <div class="setting-row">
                    <span class="setting-label">Collection</span>
                    <input class="setting-input" @bind="Draft.Qdrant.CollectionName" />
                </div>
                <div class="setting-row">
                    <span class="setting-label">Embedding Dim</span>
                    <input class="setting-input" type="number" min="1" @bind="Draft.Qdrant.EmbeddingDimension" />
                </div>
                <div class="setting-row">
                    <span class="setting-label">Wiki Path</span>
                    <input class="setting-input text-mono" @bind="Draft.Wiki.BasePath" />
                </div>
            </div>
        }

        @if (CurrentStep == 2)
        {
            <div class="setting-group">
                <h3 class="text-cyan">Signal <span class="badge">optional</span></h3>
                <p class="text-muted text-sm">Enable the Signal messaging adapter to interact with the agent over Signal.</p>
                <div class="setting-row">
                    <span class="setting-label">Enabled</span>
                    <input type="checkbox" @bind="Draft.Signal.Enabled" />
                </div>
                <div class="setting-row">
                    <span class="setting-label">Account</span>
                    <input class="setting-input" @bind="Draft.Signal.Account" />
                </div>
                <div class="setting-row">
                    <span class="setting-label">CLI Path</span>
                    <input class="setting-input text-mono" @bind="Draft.Signal.CliPath" />
                </div>
            </div>
        }

        @if (CurrentStep == 3)
        {
            <div class="setting-group">
                <h3 class="text-cyan">Scheduler</h3>
                <p class="text-muted text-sm">Configure the background scheduler for automated wiki maintenance tasks.</p>
                <div class="setting-row">
                    <span class="setting-label">Enabled</span>
                    <input type="checkbox" @bind="Draft.Scheduler.Enabled" />
                </div>
                <div class="setting-row">
                    <span class="setting-label">Wiki Maintenance Cron</span>
                    <input class="setting-input text-mono" @bind="Draft.Scheduler.WikiMaintenanceCron" />
                </div>
            </div>
        }

        @if (CurrentStep == 4)
        {
            <div class="setting-group">
                <h3 class="text-cyan">Agent Rules <span class="badge">optional</span></h3>
                <p class="text-muted text-sm">Define engagement rules, autonomy scope, and time boundaries for your agent.</p>
                <button class="btn-primary btn-block" @onclick='() => Nav.NavigateTo("/onboarding/agents")'>
                    Configure Agent Rules &#x2192;
                </button>
            </div>
        }

        @if (CurrentStep == 5)
        {
            <div class="setting-group">
                <h3 class="text-cyan">Authentication</h3>
                <p class="text-muted text-sm">Set your admin passcode. This will be required to access LeanKernel after onboarding.</p>
                <div class="setting-row">
                    <span class="setting-label">Admin Passcode</span>
                    <input class="setting-input" type="password" @bind="Passcode" placeholder="Min 8 characters" />
                </div>
                <div class="setting-row">
                    <span class="setting-label">Confirm Passcode</span>
                    <input class="setting-input" type="password" @bind="PasscodeConfirm" placeholder="Repeat passcode" />
                </div>
                @if (!string.IsNullOrWhiteSpace(PasscodeError))
                {
                    <p class="text-danger text-sm">@PasscodeError</p>
                }
            </div>

            @if (Validation is not null)
            {
                <div style="margin-top: 1.5rem;">
                    <h4 class="text-cyan">Validation Results</h4>
                    @foreach (var vstep in Validation.Steps)
                    {
                        <div class="diagnostic-row">
                            <span class="diagnostic-label">@vstep.Step</span>
                            <span class="diagnostic-value">
                                <span class="status-badge @(vstep.Success ? "status-healthy" : "status-error")">
                                    @(vstep.Success ? "&#x25CF; PASS" : "&#x25CF; FAIL")
                                </span>
                                <span class="text-sm">@vstep.Message</span>
                            </span>
                        </div>
                    }
                </div>
            }
        }

        @if (!string.IsNullOrWhiteSpace(StatusMessage))
        {
            <p class="text-muted text-sm">@StatusMessage</p>
        }
        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <p class="text-danger text-sm">@ErrorMessage</p>
        }
    </div>

    <!-- Navigation controls -->
    <div class="glass-card">
        <div class="section-header" style="flex-wrap: wrap; gap: 0.75rem;">
            <button class="btn-ghost" @onclick="PrevStep" disabled="@(CurrentStep == 0 || IsBusy)">
                &#x2190; Back
            </button>
            <div class="flex-row">
                <button class="btn-ghost" @onclick="SaveDraft" disabled="@IsBusy">Save Draft</button>
                @if (CurrentStep < Steps.Length - 1)
                {
                    <button class="btn-primary" @onclick="NextStep" disabled="@IsBusy">Next &#x2192;</button>
                }
                else
                {
                    <button class="btn-ghost" @onclick="Validate" disabled="@IsBusy">Run Validation</button>
                    <button class="btn-accent" @onclick="Complete" disabled="@IsBusy">
                        Complete Onboarding &#x2713;
                    </button>
                }
            </div>
        </div>
    </div>
}

@code {
    private static readonly string[] Steps =
    [
        "LiteLLM",
        "Vector + Wiki",
        "Signal",
        "Scheduler",
        "Agent Rules",
        "Authentication"
    ];

    private bool IsLoading = true;
    private bool IsBusy;
    private bool Completed;
    private int CurrentStep;
    private string? StatusMessage;
    private string? ErrorMessage;
    private string Passcode = "";
    private string PasscodeConfirm = "";
    private string? PasscodeError;
    private OnboardingDraftDto Draft { get; set; } = new();
    private OnboardingValidationDto? Validation;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        IsLoading = true;
        ErrorMessage = null;
        try
        {
            var status = await Http.GetFromJsonAsync<OnboardingStatusDto>("api/onboarding/status");
            Completed = status?.Completed == true;

            var draft = await Http.GetFromJsonAsync<OnboardingDraftDto>("api/onboarding/draft");
            if (draft is not null)
                Draft = draft;

            StatusMessage = Completed
                ? $"Completed at {status?.CompletedAt?.ToLocalTime():yyyy-MM-dd HH:mm:ss}"
                : "Save your configuration, validate dependencies, then complete onboarding.";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to load onboarding state: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void GoToStep(int index)
    {
        // Allow navigation to completed steps or current step
        if (index <= CurrentStep)
            CurrentStep = index;
    }

    private void PrevStep()
    {
        if (CurrentStep > 0) CurrentStep--;
    }

    private async Task NextStep()
    {
        await RunBusyAsync(async () =>
        {
            if (!await SaveDraftInternal()) return;
            if (CurrentStep < Steps.Length - 1) CurrentStep++;
        });
    }

    private async Task SaveDraft()
    {
        await RunBusyAsync(SaveDraftInternal);
    }

    private async Task Validate()
    {
        await RunBusyAsync(async () =>
        {
            if (!await SaveDraftInternal())
                return;

            var response = await Http.PostAsync("api/onboarding/validate", content: null);
            if (!response.IsSuccessStatusCode)
            {
                ErrorMessage = $"Validation request failed ({(int)response.StatusCode})";
                return;
            }

            Validation = await response.Content.ReadFromJsonAsync<OnboardingValidationDto>();
            StatusMessage = Validation?.Success == true
                ? "All checks passed. You can complete onboarding."
                : "Some checks failed. Fix issues and retry.";
            ErrorMessage = null;
        });
    }

    private async Task Complete()
    {
        await RunBusyAsync(async () =>
        {
            PasscodeError = null;
            if (string.IsNullOrWhiteSpace(Passcode) || Passcode.Length < 8)
            {
                PasscodeError = "Passcode must be at least 8 characters.";
                ErrorMessage = "Please set an admin passcode before completing.";
                return;
            }
            if (Passcode != PasscodeConfirm)
            {
                PasscodeError = "Passcodes do not match.";
                ErrorMessage = "Please confirm your passcode.";
                return;
            }

            if (!await SaveDraftInternal())
                return;

            var response = await Http.PostAsync("api/onboarding/complete", content: null);
            var completion = await response.Content.ReadFromJsonAsync<OnboardingCompletionDto>();

            Validation = completion?.Validation;
            if (response.IsSuccessStatusCode && completion?.Success == true)
            {
                var authResponse = await Http.PostAsJsonAsync("api/auth/bootstrap", new { passcode = Passcode });
                if (!authResponse.IsSuccessStatusCode)
                {
                    ErrorMessage = "Onboarding completed but passcode setup failed. You may need to set it manually.";
                    Completed = true;
                    return;
                }

                Completed = true;
                StatusMessage = completion.Message;
                ErrorMessage = null;
                return;
            }

            ErrorMessage = completion?.Message ?? $"Completion failed ({(int)response.StatusCode})";
        });
    }

    private async Task<bool> SaveDraftInternal()
    {
        var response = await Http.PutAsJsonAsync("api/onboarding/draft", Draft);
        if (!response.IsSuccessStatusCode)
        {
            ErrorMessage = $"Draft save failed ({(int)response.StatusCode})";
            return false;
        }

        StatusMessage = "Draft configuration saved.";
        ErrorMessage = null;
        return true;
    }

    private async Task RunBusyAsync(Func<Task> action)
    {
        if (IsBusy) return;
        IsBusy = true;
        try
        {
            await action();
        }
        finally
        {
            IsBusy = false;
        }
    }

    private sealed record OnboardingStatusDto
    {
        public bool Completed { get; init; }
        public DateTimeOffset? CompletedAt { get; init; }
    }

    private sealed record OnboardingValidationStepDto
    {
        public string Step { get; init; } = "";
        public bool Success { get; init; }
        public string Message { get; init; } = "";
    }

    private sealed record OnboardingValidationDto
    {
        public bool Success { get; init; }
        public List<OnboardingValidationStepDto> Steps { get; init; } = [];
    }

    private sealed record OnboardingCompletionDto
    {
        public bool Success { get; init; }
        public string Message { get; init; } = "";
        public OnboardingValidationDto? Validation { get; init; }
    }

    private sealed class OnboardingDraftDto
    {
        public LiteLlmDto LiteLlm { get; init; } = new();
        public QdrantDto Qdrant { get; init; } = new();
        public SignalDto Signal { get; init; } = new();
        public WikiDto Wiki { get; init; } = new();
        public SchedulerDto Scheduler { get; init; } = new();
    }

    private sealed class LiteLlmDto
    {
        public string BaseUrl { get; set; } = "http://litellm:4000";
        public string ApiKey { get; set; } = "sk-LeanKernel-local";
        public string DefaultModel { get; set; } = "small";
        public string EmbeddingModel { get; set; } = "embedding-small";
        public int ContextWindowTokens { get; set; } = 128000;
    }

    private sealed class QdrantDto
    {
        public string Host { get; set; } = "qdrant";
        public int Port { get; set; } = 6334;
        public string CollectionName { get; set; } = "LEANKERNEL_wiki";
        public int EmbeddingDimension { get; set; } = 1536;
    }

    private sealed class SignalDto
    {
        public string CliPath { get; set; } = "/usr/bin/signal-cli";
        public string Account { get; set; } = "";
        public bool Enabled { get; set; } = true;
    }

    private sealed class WikiDto
    {
        public string BasePath { get; set; } = "/app/data/wiki";
        public int MaxFactsPerEntry { get; set; } = 20;
        public int StaleFactDays { get; set; } = 30;
        public double MinConfidenceThreshold { get; set; } = 0.5;
    }

    private sealed class SchedulerDto
    {
        public bool Enabled { get; set; } = true;
        public string WikiMaintenanceCron { get; set; } = "0 3 * * *";
    }
}
