@page "/files"
@using System.Diagnostics.CodeAnalysis
@using LeanKernel.Host.Services
@attribute [ExcludeFromCodeCoverage]
@inject FileBrowserService Browser
@rendermode InteractiveServer

<div class="page-header">
    <h1><span class="text-neon">▤</span> Files</h1>
    <p class="subtitle">Data directory browser</p>
</div>

<div class="files-layout">
    <!-- File tree -->
    <div class="glass-card files-tree-panel">
        <!-- Breadcrumb -->
        <div class="files-breadcrumb">
            <button class="btn-ghost" style="padding: 0.25rem 0.5rem; font-size: 0.8rem;"
                    @onclick="NavigateUp" disabled="@(CurrentPath == "")">
                ↑ Up
            </button>
            <span class="text-mono text-muted files-path">
                /@CurrentPath
            </span>
        </div>

        <ul class="file-tree" aria-label="File browser entries">
            @if (BrowseResult?.Entries is not null)
            {
                @foreach (var item in BrowseResult.Entries)
                {
                    <li class="file-item"
                        role="button"
                        tabindex="0"
                        aria-label="@(item.IsDirectory ? $"Open folder {item.Name}" : $"Preview file {item.Name}")"
                        @onclick="() => OnItemClick(item)"
                        @onkeydown="(e) => OnFileKeyDown(e, item)">
                        <span class="file-icon">@(item.IsDirectory ? "📁" : GetFileIcon(item.Name))</span>
                        <span>@item.Name</span>
                        @if (!item.IsDirectory)
                        {
                            <span class="file-size">@FormatSize(item.Size)</span>
                        }
                    </li>
                }

                @if (BrowseResult.Entries.Count == 0)
                {
                    <li class="empty-state">Empty directory</li>
                }
            }
        </ul>
    </div>

    <!-- File preview -->
    <div class="glass-card files-preview-panel">
        @if (FileContent is not null)
        {
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                <div>
                    <h3>@FileContent.Path</h3>
                    <span class="text-muted" style="font-size: 0.8rem;">@FormatSize(FileContent.Size)</span>
                </div>
                <button class="btn-ghost" @onclick="() => FileContent = null">✕</button>
            </div>
            <div class="log-viewer" style="max-height: none;">
                <pre class="file-preview-content">@FileContent.Content</pre>
            </div>
        }
        else if (FileError is not null)
        {
            <div class="error-state" role="alert">@FileError</div>
        }
        else
        {
            <div class="empty-state" style="height: 100%; display: grid; place-items: center;">
                Select a file to preview
            </div>
        }
    </div>
</div>

@code {
    private string CurrentPath = "";
    private FileBrowseResult? BrowseResult;
    private FileReadResult? FileContent;
    private string? FileError;

    protected override async Task OnInitializedAsync()
    {
        await Browse("");
    }

    private async Task Browse(string path)
    {
        CurrentPath = path;
        FileContent = null;
        FileError = null;
        BrowseResult = Browser.Browse(path);
        if (BrowseResult.Error is not null)
            FileError = BrowseResult.Error;
        await Task.CompletedTask;
    }

    private async Task OnItemClick(FileSystemItem item)
    {
        if (item.IsDirectory)
        {
            await Browse(item.Path);
        }
        else
        {
            await ReadFile(item.Path);
        }
    }

    private async Task OnFileKeyDown(KeyboardEventArgs e, FileSystemItem item)
    {
        if (e.Key is "Enter" or " ")
            await OnItemClick(item);
    }

    private async Task ReadFile(string path)
    {
        FileError = null;
        FileContent = await Browser.ReadAsync(path, CancellationToken.None);
        if (FileContent.Error is not null)
        {
            FileError = FileContent.Error;
            FileContent = null;
        }
    }

    private async Task NavigateUp()
    {
        if (string.IsNullOrEmpty(CurrentPath)) return;
        var parent = Path.GetDirectoryName(CurrentPath)?.Replace('\\', '/') ?? "";
        await Browse(parent);
    }

    private static string FormatSize(long bytes) =>
        bytes switch
        {
            < 1024 => $"{bytes} B",
            < 1_048_576 => $"{bytes / 1024.0:F1} KB",
            _ => $"{bytes / 1_048_576.0:F1} MB"
        };

    private static string GetFileIcon(string name) =>
        Path.GetExtension(name).ToLower() switch
        {
            ".json" => "📄",
            ".yaml" or ".yml" => "⚙️",
            ".log" => "📋",
            ".md" => "📝",
            ".cs" => "💎",
            ".sh" => "🔧",
            _ => "📄"
        };

}
