@page "/onboarding/agents"
@using System.Diagnostics.CodeAnalysis
@using System.Text.Json
@using System.Net.Http.Json
@attribute [ExcludeFromCodeCoverage]
@inject HttpClient Http
@inject NavigationManager Nav
@rendermode InteractiveServer

<div class="page-header">
    <h1><span class="text-neon"><LeanKernelIcon Name="settings" /></span> Configure Agent Rules</h1>
    <p class="subtitle">Define engagement rules, autonomy scope, and time boundaries</p>
</div>

@if (IsLoading)
{
    <div class="glass-card" style="text-align: center; padding: 2.5rem;">
        <p class="text-muted">Loading agent presets...</p>
    </div>
}
else if (ShowAgentsMdEditor)
{
    <div class="content-grid stagger-in">
        <!-- Preset Selection -->
        <div class="glass-card">
            <h3 class="text-cyan">1) Choose a Preset</h3>
            <p class="text-muted" style="margin-bottom: 1rem; font-size: 0.85rem;">
                Select a preset to initialize your AGENTS.md file with recommended defaults.
            </p>
            <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
                @foreach (var preset in Presets)
                {
                    <button 
                        class="@($"btn-preset {(SelectedPreset == preset.Name ? "active" : "")}")"
                        @onclick="() => SelectPreset(preset)">
                        <strong>@preset.DisplayName</strong>
                        <span class="preset-desc">@preset.Description</span>
                    </button>
                }
            </div>
            @if (SelectedPreset != null)
            {
                <div style="margin-top: 1rem; text-align: center;">
                    <button class="btn-primary" @onclick="InitializeAgents" disabled="@IsBusy">
                        Initialize with @SelectedPreset
                    </button>
                </div>
            }
        </div>

        <!-- Section Editor (if AGENTS.md exists) -->
        @if (AgentsMdExists)
        {
            <div class="glass-card">
                <h3 class="text-cyan">2) Edit Sections</h3>
                <p class="text-muted" style="margin-bottom: 1rem; font-size: 0.85rem;">
                    Update specific sections of your AGENTS.md file. Each change is saved immediately.
                </p>
                
                <div style="margin-bottom: 1rem;">
                    <label class="setting-label">Section to Edit:</label>
                    <select class="setting-input" @onchange="e => SelectSection(e.Value?.ToString())">
                        <option value="">-- Select section --</option>
                        <option value="Agent Personality">Agent Personality</option>
                        <option value="Scope of Autonomy">Scope of Autonomy</option>
                        <option value="Time Boundaries">Time Boundaries</option>
                        <option value="Communication Rules">Communication Rules</option>
                        <option value="Action Follow-Up">Action Follow-Up</option>
                        <option value="Knowledge Management">Knowledge Management</option>
                        <option value="Privacy &amp; Safety">Privacy &amp; Safety</option>
                    </select>
                </div>

                @if (!string.IsNullOrEmpty(SelectedSection))
                {
                    <div>
                        <label class="setting-label">Content for @SelectedSection:</label>
                        <textarea 
                            class="setting-textarea" 
                            style="font-family: monospace; min-height: 200px; width: 100%;"
                            @bind="SectionContent"
                            placeholder="Enter section content..."
                        ></textarea>
                        <div style="margin-top: 0.75rem; display: flex; gap: 0.5rem;">
                            <button class="btn-primary" @onclick="UpdateSection" disabled="@IsBusy">
                                Save Section
                            </button>
                            <button class="btn-ghost" @onclick="ResetSection">Reset</button>
                        </div>
                    </div>
                }
            </div>

            <!-- Validation -->
            <div class="glass-card">
                <h3 class="text-cyan">3) Validate Configuration</h3>
                <p class="text-muted" style="margin-bottom: 1rem; font-size: 0.85rem;">
                    Check that your AGENTS.md file is valid and properly formatted.
                </p>
                <button class="btn-primary" @onclick="ValidateAgents" disabled="@IsBusy">
                    Validate AGENTS.md
                </button>
                
                @if (ValidationResult != null)
                {
                    <div style="margin-top: 1rem;">
                        @if (ValidationResult.IsValid)
                        {
                            <div class="validation-success">
                                <p style="margin: 0;"><strong>[PASS] AGENTS.md is valid</strong></p>
                            </div>
                        }
                        else
                        {
                            <div class="validation-error">
                                <p style="margin: 0; margin-bottom: 0.5rem;"><strong>[FAIL] Validation failed</strong></p>
                                @foreach (var error in ValidationResult.Errors)
                                {
                                    <p style="margin: 0.25rem 0; font-size: 0.85rem;">- @error</p>
                                }
                            </div>
                        }
                        @if (ValidationResult.Warnings.Any())
                        {
                            <div style="margin-top: 0.75rem; padding: 0.75rem; background: rgba(255, 193, 7, 0.1); border-left: 3px solid var(--neon-warning); border-radius: 4px;">
                                <p style="margin: 0; margin-bottom: 0.5rem;"><strong>[WARN] Warnings</strong></p>
                                @foreach (var warning in ValidationResult.Warnings)
                                {
                                    <p style="margin: 0.25rem 0; font-size: 0.85rem;">- @warning</p>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }

        <!-- Status Messages -->
        @if (!string.IsNullOrWhiteSpace(StatusMessage))
        {
            <div class="glass-card" style="background: rgba(0, 255, 136, 0.05); border-left: 3px solid var(--neon-success);">
                <p style="margin: 0; color: var(--neon-success);">[OK] @StatusMessage</p>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="glass-card" style="background: rgba(255, 0, 127, 0.05); border-left: 3px solid var(--neon-danger);">
                <p style="margin: 0; color: var(--neon-danger);">[ERROR] @ErrorMessage</p>
            </div>
        }
    </div>

    <!-- Navigation -->
    <div class="glass-card" style="margin-top: 1.5rem;">
        <div style="display: flex; gap: 0.75rem; justify-content: space-between;">
            <button class="btn-ghost" @onclick="BackToOnboarding">
                Back to Onboarding
            </button>
            @if (AgentsMdExists)
            {
                <button class="btn-primary" @onclick="NextStep">
                    Next Step
                </button>
            }
        </div>
    </div>
}

@code {
    private bool IsLoading = true;
    private bool IsBusy = false;
    private bool ShowAgentsMdEditor = true;
    private bool AgentsMdExists = false;

    private List<AgentsPreset> Presets = new();
    private string? SelectedPreset = null;
    private string? SelectedSection = null;
    private string SectionContent = "";
    private string OriginalSectionContent = "";

    private string? StatusMessage = null;
    private string? ErrorMessage = null;
    private AgentsValidateResponse? ValidationResult = null;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            IsLoading = true;
            await LoadPresets();
            await CheckAgentsMdStatus();
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task LoadPresets()
    {
        try
        {
            Presets = await Http.GetFromJsonAsync<List<AgentsPreset>>("/api/onboarding/agents/presets") ?? new();
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to load presets: {ex.Message}";
        }
    }

    private async Task CheckAgentsMdStatus()
    {
        try
        {
            var result = await Http.GetFromJsonAsync<AgentsValidateResponse>("/api/onboarding/agents/validate");
            if (result != null)
            {
                AgentsMdExists = result.Success;
                ValidationResult = result;
            }
        }
        catch
        {
            // AGENTS.md doesn't exist yet
            AgentsMdExists = false;
        }
    }

    private void SelectPreset(AgentsPreset preset)
    {
        SelectedPreset = preset.Name;
        StatusMessage = null;
        ErrorMessage = null;
    }

    private async Task InitializeAgents()
    {
        if (string.IsNullOrEmpty(SelectedPreset))
            return;

        try
        {
            IsBusy = true;
            StatusMessage = null;
            ErrorMessage = null;

            var request = new { PresetName = SelectedPreset };
            var response = await Http.PostAsJsonAsync("/api/onboarding/agents/initialize", request);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<AgentsInitializeResponse>();
                if (result != null && result.Success)
                {
                    StatusMessage = $"AGENTS.md initialized with {SelectedPreset} preset";
                    await CheckAgentsMdStatus();
                    SelectedPreset = null;
                }
                else
                {
                    ErrorMessage = result?.Message ?? "Failed to initialize AGENTS.md";
                }
            }
            else
            {
                ErrorMessage = "Failed to initialize AGENTS.md";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task SelectSection(string? section)
    {
        if (string.IsNullOrEmpty(section))
        {
            SelectedSection = null;
            SectionContent = "";
            OriginalSectionContent = "";
            return;
        }

        SelectedSection = section;
        SectionContent = "";
        OriginalSectionContent = "";
        StatusMessage = null;
        ErrorMessage = null;
    }

    private async Task UpdateSection()
    {
        if (string.IsNullOrEmpty(SelectedSection) || string.IsNullOrEmpty(SectionContent))
            return;

        try
        {
            IsBusy = true;
            StatusMessage = null;
            ErrorMessage = null;

            var request = new { SectionName = SelectedSection, Content = SectionContent };
            var response = await Http.PostAsJsonAsync($"/api/onboarding/agents/sections/{SelectedSection}", request);

            if (response.IsSuccessStatusCode)
            {
                StatusMessage = $"Section '{SelectedSection}' updated";
                await ValidateAgents();
            }
            else
            {
                ErrorMessage = "Failed to update section";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private void ResetSection()
    {
        SectionContent = OriginalSectionContent;
    }

    private async Task ValidateAgents()
    {
        try
        {
            IsBusy = true;
            var result = await Http.GetFromJsonAsync<AgentsValidateResponse>("/api/onboarding/agents/validate");

            if (result != null)
            {
                ValidationResult = result;
                if (ValidationResult.IsValid)
                {
                    StatusMessage = "AGENTS.md is valid";
                }
                else
                {
                    ErrorMessage = "AGENTS.md validation failed";
                }
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Validation error: {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private void BackToOnboarding()
    {
        Nav.NavigateTo("/onboarding");
    }

    private void NextStep()
    {
        Nav.NavigateTo("/onboarding");
    }

    // DTO Classes
    private class AgentsPreset
    {
        public string Name { get; set; } = "";
        public string DisplayName { get; set; } = "";
        public string Description { get; set; } = "";
    }

    private class AgentsInitializeResponse
    {
        public bool Success { get; set; }
        public string Message { get; set; } = "";
    }

    private class AgentsValidateResponse
    {
        public bool Success { get; set; }
        public bool IsValid { get; set; }
        public List<string> Errors { get; set; } = new();
        public List<string> Warnings { get; set; } = new();
    }
}

<style>
.btn-preset {
    padding: 1rem;
    background: rgba(0, 200, 255, 0.05);
    border: 2px solid rgba(0, 200, 255, 0.3);
    border-radius: 8px;
    color: var(--text-color);
    cursor: pointer;
    flex: 1;
    min-width: 200px;
    text-align: center;
    transition: all 0.3s ease;
}

.btn-preset:hover {
    background: rgba(0, 200, 255, 0.1);
    border-color: rgba(0, 200, 255, 0.6);
}

.btn-preset.active {
    background: rgba(0, 200, 255, 0.2);
    border-color: var(--neon-primary);
    box-shadow: 0 0 12px rgba(0, 200, 255, 0.3);
}

.preset-desc {
    display: block;
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.5rem;
    font-weight: normal;
}

.setting-textarea {
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(0, 200, 255, 0.2);
    border-radius: 4px;
    color: var(--text-color);
    padding: 0.75rem;
    font-size: 0.9rem;
}

.setting-textarea:focus {
    outline: none;
    border-color: var(--neon-primary);
    box-shadow: 0 0 8px rgba(0, 200, 255, 0.2);
}

.validation-success {
    padding: 0.75rem;
    background: rgba(0, 255, 136, 0.1);
    border-left: 3px solid var(--neon-success);
    border-radius: 4px;
    color: var(--neon-success);
}

.validation-error {
    padding: 0.75rem;
    background: rgba(255, 0, 127, 0.1);
    border-left: 3px solid var(--neon-danger);
    border-radius: 4px;
    color: var(--neon-danger);
}
</style>
