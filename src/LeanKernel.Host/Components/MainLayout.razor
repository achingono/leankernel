@inherits LayoutComponentBase
@using System.Diagnostics.CodeAnalysis
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components.Authorization
@attribute [ExcludeFromCodeCoverage]
@inject HttpClient Http
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@implements IDisposable

<div class="LeanKernel-layout">
    <!-- Sidebar Navigation -->
    <nav class="LeanKernel-sidebar @(SidebarCollapsed ? "collapsed" : "")" aria-label="Main navigation">
        <div class="sidebar-header">
            <img src="brand/logo-mark.png" class="LeanKernel-logo" alt="LeanKernel logo" />
            @if (!SidebarCollapsed)
            {
                <span class="LeanKernel-title">LeanKernel</span>
            }
            <button class="sidebar-toggle"
                    @onclick="ToggleSidebar"
                    aria-label="@(SidebarCollapsed ? "Expand sidebar" : "Collapse sidebar")"
                    aria-expanded="@(!SidebarCollapsed)">
                <LeanKernelIcon Name="@(SidebarCollapsed ? "chevron-right" : "chevron-left")" Class="sidebar-toggle-icon" />
            </button>
        </div>

        <div class="sidebar-nav" role="list">
            @if (OnboardingIncomplete)
            {
                <NavLink href="/onboarding" class="nav-item" role="listitem" aria-label="Onboarding">
                    <LeanKernelIcon Name="onboarding" Class="nav-icon" />
                    @if (!SidebarCollapsed) { <span>Onboarding</span> }
                </NavLink>
            }
            else if (!IsAuthenticated)
            {
                <NavLink href="/login" class="nav-item" role="listitem" aria-label="Login">
                    <LeanKernelIcon Name="lock" Class="nav-icon" />
                    @if (!SidebarCollapsed) { <span>Login</span> }
                </NavLink>
            }
            else
            {
                <NavLink href="/" class="nav-item" Match="NavLinkMatch.All" role="listitem" aria-label="Dashboard">
                    <LeanKernelIcon Name="dashboard" Class="nav-icon" />
                    @if (!SidebarCollapsed) { <span>Dashboard</span> }
                </NavLink>
                <NavLink href="/chat" class="nav-item" role="listitem" aria-label="Chat">
                    <LeanKernelIcon Name="chat" Class="nav-icon" />
                    @if (!SidebarCollapsed) { <span>Chat</span> }
                </NavLink>
                <NavLink href="/wiki" class="nav-item" role="listitem" aria-label="Wiki">
                    <LeanKernelIcon Name="wiki" Class="nav-icon" />
                    @if (!SidebarCollapsed) { <span>Wiki</span> }
                </NavLink>
                <NavLink href="/logs" class="nav-item" role="listitem" aria-label="Logs">
                    <LeanKernelIcon Name="logs" Class="nav-icon" />
                    @if (!SidebarCollapsed) { <span>Logs</span> }
                </NavLink>
                <NavLink href="/files" class="nav-item" role="listitem" aria-label="Files">
                    <LeanKernelIcon Name="files" Class="nav-icon" />
                    @if (!SidebarCollapsed) { <span>Files</span> }
                </NavLink>
                <NavLink href="/settings" class="nav-item" role="listitem" aria-label="Settings">
                    <LeanKernelIcon Name="settings" Class="nav-icon" />
                    @if (!SidebarCollapsed) { <span>Settings</span> }
                </NavLink>
                <NavLink href="/admin/routing" class="nav-item" role="listitem" aria-label="Routing">
                    <LeanKernelIcon Name="routing" Class="nav-icon" />
                    @if (!SidebarCollapsed) { <span>Routing</span> }
                </NavLink>
                <NavLink href="/admin/routing-config" class="nav-item" role="listitem" aria-label="Routing Config">
                    <LeanKernelIcon Name="routing" Class="nav-icon" />
                    @if (!SidebarCollapsed) { <span>Route Config</span> }
                </NavLink>

                <div class="nav-spacer"></div>
                <button class="nav-item nav-logout" @onclick="LogoutAsync" aria-label="Logout">
                    <LeanKernelIcon Name="logout" Class="nav-icon" />
                    @if (!SidebarCollapsed) { <span>Logout</span> }
                </button>
            }
        </div>
    </nav>

    <!-- Main Content -->
    <main class="LeanKernel-main" role="main">
        <div class="noise-overlay" aria-hidden="true"></div>
        @Body
    </main>
</div>

@code {
    private bool SidebarCollapsed { get; set; }
    private bool OnboardingIncomplete { get; set; }
    private bool IsAuthenticated { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += HandleLocationChanged;
        await RefreshStateAsync();
    }

    private void ToggleSidebar() => SidebarCollapsed = !SidebarCollapsed;

    private async void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await RefreshStateAsync();
    }

    private async Task RefreshStateAsync()
    {
        try
        {
            var status = await Http.GetFromJsonAsync<OnboardingStatusDto>("api/onboarding/status");
            OnboardingIncomplete = status?.Completed != true;
        }
        catch
        {
            OnboardingIncomplete = true;
        }

        if (!OnboardingIncomplete)
        {
            try
            {
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                IsAuthenticated = authState.User.Identity?.IsAuthenticated ?? false;
            }
            catch
            {
                IsAuthenticated = false;
            }
        }

        var relativePath = Nav.ToBaseRelativePath(Nav.Uri).Split('?', 2)[0];
        if (OnboardingIncomplete &&
            !relativePath.StartsWith("onboarding", StringComparison.OrdinalIgnoreCase))
        {
            Nav.NavigateTo("/onboarding");
        }
        else if (!OnboardingIncomplete && !IsAuthenticated &&
                 !relativePath.StartsWith("login", StringComparison.OrdinalIgnoreCase) &&
                 !relativePath.StartsWith("onboarding", StringComparison.OrdinalIgnoreCase))
        {
            Nav.NavigateTo("/login");
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task LogoutAsync()
    {
        try
        {
            await Http.PostAsync("api/auth/logout", null);
        }
        catch { }
        IsAuthenticated = false;
        Nav.NavigateTo("/login");
    }

    public void Dispose()
    {
        Nav.LocationChanged -= HandleLocationChanged;
    }

    private sealed record OnboardingStatusDto
    {
        public bool Completed { get; init; }
    }

}
